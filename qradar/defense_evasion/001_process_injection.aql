FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreateTime%'
  AND NOT (UTF8(payload) ILIKE '%installer%'
    OR UTF8(payload) ILIKE '%msiexec%'
    OR UTF8(payload) ILIKE '%setup%')
LAST 1440 MINUTES;


-- ==================================================
