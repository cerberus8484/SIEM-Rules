    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%mavinject%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-102006 | T1055 | VirtualAllocEx / WriteProcessMemory in PS Script
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%VirtualAllocEx%'
    OR UTF8(payload) ILIKE '%WriteProcessMemory%'
    OR UTF8(payload) ILIKE '%CreateRemoteThread%'
    OR UTF8(payload) ILIKE '%NtCreateThreadEx%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102007 | T1055 | Shellcode Byte Array in PowerShell
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%[Byte[]]%'
    OR UTF8(payload) ILIKE '%[byte[]]%'
    OR UTF8(payload) ILIKE '%0xfc,0x48%'
    OR UTF8(payload) ILIKE '%0x4d,0x5a%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102008 | T1055.004 | APC Injection via NtQueueApcThread
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%NtQueueApcThread%'
    OR UTF8(payload) ILIKE '%QueueUserAPC%'
    OR UTF8(payload) ILIKE '%EarlyBird%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102009 | T1574.001 | DLL Sideloading from Application Directory
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND NOT UTF8(payload) ILIKE '%Signed>true%'
  AND (UTF8(payload) ILIKE '%\Program Files\%'
    OR UTF8(payload) ILIKE '%\Program Files (x86)\%')
  AND (UTF8(payload) ILIKE '%.dll%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102010 | T1574 | DLL Loaded from User-Writable Path
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Public\%')
  AND NOT UTF8(payload) ILIKE '%Signed>true%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-102011 | T1134.002 | PPID Spoofing from Office / Browser
