-- ==================================================
-- QR-102018 | T1562.002 | Windows Event Log Service Stopped
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7036<%'
    OR UTF8(payload) ILIKE '%EventID">"7036"%')
  AND UTF8(payload) ILIKE '%EventLog%'
  AND UTF8(payload) ILIKE '%stopped%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-102019 | T1553 | Binary with Invalid/Expired Signature in Staging
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%SignatureStatus>Invalid%'
    OR UTF8(payload) ILIKE '%SignatureStatus>Expired%')
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102020 | T1036.005 | Double Extension Masquerade (.pdf.exe)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%FileCreate%'
    OR UTF8(payload) ILIKE '%ProcessCreate%')
  AND (UTF8(payload) ILIKE '%.pdf.exe%'
    OR UTF8(payload) ILIKE '%.doc.exe%'
    OR UTF8(payload) ILIKE '%.jpg.exe%'
    OR UTF8(payload) ILIKE '%.txt.exe%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102021 | T1027 | Alternate Data Stream (ADS) Execution
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%:%'
  AND (UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%powershell%')
  AND (UTF8(payload) ILIKE '%.exe:%'
    OR UTF8(payload) ILIKE '%.txt:%'
    OR UTF8(payload) ILIKE '%:Zone.Identifier%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102022 | T1562.004 | Netsh Firewall Disable
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%netsh%'
  AND (UTF8(payload) ILIKE '%firewall set opmode disable%'
    OR UTF8(payload) ILIKE '%advfirewall set allprofiles state off%'
    OR UTF8(payload) ILIKE '%firewall%disable%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102023 | T1027 | Long Command Line / Unicode Obfuscation
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND LEN(UTF8(payload)) > 1000
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%rundll32%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102024 | T1055 | Full-Access Handle to Legitimate Process
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessAccess%'
  AND UTF8(payload) ILIKE '%0x1fffff%'
  AND (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%explorer%'
    OR UTF8(payload) ILIKE '%chrome%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102025 | T1562 | Security Event Log Registry Tamper
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND (UTF8(payload) ILIKE '%SYSTEM\CurrentControlSet\Services\EventLog%'
    OR UTF8(payload) ILIKE '%Microsoft-Windows-Security%')
  AND NOT (UTF8(payload) ILIKE '%services%'
    OR UTF8(payload) ILIKE '%system%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102026 | T1036.004 | Fake Svchost Path (Masquerading)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%svchost%'
  AND NOT (UTF8(payload) ILIKE '%\System32\svchost%'
    OR UTF8(payload) ILIKE '%\SysWOW64\svchost%')
  AND NOT UTF8(payload) ILIKE '%services.exe%'
LAST 1440 MINUTES;


