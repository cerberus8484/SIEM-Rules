-- ==================================================
-- QR-102034 | T1070 | MOTW Zone.Identifier Removal (attrib / Remove-Item)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%')
  AND (UTF8(payload) ILIKE '%Zone.Identifier%')
  AND (UTF8(payload) ILIKE '%attrib%'
    OR UTF8(payload) ILIKE '%Remove-Item%'
    OR UTF8(payload) ILIKE '%streams.exe%'
    OR UTF8(payload) ILIKE '%-d%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102035 | T1036 | Phantom / Missing DLL Loaded from System32 Staging
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%wlbsctrl.dll%'
    OR UTF8(payload) ILIKE '%comsvcs.dll%'
    OR UTF8(payload) ILIKE '%wbemcomn.dll%'
    OR UTF8(payload) ILIKE '%wbemprox.dll%')
  AND NOT UTF8(payload) ILIKE '%\Windows\System32\%'
LAST 1440 MINUTES;
