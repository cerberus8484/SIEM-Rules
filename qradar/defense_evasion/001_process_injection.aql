-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Defense Evasion — Process Injection / Hollowing / Log Tamper (T1055, T1562)
-- Batch    : 9 / Defense Evasion
-- Rules    : QR-102001 – QR-102035
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Sysmon (8/10/7/11/25), Windows Security, PowerShell (4104)
-- ============================================================

-- ==================================================
-- QR-102001 | T1055.003 | CreateRemoteThread (Sysmon 8)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%CreateRemoteThread%'
  AND NOT (UTF8(payload) ILIKE '%antimalware%'
    OR UTF8(payload) ILIKE '%MsMpEng%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-102002 | T1055.001 | CreateRemoteThread into LSASS
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%CreateRemoteThread%'
  AND UTF8(payload) ILIKE '%lsass%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-102003 | T1055 | CreateRemoteThread into Browser Process
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%CreateRemoteThread%'
  AND (UTF8(payload) ILIKE '%chrome%'
    OR UTF8(payload) ILIKE '%firefox%'
    OR UTF8(payload) ILIKE '%msedge%'
    OR UTF8(payload) ILIKE '%iexplore%')
LAST 1440 MINUTES;


