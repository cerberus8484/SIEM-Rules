    OR UTF8(payload) ILIKE '%pagekite.me%'
    OR UTF8(payload) ILIKE '%localtunnel.me%'
    OR UTF8(payload) ILIKE '%bore.pub%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104032 | T1071 | Process in TEMP Path Making Outbound Connection
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\Local\Temp\%')
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '127.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104033 | T1071 | Keep-Alive Beaconing — 10+ Same-Host Same-Port (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 10+ connections to same ip:port in 5 min
-- ==================================================
SELECT
  destinationip,
  destinationport,
  COUNT(*) AS BeaconCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '127.%')
GROUP BY destinationip, destinationport
HAVING COUNT(*) >= 10
LAST 300 MINUTES;


-- ==================================================
-- QR-104034 | T1071 | VNC Port 5900-5909 Non-Enterprise Connection
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Firewall%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Netflow%')
  AND destinationport BETWEEN 5900 AND 5909
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104035 | T1571 | BitTorrent Ports 6881-6890 from Non-Torrent Process
-- Severity: Medium | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport BETWEEN 6881 AND 6890
  AND NOT (UTF8(payload) ILIKE '%bittorrent%'
    OR UTF8(payload) ILIKE '%qbittorrent%'
    OR UTF8(payload) ILIKE '%utorrent%')
LAST 1440 MINUTES;
