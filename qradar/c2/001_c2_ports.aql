-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Command & Control — Ports / Tunneling / Frameworks (T1071, T1095, T1571)
-- Batch    : 8 / C2
-- Rules    : QR-104001 – QR-104035
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Sysmon (Event 3/22), Windows Firewall, Netflow, WinCollect
-- ============================================================

-- ==================================================
-- QR-104001 | T1571 | Known C2 Port Used (4444/1337/31337)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Firewall%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Netflow%')
  AND destinationport IN (1234, 1337, 4242, 4444, 4445, 4446, 31337, 65535)
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '172.16.%'
    OR destinationip ILIKE '172.17.%'
    OR destinationip ILIKE '172.18.%'
    OR destinationip ILIKE '172.19.%'
    OR destinationip ILIKE '172.2%.%'
    OR destinationip ILIKE '172.30.%'
    OR destinationip ILIKE '172.31.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104002 | T1571 | Non-Browser Process Using Port 443 (HTTPS C2)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport = 443
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%cscript%'
    OR UTF8(payload) ILIKE '%mshta%'
    OR UTF8(payload) ILIKE '%rundll32%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104003 | T1571 | Cobalt Strike Default Ports (50050/7443/2222)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Firewall%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Netflow%')
  AND destinationport IN (50050, 50051, 50052, 50053, 7443, 2222, 8443)
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104004 | T1090.001 | Ngrok / Frpc Tunnel Detected
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%ngrok%'
    OR UTF8(payload) ILIKE '%frpc%'
    OR UTF8(payload) ILIKE '%cloudflared%'
    OR UTF8(payload) ILIKE '%bore.pub%'
    OR UTF8(payload) ILIKE '%serveo.net%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104005 | T1071.001 | DNS to Non-Standard Port from Non-DNS Process
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport = 53
  AND NOT (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%dns%'
    OR UTF8(payload) ILIKE '%resolver%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104006 | T1071.004 | DNS Tunneling — Long Subdomain Query
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%DnsQuery%'
  AND LEN(UTF8(payload)) > 400
LAST 1440 MINUTES;


-- ==================================================
-- QR-104007 | T1071.004 | DNS TXT Record Query (Data Exfil / C2 Config)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%DnsQuery%'
  AND UTF8(payload) ILIKE '%QueryType>16<%'
  AND NOT (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%dns%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104008 | T1095 | Netcat with Shell Execution
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%nc.exe%'
    OR UTF8(payload) ILIKE '%ncat%'
    OR UTF8(payload) ILIKE '%netcat%')
  AND (UTF8(payload) ILIKE '%-e %'
    OR UTF8(payload) ILIKE '%-exec %'
    OR UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%powershell%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-104009 | T1090.001 | SSH Reverse Tunnel (-R Flag)
