    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%ssh%'
  AND (UTF8(payload) ILIKE '% -R %'
    OR UTF8(payload) ILIKE '% -L %'
    OR UTF8(payload) ILIKE '% -D %')
  AND NOT UTF8(payload) ILIKE '%openssh%windows%'
LAST 1440 MINUTES;


