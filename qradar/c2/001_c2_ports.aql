-- ==================================================
-- QR-104019 | T1071 | Beaconing Pattern — 5+ Connections to Same IP (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 5+ outbound connections to same external IP in 6 minutes
-- ==================================================
SELECT
  destinationip,
  COUNT(*) AS ConnectionCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '172.1%.%'
    OR destinationip ILIKE '127.%')
  AND destinationport IN (80, 443, 8080, 8443)
GROUP BY destinationip
HAVING COUNT(*) >= 5
LAST 360 MINUTES;


