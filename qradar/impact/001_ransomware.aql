-- ==================================================
-- QR-108008 | T1489 | Critical Service Stopped (Event 7036 — SQL / Exchange / DC)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7036<%'
    OR UTF8(payload) ILIKE '%EventID">"7036"%')
  AND UTF8(payload) ILIKE '%stopped%'
  AND (UTF8(payload) ILIKE '%MSSQL%'
    OR UTF8(payload) ILIKE '%MSExchange%'
    OR UTF8(payload) ILIKE '%DNS Server%'
    OR UTF8(payload) ILIKE '%Netlogon%'
    OR UTF8(payload) ILIKE '%CrowdStrike%'
    OR UTF8(payload) ILIKE '%MSSQLServer%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108009 | T1489 | Mass Service Stop via sc.exe (Threshold)
-- Severity: Critical | Confidence: High
-- Threshold: 5+ service stop commands in 60 seconds
-- ==================================================
SELECT
  username,
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS ServiceStops
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc%'
  AND UTF8(payload) ILIKE '% stop%'
GROUP BY username, LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 5
LAST 1 MINUTES;


-- ==================================================
-- QR-108010 | T1486 | File Extension Changed to Known Ransomware Ext (FileRename)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreateStreamHash%'
  AND (UTF8(payload) ILIKE '%.akira%'
    OR UTF8(payload) ILIKE '%.alphv%'
    OR UTF8(payload) ILIKE '%.noberus%'
    OR UTF8(payload) ILIKE '%.phobos%'
    OR UTF8(payload) ILIKE '%.dharma%'
    OR UTF8(payload) ILIKE '%.makop%'
    OR UTF8(payload) ILIKE '%.babuk%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108011 | T1485 | Recursive File Deletion (rd /s /q or Remove-Item -Recurse)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%rd /s /q%'
    OR UTF8(payload) ILIKE '%rmdir /s%'
    OR UTF8(payload) ILIKE '%Remove-Item -Recurse%')
  AND (UTF8(payload) ILIKE '%C:\Users\%'
    OR UTF8(payload) ILIKE '%C:\Windows\%'
    OR UTF8(payload) ILIKE '%C:\ProgramData\%')
LAST 1440 MINUTES;


