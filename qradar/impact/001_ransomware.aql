-- ==================================================
-- QR-108021 | T1490 | Firewall Rules Flushed (netsh advfirewall reset)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%netsh%'
  AND (UTF8(payload) ILIKE '%firewall reset%'
    OR UTF8(payload) ILIKE '%advfirewall reset%'
    OR UTF8(payload) ILIKE '%advfirewall set allprofiles state off%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108022 | T1489 | Stopping Hyper-V VMs (Stop-VM / virsh destroy)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Stop-VM%'
    OR UTF8(payload) ILIKE '%Get-VM%')
  AND NOT username ILIKE '%admin%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-108023 | T1486 | CryptAPI / BCryptEncrypt Called by Non-standard Process
-- Severity: Critical | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%bcrypt.dll%'
    OR UTF8(payload) ILIKE '%cryptsp.dll%')
  AND NOT (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%lsass%'
    OR UTF8(payload) ILIKE '%explorer%'
    OR UTF8(payload) ILIKE '%system32%')
LAST 1440 MINUTES;


