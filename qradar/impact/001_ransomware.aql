-- ==================================================
-- QR-108015 | T1486 | Encrypting Sensitive Directory Trees
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\Documents\%'
    OR UTF8(payload) ILIKE '%\Desktop\%'
    OR UTF8(payload) ILIKE '%\Finance\%'
    OR UTF8(payload) ILIKE '%\Accounting\%'
    OR UTF8(payload) ILIKE '%\HR\%')
  AND (UTF8(payload) ILIKE '%.enc%'
    OR UTF8(payload) ILIKE '%.cry%'
    OR UTF8(payload) ILIKE '%.lock%')
LAST 1440 MINUTES;


