-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Impact / Ransomware (T1486, T1489, T1490, T1485, T1491)
-- Batch    : 13 / Impact
-- Rules    : QR-108001 – QR-108030
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows (4688/7036), Sysmon (1/2/11), PowerShell
-- ============================================================

-- ==================================================
-- QR-108001 | T1486 | Mass File Rename with Known Ransomware Extension
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%FileCreate%'
    OR UTF8(payload) ILIKE '%FileRename%')
  AND (UTF8(payload) ILIKE '%.locked%'
    OR UTF8(payload) ILIKE '%.encrypted%'
    OR UTF8(payload) ILIKE '%.ryuk%'
    OR UTF8(payload) ILIKE '%.conti%'
    OR UTF8(payload) ILIKE '%.lockbit%'
    OR UTF8(payload) ILIKE '%.hive%'
    OR UTF8(payload) ILIKE '%.blackcat%'
    OR UTF8(payload) ILIKE '%.cl0p%'
    OR UTF8(payload) ILIKE '%.wnry%'
    OR UTF8(payload) ILIKE '%.wncry%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108002 | T1486 | High Volume File Modification Rate (Threshold)
-- Severity: Critical | Confidence: High
-- Threshold: 100+ file writes to same volume in 5 minutes
-- ==================================================
SELECT
  username,
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS FileOps
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%FileCreate%'
    OR UTF8(payload) ILIKE '%FileRename%')
  AND (UTF8(payload) ILIKE '%C:\Users\%'
    OR UTF8(payload) ILIKE '%C:\Documents%'
    OR UTF8(payload) ILIKE '%\\%\%')
GROUP BY username, LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 100
LAST 5 MINUTES;


-- ==================================================
-- QR-108003 | T1486 | README / Ransom Note File Created
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%READ_ME%'
    OR UTF8(payload) ILIKE '%DECRYPT%'
    OR UTF8(payload) ILIKE '%HOW_TO_RECOVER%'
    OR UTF8(payload) ILIKE '%RESTORE_FILES%'
    OR UTF8(payload) ILIKE '%YOUR_FILES%'
    OR UTF8(payload) ILIKE '%RANSOM%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108004 | T1490 | Shadow Copy Deletion (vssadmin delete shadows)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%vssadmin%'
    OR UTF8(payload) ILIKE '%wmic shadowcopy%')
  AND (UTF8(payload) ILIKE '%delete%'
    OR UTF8(payload) ILIKE '%Delete%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108005 | T1490 | Shadow Copy Deletion via PowerShell (Get-WmiObject)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Win32_ShadowCopy%'
    OR UTF8(payload) ILIKE '%Get-WmiObject%')
  AND (UTF8(payload) ILIKE '%.Delete()%'
    OR UTF8(payload) ILIKE '%Remove-WmiObject%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108006 | T1490 | Disable Automatic System Repair (bcdedit)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%bcdedit%'
  AND (UTF8(payload) ILIKE '%recoveryenabled no%'
    OR UTF8(payload) ILIKE '%bootstatuspolicy ignoreallfailures%'
    OR UTF8(payload) ILIKE '%safeboot%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108007 | T1490 | wbadmin Delete System State Backup
