-- ==================================================
-- QR-108029 | T1490 | registry key SafeBoot Deleted / Modified
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND (UTF8(payload) ILIKE '%SafeBoot%'
    OR UTF8(payload) ILIKE '%BootExecute%')
  AND (UTF8(payload) ILIKE '%SetValue%'
    OR UTF8(payload) ILIKE '%DeleteValue%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-108030 | T1486 | Ransomware Campaign Combo: Shadow Deletion + BCDedit + File Rename
-- Severity: Critical | Confidence: High
-- Threshold: All 3 indicators from same host in 30 minutes
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(DISTINCT UTF8(payload)) AS RansomIndicators
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%vssadmin%delete%'
    OR UTF8(payload) ILIKE '%bcdedit%recoveryenabled no%'
    OR UTF8(payload) ILIKE '%FileCreate%.locked%'
    OR UTF8(payload) ILIKE '%wbadmin%delete%')
GROUP BY LOGSOURCENAME(logsourceid)
HAVING COUNT(DISTINCT UTF8(payload)) >= 2
LAST 30 MINUTES;
