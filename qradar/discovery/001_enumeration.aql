-- ==================================================
-- QR-106019 | T1018 | Remote System Discovery (Invoke-HostEnum / nmap via PS)
-- Severity: Medium | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Invoke-HostEnum%'
    OR UTF8(payload) ILIKE '%Test-NetConnection%'
    OR UTF8(payload) ILIKE '%1..254 |%'
    OR UTF8(payload) ILIKE '%ForEach-Object%')
  AND UTF8(payload) ILIKE '%.%'
  AND (UTF8(payload) ILIKE '%445%'
    OR UTF8(payload) ILIKE '%3389%'
    OR UTF8(payload) ILIKE '%80%')
LAST 1440 MINUTES;


