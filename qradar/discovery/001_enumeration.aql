-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Discovery / Enumeration (T1087, T1069, T1018, T1083)
-- Batch    : 11 / Discovery
-- Rules    : QR-106001 – QR-106035
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4662/4688/7045), Sysmon (1/3/17), PowerShell
-- ============================================================

-- ==================================================
-- QR-106001 | T1087.002 | Domain User Enumeration (net user /domain)
-- Severity: Medium | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%net%'
  AND (UTF8(payload) ILIKE '%user /domain%'
    OR UTF8(payload) ILIKE '%group /domain%'
    OR UTF8(payload) ILIKE '%group "domain admins"%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106002 | T1069.002 | Domain Group Enumeration (Event 4799/4798)
-- Severity: Medium | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4799<%'
    OR UTF8(payload) ILIKE '%EventID">"4799"%'
    OR UTF8(payload) ILIKE '%EventID>4798<%'
    OR UTF8(payload) ILIKE '%EventID">"4798"%')
  AND NOT (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%taskhostw%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106003 | T1018 | Network Share Enumeration (Event 5140/5142)
-- Severity: Low | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>5140<%'
    OR UTF8(payload) ILIKE '%EventID">"5140"%')
  AND (UTF8(payload) ILIKE '%IPC$%'
    OR UTF8(payload) ILIKE '%SYSVOL%'
    OR UTF8(payload) ILIKE '%NETLOGON%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106004 | T1087 | LDAP Enumeration via ldifde / csvde
-- Severity: Medium | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%ldifde%'
    OR UTF8(payload) ILIKE '%csvde%'
    OR UTF8(payload) ILIKE '%adfind%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106005 | T1046 | Port Scan via Repeated Network Connections (Threshold)
-- Severity: High | Confidence: Medium
-- Threshold: 20+ distinct destination ports from same source in 5 min
-- ==================================================
SELECT
  sourceip,
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(DISTINCT destinationport) AS PortCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND NOT (destinationip ILIKE '10.%' AND sourceip = destinationip)
GROUP BY sourceip, LOGSOURCENAME(logsourceid)
HAVING COUNT(DISTINCT destinationport) >= 20
LAST 5 MINUTES;


-- ==================================================
-- QR-106006 | T1083 | Directory Traversal via cmd/PowerShell
-- Severity: Low | Confidence: Low
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%dir /s /b%'
    OR UTF8(payload) ILIKE '%Get-ChildItem -Recurse%'
    OR UTF8(payload) ILIKE '%ls -la%')
  AND (UTF8(payload) ILIKE '%C:\Users\%'
    OR UTF8(payload) ILIKE '%C:\Windows\%'
    OR UTF8(payload) ILIKE '%C:\ProgramData\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106007 | T1057 | Process Discovery (tasklist / Get-Process)
-- Severity: Low | Confidence: Low
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%')
  AND (UTF8(payload) ILIKE '%tasklist%'
    OR UTF8(payload) ILIKE '%Get-Process%'
    OR UTF8(payload) ILIKE '%ps -ef%'
    OR UTF8(payload) ILIKE '%wmic process list%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%cmd.exe%')
LAST 1440 MINUTES;


