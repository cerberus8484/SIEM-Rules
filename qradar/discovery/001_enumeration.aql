    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%')
  AND (UTF8(payload) ILIKE '%whoami /priv%'
    OR UTF8(payload) ILIKE '%whoami /groups%'
    OR UTF8(payload) ILIKE '%echo %username%%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd.exe%'
    OR UTF8(payload) ILIKE '%wscript%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106016 | T1040 | Network Capture Tool Detected (Wireshark/tcpdump/pktmon)
-- Severity: High | Confidence: High
