SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Domain Admins%'
    OR UTF8(payload) ILIKE '%Enterprise Admins%'
    OR UTF8(payload) ILIKE '%Schema Admins%'
    OR UTF8(payload) ILIKE '%Account Operators%')
  AND (UTF8(payload) ILIKE '%Get-ADGroupMember%'
    OR UTF8(payload) ILIKE '%Get-DomainGroupMember%')
LAST 1440 MINUTES;


