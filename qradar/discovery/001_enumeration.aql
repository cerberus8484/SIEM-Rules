-- ==================================================
-- QR-106031 | T1082 | BIOS / UUID Fingerprinting (Anti-Sandbox)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Win32_BIOS%'
    OR UTF8(payload) ILIKE '%Win32_BaseBoard%'
    OR UTF8(payload) ILIKE '%SerialNumber%'
    OR UTF8(payload) ILIKE '%UUID%')
  AND (UTF8(payload) ILIKE '%Get-WmiObject%'
    OR UTF8(payload) ILIKE '%Get-CimInstance%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106032 | T1614 | System Language Discovery (GetUserDefaultUILanguage)
-- Severity: Medium | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%GetUserDefaultUILanguage%'
    OR UTF8(payload) ILIKE '%CultureInfo%'
    OR UTF8(payload) ILIKE '%CurrentCulture%'
    OR UTF8(payload) ILIKE '%(Get-Culture)%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106033 | T1046 | Masscan / Zmap Detected on Host
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%masscan%'
    OR UTF8(payload) ILIKE '%zmap%'
    OR UTF8(payload) ILIKE '%naabu%'
    OR UTF8(payload) ILIKE '%sx tool%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106034 | T1087 | Get-ADUser / Get-ADComputer Bulk Enumeration (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 3+ distinct enumeration calls in 5 minutes
-- ==================================================
SELECT
  username,
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS EnumCalls
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Get-ADUser%'
    OR UTF8(payload) ILIKE '%Get-ADComputer%'
    OR UTF8(payload) ILIKE '%Get-ADGroup%')
  AND NOT username ILIKE '%$%'
GROUP BY username, LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 3
LAST 5 MINUTES;


-- ==================================================
-- QR-106035 | T1087 | CrackMapExec / BloodHound SMB Signing Enum
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%crackmapexec%'
    OR UTF8(payload) ILIKE '%cme %'
    OR UTF8(payload) ILIKE '%SMB signing%'
    OR UTF8(payload) ILIKE '% smb %')
  AND (UTF8(payload) ILIKE '%--shares%'
    OR UTF8(payload) ILIKE '--users%'
    OR UTF8(payload) ILIKE '%--groups%')
LAST 1440 MINUTES;
