    OR UTF8(payload) ILIKE '%masscan%'
    OR UTF8(payload) ILIKE '%rustscan%'
    OR UTF8(payload) ILIKE '%zmap%')
  AND NOT username ILIKE '%admin%'
LAST 1440 MINUTES;


