  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%mshta%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106010 | T1016 | Network Configuration Discovery (arp, route, netstat)
-- Severity: Low | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%arp -a%'
    OR UTF8(payload) ILIKE '%route print%'
    OR UTF8(payload) ILIKE '%netstat -an%'
    OR UTF8(payload) ILIKE '%nbtstat%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%cmd.exe%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106011 | T1018 | Ping Sweep (Threshold)
-- Severity: Medium | Confidence: High
-- Threshold: 10+ ICMP echo requests to distinct hosts in 2 min
-- ==================================================
SELECT
  sourceip,
  COUNT(DISTINCT destinationip) AS PingedHosts
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND (UTF8(payload) ILIKE '%ping%'
    OR destinationport = 0)
GROUP BY sourceip
HAVING COUNT(DISTINCT destinationip) >= 10
LAST 2 MINUTES;


-- ==================================================
-- QR-106012 | T1087.001 | Local Account Enumeration (Event 4798/Sam)
-- Severity: Low | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%net localgroup administrators%'
    OR UTF8(payload) ILIKE '%net user%'
    OR UTF8(payload) ILIKE '%wmic useraccount%')
  AND NOT (UTF8(payload) ILIKE '%/add%'
    OR UTF8(payload) ILIKE '%/delete%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106013 | T1069.002 | Enumeration of Privileged Groups (Domain Admins / EA)
