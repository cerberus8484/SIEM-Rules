-- ==================================================
-- QR-106023 | T1083 | File Search for Credentials (pass / key / token in names)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%dir%'
    OR UTF8(payload) ILIKE '%Get-ChildItem%')
  AND (UTF8(payload) ILIKE '%password%'
    OR UTF8(payload) ILIKE '%passwd%'
    OR UTF8(payload) ILIKE '%creds%'
    OR UTF8(payload) ILIKE '%secret%'
    OR UTF8(payload) ILIKE '%.kdbx%'
    OR UTF8(payload) ILIKE '%.pfx%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106024 | T1012 | Registry Discovery (reg query HKLM Security)
-- Severity: Medium | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%reg query%'
  AND (UTF8(payload) ILIKE '%HKLM\System\CurrentControlSet%'
    OR UTF8(payload) ILIKE '%HKLM\Software\Microsoft\Windows NT%'
    OR UTF8(payload) ILIKE '%HKCU\Software%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-106025 | T1119 | Automated Data Collection (Loop + File Copy to Temp)
