  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%wireshark%'
    OR UTF8(payload) ILIKE '%tcpdump%'
    OR UTF8(payload) ILIKE '%pktmon%'
    OR UTF8(payload) ILIKE '%dumpcap%'
    OR UTF8(payload) ILIKE '%tshark%'
    OR UTF8(payload) ILIKE '%windump%')
  AND NOT (username ILIKE '%network%'
    OR username ILIKE '%soc%'
    OR username ILIKE '%admin%')
LAST 1440 MINUTES;


