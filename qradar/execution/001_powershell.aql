-- ==================================================
-- QR-100022 | T1059.001 | PowerShell Clear Event Log
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%')
  AND (UTF8(payload) ILIKE '%Clear-EventLog%'
    OR UTF8(payload) ILIKE '%Clear-WinEvent%'
    OR UTF8(payload) ILIKE '%wevtutil cl%'
    OR UTF8(payload) ILIKE '%Remove-EventLog%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100023 | T1059.001 | PowerShell Compress-Archive Staging
-- Severity: Medium | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Compress-Archive%'
    OR UTF8(payload) ILIKE '%[IO.Compression.ZipFile]%'
    OR UTF8(payload) ILIKE '%System.IO.Compression%')
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Public\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100024 | T1059.001 | PowerShell Token Manipulation
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%DuplicateTokenEx%'
    OR UTF8(payload) ILIKE '%ImpersonateLoggedOnUser%'
    OR UTF8(payload) ILIKE '%AdjustTokenPrivileges%'
    OR UTF8(payload) ILIKE '%OpenProcessToken%'
    OR UTF8(payload) ILIKE '%LookupPrivilegeValue%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100025 | T1059.001 | PowerShell Direct Syscall Patterns
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%NtAllocateVirtualMemory%'
    OR UTF8(payload) ILIKE '%NtWriteVirtualMemory%'
    OR UTF8(payload) ILIKE '%NtCreateThreadEx%'
    OR UTF8(payload) ILIKE '%ZwAllocateVirtualMemory%'
    OR UTF8(payload) ILIKE '%syscall%')
LAST 1440 MINUTES;
