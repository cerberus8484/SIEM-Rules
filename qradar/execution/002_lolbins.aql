  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%verclsid%'
  AND (UTF8(payload) ILIKE '%/S%'
    OR UTF8(payload) ILIKE '%{%}%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100058 | T1059 | RMM Tool Spawning Shell (Kaseya / LTSvc / NinjaRMM)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%LTSvc%'
    OR UTF8(payload) ILIKE '%Kaseya%'
    OR UTF8(payload) ILIKE '%ConnectWise%'
    OR UTF8(payload) ILIKE '%NinjaRMM%'
    OR UTF8(payload) ILIKE '%SolarWinds%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd.exe%')
LAST 1440 MINUTES;


