-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Execution — Living off the Land Binaries (T1218)
-- Batch    : 2 / Execution
-- Rules    : QR-100026 – QR-100060
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4688), Sysmon (Event 1), WinCollect
-- ============================================================

-- ==================================================
-- QR-100026 | T1218.011 | Rundll32 Remote DLL / SCT Execution
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%rundll32%'
  AND (UTF8(payload) ILIKE '%http%'
    OR UTF8(payload) ILIKE '%\\\\%'
    OR UTF8(payload) ILIKE '%.sct%'
    OR UTF8(payload) ILIKE '%javascript%'
    OR UTF8(payload) ILIKE '%vbscript%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100027 | T1218.010 | Regsvr32 Squiblydoo (Remote SCT)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%regsvr32%'
  AND (UTF8(payload) ILIKE '%/s%'
    OR UTF8(payload) ILIKE '%-s %')
  AND (UTF8(payload) ILIKE '%http%'
    OR UTF8(payload) ILIKE '%\\\\%'
    OR UTF8(payload) ILIKE '%.sct%'
    OR UTF8(payload) ILIKE '%.ocx%')
LAST 1440 MINUTES;


