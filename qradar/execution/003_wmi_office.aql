-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Execution — WMI Subscriptions & Office Macros (T1047, T1566)
-- Batch    : 3 / Execution
-- Rules    : QR-100061 – QR-100100
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4688), Sysmon (1/19/20/21), WinCollect,
--            PowerShell Operational (4104)
-- ============================================================

-- ==================================================
-- QR-100061 | T1047 | WMIC Process Call Create from Script
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%wmic%'
  AND UTF8(payload) ILIKE '%process%'
  AND UTF8(payload) ILIKE '%call create%'
  AND (UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100062 | T1546.003 | WMI EventFilter Registration (Sysmon 19)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%WmiEventFilter%'
    OR UTF8(payload) ILIKE '%EventID>19<%'
    OR UTF8(payload) ILIKE '%Sysmon%EventId>19%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100063 | T1546.003 | WMI EventConsumer Registration (Sysmon 20)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%WmiEventConsumer%'
    OR UTF8(payload) ILIKE '%EventID>20<%'
    OR UTF8(payload) ILIKE '%Sysmon%EventId>20%')
  AND (UTF8(payload) ILIKE '%CommandLineEventConsumer%'
    OR UTF8(payload) ILIKE '%ActiveScriptEventConsumer%')
LAST 1440 MINUTES;


