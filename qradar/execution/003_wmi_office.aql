-- ==================================================
-- QR-100079 | T1566 | Macro-Enabled Document Downloaded (XLSM/DOCM)
-- Severity: Medium | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%.xlsm%'
    OR UTF8(payload) ILIKE '%.docm%'
    OR UTF8(payload) ILIKE '%.xlam%'
    OR UTF8(payload) ILIKE '%.xltm%')
  AND (UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%INetCache%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100080 | T1566 | Remote Template Injection (Office Network on Open)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND (UTF8(payload) ILIKE '%WINWORD%'
    OR UTF8(payload) ILIKE '%EXCEL%')
  AND NOT destinationip ILIKE '192.168.%'
  AND NOT destinationip ILIKE '10.%'
LAST 60 MINUTES;


