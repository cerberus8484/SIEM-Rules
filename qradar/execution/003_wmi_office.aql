  AND UTF8(payload) ILIKE '%powershell%'
  AND (UTF8(payload) ILIKE '%AcroRd32%'
    OR UTF8(payload) ILIKE '%FoxitReader%'
    OR UTF8(payload) ILIKE '%chrome%'
    OR UTF8(payload) ILIKE '%firefox%'
    OR UTF8(payload) ILIKE '%WinRAR%'
    OR UTF8(payload) ILIKE '%7z%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100093 | T1059 | Wscript Running JS from Temp (Dropper Pattern)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%wscript%'
  AND (UTF8(payload) ILIKE '%.js%'
    OR UTF8(payload) ILIKE '%.vbs%')
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%INetCache%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-100094 | T1059 | Regsvr32 / Rundll32 with Long Command Line (Obfuscated)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%regsvr32%'
    OR UTF8(payload) ILIKE '%rundll32%')
  AND LEN(UTF8(payload)) > 500
LAST 1440 MINUTES;


