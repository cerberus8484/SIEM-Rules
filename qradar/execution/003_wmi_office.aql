    OR UTF8(payload) ILIKE '%CreateObject%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%http%')
LAST 1440 MINUTES;


