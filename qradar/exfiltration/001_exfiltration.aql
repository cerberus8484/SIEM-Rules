  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND (UTF8(payload) ILIKE '%winscp%'
    OR UTF8(payload) ILIKE '%filezilla%'
    OR UTF8(payload) ILIKE '%sftp%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd.exe%'
    OR UTF8(payload) ILIKE '%wscript%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107014 | T1132.001 | Base64 Blob in DNS TXT Response
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%DnsQuery%'
  AND UTF8(payload) ILIKE '%QueryType>16%'
  AND (UTF8(payload) ILIKE '%AAAA%'
    OR UTF8(payload) ILIKE '%base64%'
    OR UTF8(payload) ILIKE '%==%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107015 | T1052 | USB / Removable Media Write (Event 6416 + Sysmon FileCreate)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>6416<%'
    OR UTF8(payload) ILIKE '%EventID">"6416"%')
  AND UTF8(payload) ILIKE '%DiskDrive%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-107016 | T1041 | Email Attachment with Archive (Outlook Scripted Send)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND UTF8(payload) ILIKE '%Outlook%'
  AND (UTF8(payload) ILIKE '%CreateItem%'
    OR UTF8(payload) ILIKE '%.Send()%')
  AND (UTF8(payload) ILIKE '%.zip%'
    OR UTF8(payload) ILIKE '%.7z%'
    OR UTF8(payload) ILIKE '%.rar%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107017 | T1048 | Archive Created in Staging Path then Exfiltrated
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\Local\%'
    OR UTF8(payload) ILIKE '%\ProgramData\%')
  AND (UTF8(payload) ILIKE '%.zip%'
    OR UTF8(payload) ILIKE '%.7z%'
    OR UTF8(payload) ILIKE '%.rar%'
    OR UTF8(payload) ILIKE '%.tar%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107018 | T1048 | 7zip / WinRAR / tar from Command Line with Password
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%7z.exe%'
    OR UTF8(payload) ILIKE '%winrar%'
    OR UTF8(payload) ILIKE '%rar.exe%')
  AND (UTF8(payload) ILIKE '% -p%'
    OR UTF8(payload) ILIKE '% a %')
LAST 1440 MINUTES;


