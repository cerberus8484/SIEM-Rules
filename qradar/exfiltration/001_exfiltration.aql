FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%UploadString%'
    OR UTF8(payload) ILIKE '%UploadFile%'
    OR UTF8(payload) ILIKE '%UploadData%')
LAST 1440 MINUTES;


