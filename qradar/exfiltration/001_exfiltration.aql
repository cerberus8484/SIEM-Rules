-- ==================================================
-- QR-107025 | T1048 | Certutil Encode then HTTP Upload
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%certutil%'
  AND (UTF8(payload) ILIKE '%-encode%'
    OR UTF8(payload) ILIKE '%-encodehex%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107026 | T1020 | Automated Exfil — Same Source Sends 5+ Files in 10 min (Threshold)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  sourceip,
  destinationip,
  COUNT(*) AS FileSendCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport IN (21, 443, 80, 8080)
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%')
GROUP BY sourceip, destinationip
HAVING COUNT(*) >= 5
LAST 10 MINUTES;


-- ==================================================
-- QR-107027 | T1048.002 | Exfiltration via Alternate Port (Non-standard HTTPS)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport NOT IN (80, 443, 22, 25, 53, 3389, 8080, 8443)
  AND destinationport > 1024
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '172.1%.%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%python%')
LAST 1440 MINUTES;


