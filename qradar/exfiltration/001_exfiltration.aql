-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Exfiltration (T1048, T1041, T1071.004, T1052, T1567)
-- Batch    : 12 / Exfiltration
-- Rules    : QR-107001 – QR-107030
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows (4688), Sysmon (1/3), Firewall/Netflow, PowerShell
-- ============================================================

-- ==================================================
-- QR-107001 | T1048.003 | Data Staged and Sent to External IP via SMB
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport = 445
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '172.1%.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107002 | T1041 | Large Outbound Transfer via HTTPS (Netflow Threshold)
-- Severity: High | Confidence: Medium
-- Threshold: 100MB+ to single external IP in 60 min
-- ==================================================
SELECT
  sourceip,
  destinationip,
  SUM(eventcount) AS TotalBytes
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Netflow%'
  AND destinationport = 443
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%'
    OR destinationip ILIKE '172.1%.%')
GROUP BY sourceip, destinationip
HAVING SUM(eventcount) >= 100000000
LAST 60 MINUTES;


-- ==================================================
-- QR-107003 | T1071.004 | DNS Tunneling — Long Encoded Subdomain Query
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%DnsQuery%'
  AND (UTF8(payload) ILIKE '%================%'
    OR UTF8(payload) ILIKE '%AAAAAAAAAAAAAAAA%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107004 | T1048.001 | BITSadmin Upload to External URL
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%bitsadmin%'
  AND (UTF8(payload) ILIKE '%/upload%'
    OR UTF8(payload) ILIKE '%Transfer%')
  AND UTF8(payload) ILIKE '%http%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-107005 | T1567.002 | Rclone to Cloud Storage (s3/gdrive/dropbox)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%rclone%'
    OR UTF8(payload) ILIKE '%mega-put%'
    OR UTF8(payload) ILIKE '%s3 cp%')
  AND (UTF8(payload) ILIKE '%sync%'
    OR UTF8(payload) ILIKE '%copy%'
    OR UTF8(payload) ILIKE '%upload%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107006 | T1071.001 | HTTP POST with Unusually Large Body from Script
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Invoke-WebRequest%'
    OR UTF8(payload) ILIKE '%Invoke-RestMethod%')
  AND UTF8(payload) ILIKE '%-Method Post%'
  AND (UTF8(payload) ILIKE '%-Body%'
    OR UTF8(payload) ILIKE '%-InFile%')
LAST 1440 MINUTES;


