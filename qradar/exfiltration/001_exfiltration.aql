-- ==================================================
-- QR-107008 | T1041 | PowerShell Compress-Archive + Upload Pattern
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND UTF8(payload) ILIKE '%Compress-Archive%'
  AND (UTF8(payload) ILIKE '%WebClient%'
    OR UTF8(payload) ILIKE '%UploadFile%'
    OR UTF8(payload) ILIKE '%Invoke-WebRequest%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107009 | T1567 | Curl/Wget Upload to Pastebin or Cloud
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%curl%'
    OR UTF8(payload) ILIKE '%wget%')
  AND (UTF8(payload) ILIKE '%pastebin%'
    OR UTF8(payload) ILIKE '%transfer.sh%'
    OR UTF8(payload) ILIKE '%gofile.io%'
    OR UTF8(payload) ILIKE '%0x0.st%'
    OR UTF8(payload) ILIKE '%-F "%'
    OR UTF8(payload) ILIKE '%--data-binary%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107010 | T1048 | Netcat / Socat Outbound with Redirect
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%nc.exe%'
    OR UTF8(payload) ILIKE '%ncat%'
    OR UTF8(payload) ILIKE '%socat%')
  AND (UTF8(payload) ILIKE '%< %'
    OR UTF8(payload) ILIKE '%| nc%'
    OR UTF8(payload) ILIKE '%EXEC%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107011 | T1071.004 | DNS High Query Rate to Single Domain (Tunneling Threshold)
-- Severity: High | Confidence: High
-- Threshold: 100+ DNS queries to same domain in 10 minutes
-- ==================================================
SELECT
  sourceip,
  UTF8(payload) AS TopDomain,
  COUNT(*) AS QueryCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%DnsQuery%'
GROUP BY sourceip, UTF8(payload)
HAVING COUNT(*) >= 100
LAST 10 MINUTES;


-- ==================================================
-- QR-107012 | T1567.001 | GitHub Gist or Raw Upload from Script
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%api.github.com/gists%'
    OR UTF8(payload) ILIKE '%gist.github.com%'
    OR UTF8(payload) ILIKE '%raw.githubusercontent.com%')
  AND (UTF8(payload) ILIKE '%-Method Post%'
    OR UTF8(payload) ILIKE '%WebClient%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107013 | T1048.003 | WinSCP / FileZilla Spawned by Script
-- Severity: High | Confidence: High
-- ==================================================
SELECT
