-- ==================================================
-- QR-107029 | T1048 | Browser Data / Cookie File Copied to Staging
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCopy%'
  AND (UTF8(payload) ILIKE '%\Google\Chrome\User Data\%'
    OR UTF8(payload) ILIKE '%\Mozilla\Firefox\Profiles\%'
    OR UTF8(payload) ILIKE '%\Microsoft\Edge\User Data\%')
  AND (UTF8(payload) ILIKE '%Cookies%'
    OR UTF8(payload) ILIKE '%Login Data%'
    OR UTF8(payload) ILIKE '%key4.db%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-107030 | T1048 | exfiltration via Slack/Teams API from Script
-- Severity: High | Confidence: High
