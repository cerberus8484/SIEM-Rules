-- ==================================================
-- QR-105030 | T1021.004 | SSH to Internal Hosts from Non-SSH Process
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport = 22
  AND NOT (UTF8(payload) ILIKE '%ssh%'
    OR UTF8(payload) ILIKE '%putty%'
    OR UTF8(payload) ILIKE '%winscp%'
    OR UTF8(payload) ILIKE '%openssh%')
LAST 1440 MINUTES;


