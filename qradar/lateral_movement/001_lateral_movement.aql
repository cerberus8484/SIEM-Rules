-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Lateral Movement (T1021, T1047, T1570)
-- Batch    : 10 / Lateral Movement
-- Rules    : QR-105001 – QR-105040
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4624/4648/4769), Sysmon (1/3), WinCollect
-- ============================================================

-- ==================================================
-- QR-105001 | T1021.001 | External RDP Logon (Event 4624 Type 10)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND UTF8(payload) ILIKE '%10%'
  AND NOT (sourceip ILIKE '10.%'
    OR sourceip ILIKE '192.168.%'
    OR sourceip ILIKE '172.1%.%'
    OR sourceip ILIKE '127.%'
    OR sourceip ILIKE '::1')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105002 | T1021.002 | Admin Share Access (C$/ADMIN$/IPC$)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%C$%'
    OR UTF8(payload) ILIKE '%ADMIN$%'
    OR UTF8(payload) ILIKE '%IPC$%')
  AND NOT (sourceip ILIKE '10.%'
    OR sourceip ILIKE '192.168.%'
    OR sourceip ILIKE '172.1%.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105003 | T1570 | PsExec / PaExec Service Installed Remotely
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND (UTF8(payload) ILIKE '%PSEXESVC%'
    OR UTF8(payload) ILIKE '%paexec%'
    OR UTF8(payload) ILIKE '%PAExecSvc%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105004 | T1021.003 | WMIC Remote Process Creation
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%wmic%'
  AND (UTF8(payload) ILIKE '%/node:%'
    OR UTF8(payload) ILIKE '% node:%')
  AND UTF8(payload) ILIKE '%process%'
  AND UTF8(payload) ILIKE '%call create%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-105005 | T1021.006 | PS Invoke-Command Remote Host
-- Severity: High | Confidence: High
