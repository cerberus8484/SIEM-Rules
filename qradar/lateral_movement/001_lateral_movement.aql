-- ==================================================
-- QR-105020 | T1021.002 | 3+ Logons from Same IP — Lateral Movement (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 3+ successful logons from same source to different hosts
-- ==================================================
SELECT
  sourceip,
  COUNT(DISTINCT LOGSOURCENAME(logsourceid)) AS UniqueTargets
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND NOT (sourceip ILIKE '10.%' AND sourceip = destinationip)
GROUP BY sourceip
HAVING COUNT(DISTINCT LOGSOURCENAME(logsourceid)) >= 3
LAST 60 MINUTES;


-- ==================================================
-- QR-105021 | T1021 | Multiple NTLM Failures from Same Source (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 5+ failed NTLM logons in 30 seconds
-- ==================================================
SELECT
  sourceip,
  COUNT(*) AS NtlmFailCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4625<%'
    OR UTF8(payload) ILIKE '%EventID">"4625"%')
  AND UTF8(payload) ILIKE '%NTLM%'
GROUP BY sourceip
HAVING COUNT(*) >= 5
LAST 30 MINUTES;


