-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4648<%'
    OR UTF8(payload) ILIKE '%EventID">"4648"%')
  AND NOT username ILIKE '%$%'
  AND NOT (UTF8(payload) ILIKE '%svchost%'
    OR UTF8(payload) ILIKE '%scheduled task%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105036 | T1484 | RBCD Attribute Modified (msDS-AllowedToActOnBehalfOfOtherIdentity)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>5136<%'
    OR UTF8(payload) ILIKE '%EventID">"5136"%')
  AND UTF8(payload) ILIKE '%msDS-AllowedToActOnBehalfOfOtherIdentity%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-105037 | T1134.005 | Add-DomainObjectAcl WriteDACL/GenericAll
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%Add-DomainObjectAcl%'
    OR UTF8(payload) ILIKE '%WriteDACL%'
    OR UTF8(payload) ILIKE '%GenericAll%'
    OR UTF8(payload) ILIKE '%Set-DomainObjectOwner%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105038 | T1021.003 | Psexec via Port 135/445 from Unusual Parent
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  destinationport,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND destinationport IN (135, 445)
  AND (UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%python%'
    OR UTF8(payload) ILIKE '%perl%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105039 | T1021 | Invoke-PetitPotam / EfsRpc Coercion
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%PetitPotam%'
    OR UTF8(payload) ILIKE '%EfsRpcOpenFileRaw%'
    OR UTF8(payload) ILIKE '%Invoke-Coercer%'
    OR UTF8(payload) ILIKE '%SpoolSample%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-105040 | T1484 | GPO Linked at Domain Root (gpLink on DC=)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>5136<%'
    OR UTF8(payload) ILIKE '%EventID">"5136"%')
  AND UTF8(payload) ILIKE '%gpLink%'
  AND UTF8(payload) ILIKE '%DC=%'
LAST 1440 MINUTES;
