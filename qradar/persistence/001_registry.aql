-- ==================================================
-- QR-101014 | T1112 | Defender DisableAntiSpyware/Disable Registry
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND (UTF8(payload) ILIKE '%DisableAntiSpyware%'
    OR UTF8(payload) ILIKE '%DisableAntiVirus%'
    OR UTF8(payload) ILIKE '%DisableRealtimeMonitoring%'
    OR UTF8(payload) ILIKE '%DisableBehaviorMonitoring%')
LAST 1440 MINUTES;


