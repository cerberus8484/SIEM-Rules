-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Persistence — Registry (T1547)
-- Batch    : 4 / Persistence
-- Rules    : QR-101001 – QR-101025
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Sysmon (Event 13 Registry Set), Windows Security, WinCollect
-- ============================================================

-- ==================================================
-- QR-101001 | T1547.001 | HKCU Run Key Written
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%CurrentVersion\Run%'
  AND UTF8(payload) ILIKE '%HKEY_CURRENT_USER%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-101002 | T1547.001 | HKLM Run Key Written
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%CurrentVersion\Run%'
  AND UTF8(payload) ILIKE '%HKEY_LOCAL_MACHINE%'
  AND NOT (UTF8(payload) ILIKE '%\Windows\%'
    OR UTF8(payload) ILIKE '%\Program Files\%'
    OR UTF8(payload) ILIKE '%\ProgramData\%')
LAST 1440 MINUTES;


