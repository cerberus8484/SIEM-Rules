-- ==================================================
-- QR-101022 | T1547 | Suspicious Registry Value from Staging Path
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\Roaming\%'
    OR UTF8(payload) ILIKE '%\AppData\Local\Temp\%'
    OR UTF8(payload) ILIKE '%\Downloads\%')
  AND (UTF8(payload) ILIKE '%Run%'
    OR UTF8(payload) ILIKE '%Startup%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101023 | T1547 | ADS (Alternate Data Stream) Created via Registry
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%:Zone.Identifier%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-101024 | T1547 | Multiple Run Keys Written in Short Time (Bulk Persistence)
-- Severity: Critical | Confidence: High
-- Threshold: 3+ Run key writes in 60 seconds from same host
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS RunKeyWriteCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%CurrentVersion\Run%'
GROUP BY LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 3
LAST 60 MINUTES;


-- ==================================================
-- QR-101025 | T1547 | Credential Manager Registry Key Tampered
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND (UTF8(payload) ILIKE '%Credential Manager%'
    OR UTF8(payload) ILIKE '%Credentials\%'
    OR UTF8(payload) ILIKE '%DPAPI%')
  AND NOT (UTF8(payload) ILIKE '%lsass%'
    OR UTF8(payload) ILIKE '%services%')
LAST 1440 MINUTES;
