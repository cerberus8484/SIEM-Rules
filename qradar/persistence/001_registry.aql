-- ==================================================
-- QR-101008 | T1547.005 | LSA Authentication / Notification Packages
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%LSA%'
  AND (UTF8(payload) ILIKE '%Authentication Packages%'
    OR UTF8(payload) ILIKE '%Notification Packages%'
    OR UTF8(payload) ILIKE '%Security Packages%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101009 | T1547.009 | Shortcut File Written to Startup Folder
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\Start Menu\Programs\Startup\%'
    OR UTF8(payload) ILIKE '%\Microsoft\Windows\Start Menu\Programs\StartUp\%')
  AND (UTF8(payload) ILIKE '%.lnk%'
    OR UTF8(payload) ILIKE '%.url%'
    OR UTF8(payload) ILIKE '%.exe%')
LAST 1440 MINUTES;


