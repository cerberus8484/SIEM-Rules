WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%Image File Execution Options%'
  AND (UTF8(payload) ILIKE '%Debugger%'
    OR UTF8(payload) ILIKE '%GlobalFlag%')
LAST 1440 MINUTES;


