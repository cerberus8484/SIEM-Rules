-- ==================================================
-- QR-101055 | T1053.005 | Multiple Tasks Created in 60 Seconds (Bulk)
-- Severity: Critical | Confidence: High
-- Threshold: 3+ new tasks in 60 seconds from same host
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS TaskCreateCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4698<%'
    OR UTF8(payload) ILIKE '%EventID">"4698"%')
GROUP BY LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 3
LAST 60 MINUTES;
