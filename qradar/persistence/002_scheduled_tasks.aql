LAST 1440 MINUTES;


-- ==================================================
-- QR-101036 | T1053.005 | Task XML Written to Tasks Directory (Sysmon 11)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\Windows\System32\Tasks\%'
    OR UTF8(payload) ILIKE '%\Windows\SysWOW64\Tasks\%')
  AND NOT UTF8(payload) ILIKE '%taskhost%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-101037 | T1053.005 | PS New-ScheduledTask with Script Action
