-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Persistence — Scheduled Tasks (T1053.005)
-- Batch    : 5 / Persistence
-- Rules    : QR-101026 – QR-101055
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4698-4702), Sysmon (1), WinCollect
-- ============================================================

-- ==================================================
-- QR-101026 | T1053.005 | Schtasks Create with Script Engine
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%schtasks%'
  AND UTF8(payload) ILIKE '%/create%'
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%mshta%'
    OR UTF8(payload) ILIKE '%cscript%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101027 | T1053.005 | Schtasks Create with SYSTEM Privilege
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%schtasks%'
  AND UTF8(payload) ILIKE '%/create%'
  AND (UTF8(payload) ILIKE '%/ru system%'
    OR UTF8(payload) ILIKE '%/ru SYSTEM%'
    OR UTF8(payload) ILIKE '%/RU SYSTEM%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101028 | T1053.005 | Schtasks Create from Writable Path
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%schtasks%'
  AND UTF8(payload) ILIKE '%/create%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Public\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101029 | T1053.005 | Schtasks with Encoded Command
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%schtasks%'
  AND (UTF8(payload) ILIKE '%-encodedcommand%'
    OR UTF8(payload) ILIKE '%-enc %'
    OR UTF8(payload) ILIKE '%frombase64string%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101030 | T1053.005 | Windows Security Event 4698 — Task Created
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4698<%'
    OR UTF8(payload) ILIKE '%EventID">"4698"%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%mshta%')
LAST 1440 MINUTES;


