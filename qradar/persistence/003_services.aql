-- ==================================================
-- QR-101079 | T1543.003 | SYSTEM Privilege Service with Non-System Path
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND UTF8(payload) ILIKE '%LocalSystem%'
  AND NOT (UTF8(payload) ILIKE '%\Windows\%'
    OR UTF8(payload) ILIKE '%\Program Files\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101080 | T1543.003 | Service Name Matches CrackMapExec Pattern
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND UTF8(payload) ILIKE '%cmd /Q /c%'
LAST 1440 MINUTES;
