  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc.exe%'
  AND (UTF8(payload) ILIKE '% qc %'
    OR UTF8(payload) ILIKE '% query %')
  AND (UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd.exe%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101072 | T1543.003 | Unusual Extension in Service Binary Path
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND (UTF8(payload) ILIKE '%.bat%'
    OR UTF8(payload) ILIKE '%.vbs%'
    OR UTF8(payload) ILIKE '%.ps1%'
    OR UTF8(payload) ILIKE '%.jar%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101073 | T1543.003 | Failure Action Command Set for Service
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc.exe%'
  AND (UTF8(payload) ILIKE '%failure%'
    OR UTF8(payload) ILIKE '%failureflag%')
  AND (UTF8(payload) ILIKE '%command=%'
    OR UTF8(payload) ILIKE '%binPath=%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101074 | T1543.003 | Mass Service Stop — Ransomware Precursor (Threshold)
-- Severity: Critical | Confidence: High
-- Threshold: 5+ services stopped in 30 seconds
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  COUNT(*) AS ServiceStopCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7036<%'
    OR UTF8(payload) ILIKE '%EventID">"7036"%')
  AND UTF8(payload) ILIKE '%stopped%'
GROUP BY LOGSOURCENAME(logsourceid)
HAVING COUNT(*) >= 5
LAST 30 MINUTES;


-- ==================================================
-- QR-101075 | T1543.003 | Non-Standard Parent Spawning Sc.exe
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc.exe%'
  AND (UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%mshta%'
    OR UTF8(payload) ILIKE '%WINWORD%'
    OR UTF8(payload) ILIKE '%EXCEL%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101076 | T1543.003 | Svchost Loading DLL from User-Writable Path
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND UTF8(payload) ILIKE '%svchost%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101077 | T1543.003 | Sc.exe Remote Service Operation
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc.exe%'
  AND (UTF8(payload) ILIKE '%\\\%'
    OR UTF8(payload) ILIKE '%//%')
  AND (UTF8(payload) ILIKE '% create %'
    OR UTF8(payload) ILIKE '% start %'
    OR UTF8(payload) ILIKE '% stop %')
LAST 1440 MINUTES;


