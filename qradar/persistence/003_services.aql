  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND (UTF8(payload) ILIKE '%svchost64%'
    OR UTF8(payload) ILIKE '%svchost32%'
    OR UTF8(payload) ILIKE '%svchosts%'
