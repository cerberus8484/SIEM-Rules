-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Persistence — Services (T1543.003)
-- Batch    : 6 / Persistence
-- Rules    : QR-101056 – QR-101080
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (7045/7036/7040), Sysmon (1/13), WinCollect
-- ============================================================

-- ==================================================
-- QR-101056 | T1543.003 | New Service Installed (Event 7045)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Public\%'
    OR UTF8(payload) ILIKE '%\\\\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101057 | T1543.003 | Service Binary is Script Interpreter
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND (UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%cmd.exe%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%cscript%'
    OR UTF8(payload) ILIKE '%mshta%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101058 | T1543.003 | Sc.exe Create New Service
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%sc.exe%'
  AND (UTF8(payload) ILIKE '% create %'
    OR UTF8(payload) ILIKE '% config %')
  AND (UTF8(payload) ILIKE '%binPath=%'
    OR UTF8(payload) ILIKE '%binpath=%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101059 | T1543.003 | Service Start Type Changed (7040)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7040<%'
    OR UTF8(payload) ILIKE '%EventID">"7040"%')
  AND (UTF8(payload) ILIKE '%demand start%'
    OR UTF8(payload) ILIKE '%auto start%')
  AND (UTF8(payload) ILIKE '%Defender%'
    OR UTF8(payload) ILIKE '%Security%'
    OR UTF8(payload) ILIKE '%MSSec%'
    OR UTF8(payload) ILIKE '%Firewall%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101060 | T1543.003 | Security Service Stopped (7036)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7036<%'
    OR UTF8(payload) ILIKE '%EventID">"7036"%')
  AND UTF8(payload) ILIKE '%stopped%'
  AND (UTF8(payload) ILIKE '%Defender%'
    OR UTF8(payload) ILIKE '%MsMpEng%'
    OR UTF8(payload) ILIKE '%SecurityHealth%'
    OR UTF8(payload) ILIKE '%EventLog%'
    OR UTF8(payload) ILIKE '%WinDefend%')
LAST 1440 MINUTES;


