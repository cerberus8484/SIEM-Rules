-- ==================================================
-- QR-101065 | T1543.003 | Fake Svchost Path (not System32)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>7045<%'
    OR UTF8(payload) ILIKE '%EventID">"7045"%')
  AND UTF8(payload) ILIKE '%svchost%'
  AND NOT UTF8(payload) ILIKE '%\System32\svchost%'
  AND NOT UTF8(payload) ILIKE '%\SysWOW64\svchost%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-101066 | T1543.003 | ServiceDll Registry Value Written (Sysmon 13)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%RegistryEvent%'
  AND UTF8(payload) ILIKE '%ServiceDll%'
  AND (UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Downloads\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-101067 | T1543.003 | PS New-Service from Script
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%New-Service%'
    OR UTF8(payload) ILIKE '%Set-Service%')
  AND (UTF8(payload) ILIKE '%-StartupType Automatic%'
    OR UTF8(payload) ILIKE '%-BinaryPathName%')
LAST 1440 MINUTES;


