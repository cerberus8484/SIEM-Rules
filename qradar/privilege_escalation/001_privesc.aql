SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4673<%'
    OR UTF8(payload) ILIKE '%EventID">"4673"%')
  AND UTF8(payload) ILIKE '%SeDebugPrivilege%'
  AND NOT (username ILIKE '%system%'
    OR username ILIKE '%network service%')
LAST 1440 MINUTES;


