-- ==================================================
-- QR-109011 | T1574.001 | DLL Search Order Hijacking — Writable Path DLL
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%\AppData\%'
    OR UTF8(payload) ILIKE '%\Temp\%'
    OR UTF8(payload) ILIKE '%\Users\Public\%')
  AND NOT (UTF8(payload) ILIKE '%\System32\%'
    OR UTF8(payload) ILIKE '%\SysWOW64\%'
    OR UTF8(payload) ILIKE '%\Program Files\%')
LAST 1440 MINUTES;


