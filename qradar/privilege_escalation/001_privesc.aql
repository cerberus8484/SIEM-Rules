-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Privilege Escalation (T1134, T1548, T1574, T1068, T1055)
-- Batch    : 14 / Privilege Escalation
-- Rules    : QR-109001 – QR-109040
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4672/4673/4674/4688), Sysmon (1/8/25), PowerShell
-- ============================================================

-- ==================================================
-- QR-109001 | T1134.001 | Token Impersonation via ImpersonateLoggedOnUser
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%ImpersonateLoggedOnUser%'
    OR UTF8(payload) ILIKE '%DuplicateTokenEx%'
    OR UTF8(payload) ILIKE '%SetThreadToken%'
    OR UTF8(payload) ILIKE '%Invoke-TokenManipulation%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-109002 | T1134.002 | RunAs with /savecred (Credential Caching Abuse)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%runas%'
  AND UTF8(payload) ILIKE '%/savecred%'
LAST 1440 MINUTES;


