FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\AppData\Roaming\Microsoft\Windows\Start Menu\Programs\Startup\%'
    OR UTF8(payload) ILIKE '%\ProgramData\Microsoft\Windows\Start Menu\Programs\Startup\%')
  AND (UTF8(payload) ILIKE '%.exe%'
    OR UTF8(payload) ILIKE '%.bat%'
    OR UTF8(payload) ILIKE '%.vbs%'
    OR UTF8(payload) ILIKE '%.ps1%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-109036 | T1055.002 | Portable Executable Injection (Sysmon ProcessTamper)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessTamper%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-109037 | T1574.001 | Phantom DLL Loaded by Privileged Process
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ImageLoad%'
  AND (UTF8(payload) ILIKE '%wlbsctrl.dll%'
    OR UTF8(payload) ILIKE '%wbemcomn.dll%'
    OR UTF8(payload) ILIKE '%comsvcs.dll%')
  AND (UTF8(payload) ILIKE '%spoolsv%'
    OR UTF8(payload) ILIKE '%lsass%'
    OR UTF8(payload) ILIKE '%winlogon%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-109038 | T1134 | Account Operator Group Member Added (Event 4728)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4728<%'
    OR UTF8(payload) ILIKE '%EventID">"4728"%')
  AND (UTF8(payload) ILIKE '%Account Operators%'
    OR UTF8(payload) ILIKE '%Backup Operators%'
    OR UTF8(payload) ILIKE '%Domain Admins%'
    OR UTF8(payload) ILIKE '%Enterprise Admins%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-109039 | T1068 | EternalBlue / MS17-010 Pattern (SMB Exploit)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%lsass%'
  AND (UTF8(payload) ILIKE '%\Windows\TEMP\%'
    OR UTF8(payload) ILIKE '%\Users\Public\%')
  AND UTF8(payload) ILIKE '%smb%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-109040 | T1134 | SYSTEM Process Spawned from Non-System Parent (Threshold)
-- Severity: Critical | Confidence: High
-- Threshold: 3+ SYSTEM child processes from non-system parent in 5 min
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  COUNT(*) AS SystemSpawns
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4688<%'
    OR UTF8(payload) ILIKE '%EventID">"4688"%')
  AND UTF8(payload) ILIKE '%NT AUTHORITY\SYSTEM%'
  AND NOT (UTF8(payload) ILIKE '%services.exe%'
    OR UTF8(payload) ILIKE '%svchost.exe%'
    OR UTF8(payload) ILIKE '%wininit.exe%'
    OR UTF8(payload) ILIKE '%smss.exe%')
GROUP BY LOGSOURCENAME(logsourceid), username
HAVING COUNT(*) >= 3
LAST 5 MINUTES;
