-- ==================================================
-- QR-109008 | T1068 | Kernel Exploit Process — Rare System Call (Sysmon ProcessCreate)
-- Severity: Critical | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessCreate%'
  AND (UTF8(payload) ILIKE '%PrintSpoofer%'
    OR UTF8(payload) ILIKE '%GodPotato%'
    OR UTF8(payload) ILIKE '%JuicyPotato%'
    OR UTF8(payload) ILIKE '%SweetPotato%'
    OR UTF8(payload) ILIKE '%RoguePotato%'
    OR UTF8(payload) ILIKE '%RottenPotato%'
    OR UTF8(payload) ILIKE '%LocalPotato%'
    OR UTF8(payload) ILIKE '%SigmaPotato%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-109009 | T1068 | Token Privilege Escalation — SeDebugPrivilege Enabled
-- Severity: High | Confidence: High
