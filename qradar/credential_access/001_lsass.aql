WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%procdump%'
  AND (UTF8(payload) ILIKE '%lsass%'
    OR UTF8(payload) ILIKE '%-ma%')
LAST 1440 MINUTES;


