-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Credential Access (T1003, T1558, T1555)
-- Batch    : 7 / Credential Access
-- Rules    : QR-103001 – QR-103035
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows Security (4769/4768/4624/4648), Sysmon (10/7/11),
--            PowerShell Operational (4104)
-- ============================================================

-- ==================================================
-- QR-103001 | T1003.001 | LSASS Memory Access (Sysmon 10)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessAccess%'
  AND UTF8(payload) ILIKE '%lsass%'
  AND NOT (UTF8(payload) ILIKE '%antimalware%'
    OR UTF8(payload) ILIKE '%MsMpEng%'
    OR UTF8(payload) ILIKE '%taskmgr%'
    OR UTF8(payload) ILIKE '%csrss%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-103002 | T1003.001 | LSASS Access with PROCESS_VM_READ Rights
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessAccess%'
  AND UTF8(payload) ILIKE '%lsass%'
  AND (UTF8(payload) ILIKE '%0x1010%'
    OR UTF8(payload) ILIKE '%0x1410%'
    OR UTF8(payload) ILIKE '%0x143a%'
    OR UTF8(payload) ILIKE '%0x1438%'
    OR UTF8(payload) ILIKE '%0x1fffff%')
LAST 1440 MINUTES;


-- ==================================================
