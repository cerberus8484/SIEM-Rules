-- ==================================================
-- QR-103027 | T1110 | Brute Force Login Attempts (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 10+ failures from same source IP in 60s
-- ==================================================
SELECT
  sourceip,
  COUNT(*) AS FailureCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4625<%'
    OR UTF8(payload) ILIKE '%EventID">"4625"%')
GROUP BY sourceip
HAVING COUNT(*) >= 10
LAST 60 MINUTES;


-- ==================================================
-- QR-103028 | T1558 | Multiple Kerberoasting Requests (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 5+ TGS-REQ with RC4 encryption from same IP in 5 min
-- ==================================================
SELECT
  sourceip,
  COUNT(*) AS KerberoastCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4769<%'
    OR UTF8(payload) ILIKE '%EventID">"4769"%')
  AND UTF8(payload) ILIKE '%0x17%'
GROUP BY sourceip
HAVING COUNT(*) >= 5
LAST 300 MINUTES;


