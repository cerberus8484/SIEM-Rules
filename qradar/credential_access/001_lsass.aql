SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%sekurlsa%'
    OR UTF8(payload) ILIKE '%lsadump%'
    OR UTF8(payload) ILIKE '%privilege::debug%'
    OR UTF8(payload) ILIKE '%token::elevate%'
    OR UTF8(payload) ILIKE '%logonpasswords%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-103006 | T1003.002 | Reg Save SAM / SYSTEM / SECURITY Hive
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND UTF8(payload) ILIKE '%reg%'
  AND UTF8(payload) ILIKE '% save %'
  AND (UTF8(payload) ILIKE '%\SAM%'
    OR UTF8(payload) ILIKE '%\SYSTEM%'
    OR UTF8(payload) ILIKE '%\SECURITY%'
    OR UTF8(payload) ILIKE '%HKLM\SAM%')
LAST 1440 MINUTES;


