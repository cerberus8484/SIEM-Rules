-- ==================================================
-- QR-103010 | T1558.003 | Kerberoasting — RC4 TGS (Event 4769)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4769<%'
    OR UTF8(payload) ILIKE '%EventID">"4769"%')
  AND UTF8(payload) ILIKE '%0x17%'
  AND NOT username ILIKE '%$%'
LAST 1440 MINUTES;


