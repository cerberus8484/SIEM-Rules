-- ==================================================
-- QR-103021 | T1552.001 | Cleartext Password in PowerShell Script
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%PowerShell%'
  AND (UTF8(payload) ILIKE '%password=%'
    OR UTF8(payload) ILIKE '%-Password "%'
    OR UTF8(payload) ILIKE '%-Password ''%'
    OR UTF8(payload) ILIKE '%ConvertTo-SecureString%')
  AND NOT UTF8(payload) ILIKE '%Get-Credential%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-103022 | T1552 | Searching Files for Passwords
-- Severity: High | Confidence: Medium
