-- ==================================================
-- QR-110026 | T1190 | Log4Shell Pattern in Web Request (JNDI)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%IIS%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Apache%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%')
  AND (UTF8(payload) ILIKE '%jndi:%'
    OR UTF8(payload) ILIKE '%jndi:ldap%'
    OR UTF8(payload) ILIKE '%${%{%'
    OR UTF8(payload) ILIKE '%${lower:j}%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110027 | T1078.003 | Password Spray — Many Usernames from One IP (Threshold)
-- Severity: High | Confidence: High
-- Threshold: 5+ distinct usernames failing from same IP in 5 min
-- ==================================================
SELECT
  sourceip,
  COUNT(DISTINCT username) AS UserCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4625<%'
    OR UTF8(payload) ILIKE '%EventID">"4625"%')
GROUP BY sourceip
HAVING COUNT(DISTINCT username) >= 5
LAST 5 MINUTES;


-- ==================================================
-- QR-110028 | T1190 | SQLi Pattern in Web Log (UNION SELECT / ORDER BY Fuzz)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%IIS%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Apache%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%')
  AND (UTF8(payload) ILIKE '%UNION SELECT%'
    OR UTF8(payload) ILIKE '% OR 1=1%'
    OR UTF8(payload) ILIKE '%WAITFOR DELAY%'
    OR UTF8(payload) ILIKE '%benchmark(%'
    OR UTF8(payload) ILIKE '%sleep(%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110029 | T1190 | Directory Traversal in Web Request (../../../)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%IIS%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%')
  AND (UTF8(payload) ILIKE '%/../%'
    OR UTF8(payload) ILIKE '%/..%2F%'
    OR UTF8(payload) ILIKE '%\..\%'
    OR UTF8(payload) ILIKE '%..%5C%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110030 | T1078 | Kiosk / Guest Account Interactive Login (Event 4624)
-- Severity: Medium | Confidence: High
