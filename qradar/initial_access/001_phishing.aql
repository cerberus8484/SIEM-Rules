-- ==================================================
-- QR-110017 | T1195.002 | Typosquatted Package Download (npm/pip)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%npm install%'
    OR UTF8(payload) ILIKE '%pip install%'
    OR UTF8(payload) ILIKE '%gem install%')
  AND (UTF8(payload) ILIKE '%--unsafe-perm%'
    OR UTF8(payload) ILIKE '%-I %'
    OR UTF8(payload) ILIKE '%--ignore-scripts%')
LAST 1440 MINUTES;


