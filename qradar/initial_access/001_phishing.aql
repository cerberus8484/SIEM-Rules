-- ============================================================
-- HuntingThreats — QRadar AQL Hunt Rules
-- Category : Initial Access (T1566, T1190, T1195, T1078, T1059)
-- Batch    : 15 / Initial Access
-- Rules    : QR-110001 – QR-110040
-- Platform : QRadar 7.4+ / AQL
-- Sources  : Windows (4624/4625/4688), Sysmon (1/3/11), PowerShell
-- ============================================================

-- ==================================================
-- QR-110001 | T1566.001 | Office Application Spawning Shell (Spearphishing)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessCreate%'
  AND (UTF8(payload) ILIKE '%winword%'
    OR UTF8(payload) ILIKE '%excel%'
    OR UTF8(payload) ILIKE '%powerpnt%'
    OR UTF8(payload) ILIKE '%outlook%'
    OR UTF8(payload) ILIKE '%onenote%')
  AND (UTF8(payload) ILIKE '%cmd.exe%'
    OR UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%cscript%'
    OR UTF8(payload) ILIKE '%mshta%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110002 | T1566.001 | Office Macro Download Network Connection
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  destinationip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND (UTF8(payload) ILIKE '%winword%'
    OR UTF8(payload) ILIKE '%excel%'
    OR UTF8(payload) ILIKE '%powerpnt%')
  AND NOT destinationport IN (80, 443)
LAST 1440 MINUTES;


-- ==================================================
-- QR-110003 | T1566.001 | Office Application Writing Executable to Disk
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%winword%'
    OR UTF8(payload) ILIKE '%excel%'
    OR UTF8(payload) ILIKE '%powerpnt%')
  AND (UTF8(payload) ILIKE '%.exe%'
    OR UTF8(payload) ILIKE '%.dll%'
    OR UTF8(payload) ILIKE '%.bat%'
    OR UTF8(payload) ILIKE '%.ps1%'
    OR UTF8(payload) ILIKE '%.vbs%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110004 | T1566.002 | Link File Downloaded from Web (LNK / URL in Downloads)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Temp\%')
  AND (UTF8(payload) ILIKE '%.lnk%'
    OR UTF8(payload) ILIKE '%.url%'
    OR UTF8(payload) ILIKE '%.webloc%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110005 | T1566.001 | ISO / IMG File Mounted from Email (Mark of the Web)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%.iso%'
    OR UTF8(payload) ILIKE '%.img%'
    OR UTF8(payload) ILIKE '%.vhd%'
    OR UTF8(payload) ILIKE '%.vhdx%')
  AND (UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\AppData\Local\Temp\%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110006 | T1566.001 | CHM File Execution from Download Folder
