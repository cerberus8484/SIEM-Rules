SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND (username ILIKE '%guest%'
    OR username ILIKE '%kiosk%'
    OR username ILIKE '%default%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110031 | T1190 | CVE Exploitation — Citrix / Pulse / F5 Patterns in Payload
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%')
  AND (UTF8(payload) ILIKE '%CVE-2019-19781%'
    OR UTF8(payload) ILIKE '%CVE-2020-2021%'
    OR UTF8(payload) ILIKE '%CVE-2021-22893%'
    OR UTF8(payload) ILIKE '%.portal\fgt_lang%'
    OR UTF8(payload) ILIKE '%/vpns/cfg%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110032 | T1566.001 | Emotet-style Attached XLSM Chain (Office + Regsvr32)
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessCreate%'
  AND (UTF8(payload) ILIKE '%excel%'
    OR UTF8(payload) ILIKE '%winword%')
  AND UTF8(payload) ILIKE '%regsvr32%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-110033 | T1566.001 | QR Code / Quishing — Mshta Fetching Remote URL after Email
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%NetworkConnect%'
  AND UTF8(payload) ILIKE '%mshta%'
  AND NOT (destinationip ILIKE '10.%'
    OR destinationip ILIKE '192.168.%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110034 | T1078 | Impossible Travel — Same User Logon from 2 Countries in 5 min
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  username,
  COUNT(DISTINCT sourceip) AS SourceCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND NOT (sourceip ILIKE '10.%'
    OR sourceip ILIKE '192.168.%'
    OR sourceip ILIKE '172.1%.%')
  AND NOT username ILIKE '%$%'
GROUP BY username
HAVING COUNT(DISTINCT sourceip) >= 2
LAST 5 MINUTES;


-- ==================================================
-- QR-110035 | T1190 | Spring4Shell / SpEL Injection Pattern
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE (LOGSOURCETYPENAME(logsourceid) ILIKE '%IIS%'
    OR LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%')
  AND (UTF8(payload) ILIKE '%class.module.classLoader%'
    OR UTF8(payload) ILIKE '%CVE-2022-22965%'
    OR UTF8(payload) ILIKE '%allowedClass%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110036 | T1566.001 | Malicious Archive Delivered via Teams / Slack
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%Teams%'
    OR UTF8(payload) ILIKE '%Slack%')
  AND (UTF8(payload) ILIKE '%.zip%'
    OR UTF8(payload) ILIKE '%.iso%'
    OR UTF8(payload) ILIKE '%.7z%'
    OR UTF8(payload) ILIKE '%.lnk%')
