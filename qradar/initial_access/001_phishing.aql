-- ==================================================
-- QR-110040 | T1566 | Dropper Chain — 3+ Suspicious Processes from Same Parent in 5 min
-- Severity: Critical | Confidence: High
-- Threshold: dropper chain indicator — parent spawning 3+ suspicious children
-- ==================================================
SELECT
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  COUNT(*) AS SuspiciousChain
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessCreate%'
  AND (UTF8(payload) ILIKE '%cmd.exe%'
    OR UTF8(payload) ILIKE '%powershell%'
    OR UTF8(payload) ILIKE '%wscript%'
    OR UTF8(payload) ILIKE '%mshta%'
    OR UTF8(payload) ILIKE '%regsvr32%')
GROUP BY LOGSOURCENAME(logsourceid), username
HAVING COUNT(*) >= 3
LAST 5 MINUTES;
