-- ==================================================
-- QR-110011 | T1195 | Software Supply Chain — Unsigned Installer from Download
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%ProcessCreate%'
  AND (UTF8(payload) ILIKE '%\Downloads\%'
    OR UTF8(payload) ILIKE '%\Temp\%')
  AND (UTF8(payload) ILIKE '%setup%'
    OR UTF8(payload) ILIKE '%install%'
    OR UTF8(payload) ILIKE '%update%')
  AND (UTF8(payload) ILIKE '%.exe%')
LAST 1440 MINUTES;


-- ==================================================
-- QR-110012 | T1078.002 | Valid Account — VPN Logon from New Country
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND NOT (sourceip ILIKE '10.%'
    OR sourceip ILIKE '192.168.%'
    OR sourceip ILIKE '172.1%.%')
  AND UTF8(payload) ILIKE '%VPN%'
LAST 1440 MINUTES;


-- ==================================================
-- QR-110013 | T1078 | Successful Login after Multiple Failures (Brute Force Win)
-- Severity: High | Confidence: High
-- ==================================================
SELECT
  username,
  sourceip,
  COUNT(*) AS FailCount
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4625<%'
    OR UTF8(payload) ILIKE '%EventID">"4625"%')
GROUP BY username, sourceip
HAVING COUNT(*) >= 10
LAST 15 MINUTES;


-- ==================================================
-- QR-110014 | T1078 | Service Account Login from Interactive Workstation (4624 Type 2/10)
-- Severity: High | Confidence: Medium
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  sourceip,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Windows%'
  AND (UTF8(payload) ILIKE '%EventID>4624<%'
    OR UTF8(payload) ILIKE '%EventID">"4624"%')
  AND (username ILIKE '%svc%'
    OR username ILIKE '%service%'
    OR username ILIKE '%bot%')
  AND (UTF8(payload) ILIKE '%LogonType>2<%'
    OR UTF8(payload) ILIKE '%LogonType>10<%')
LAST 1440 MINUTES;


