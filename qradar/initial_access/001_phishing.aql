-- ==================================================
-- QR-110008 | T1190 | Web Shell Dropped in Web Root
-- Severity: Critical | Confidence: High
-- ==================================================
SELECT
  DATEFORMAT(startTime, 'yyyy-MM-dd HH:mm:ss') AS EventTime,
  LOGSOURCENAME(logsourceid) AS LogSource,
  username,
  UTF8(payload) AS EventPayload
FROM events
WHERE LOGSOURCETYPENAME(logsourceid) ILIKE '%Sysmon%'
  AND UTF8(payload) ILIKE '%FileCreate%'
  AND (UTF8(payload) ILIKE '%\inetpub\wwwroot\%'
    OR UTF8(payload) ILIKE '%\htdocs\%'
    OR UTF8(payload) ILIKE '%\www\%')
  AND (UTF8(payload) ILIKE '%.php%'
    OR UTF8(payload) ILIKE '%.asp%'
    OR UTF8(payload) ILIKE '%.aspx%'
    OR UTF8(payload) ILIKE '%.jsp%')
LAST 1440 MINUTES;


