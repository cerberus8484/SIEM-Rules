-- QR-200016 | Cloud-AWS | RDS Snapshot öffentlich
-- MITRE: T1537 | Severity: CRITICAL | Confidence: 92
SELECT
  DATEFORMAT(devicetime, 'yyyy-MM-dd HH:mm:ss') AS "Zeit",
  username AS "Actor",
  sourceip AS "Quell-IP",
  UTF8(payload) AS "Payload"
FROM events
WHERE logsourcetypename(logsourceid) ILIKE '%CloudTrail%'
  AND UTF8(payload) ILIKE '%"eventName":"ModifyDBSnapshotAttribute"%'
  AND (UTF8(payload) ILIKE '%public%'
    OR UTF8(payload) ILIKE '%all%')
LAST 1440 MINUTES

-- QR-200017 | Cloud-AWS | AssumeRole über Account-Grenzen hinweg
-- MITRE: T1548 | Severity: HIGH | Confidence: 75
