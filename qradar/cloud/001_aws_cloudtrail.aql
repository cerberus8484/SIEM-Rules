-- QR-200020 | Cloud-AWS | Impact-Chain: GuardDuty + CloudTrail + Config deaktiviert
-- MITRE: T1562 | Severity: CRITICAL | Confidence: 95
SELECT
  username AS "Actor",
  COUNT(DISTINCT UTF8(payload)) AS "Anzahl_Aktionen"
FROM events
WHERE logsourcetypename(logsourceid) ILIKE '%CloudTrail%'
  AND (UTF8(payload) ILIKE '%"eventName":"DeleteDetector"%'
    OR UTF8(payload) ILIKE '%"eventName":"StopLogging"%'
    OR UTF8(payload) ILIKE '%"eventName":"StopConfigurationRecorder"%')
GROUP BY username
HAVING COUNT(DISTINCT UTF8(payload)) >= 2
LAST 60 MINUTES
