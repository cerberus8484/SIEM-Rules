// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Persistence — Registry Run Keys / Hijacking (T1547)
// Batch    : 04 / Persistence
// Rules    : GS-101001 – GS-101025
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_101001_registry_run_key_write {
  meta:
    rule_id         = "GS-101001"
    author          = "HuntingThreats"
    description     = "Registry Run key written by non-system process — persistence via Run key"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1547.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\(Run|RunOnce|RunServices|RunServicesOnce)$`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(msiexec|setup|install|update).*\.exe$`)

  condition:
    $e
}

rule ht_gs_101002_registry_run_from_temp {
  meta:
    rule_id         = "GS-101002"
    author          = "HuntingThreats"
    description     = "Run key pointing to Temp/AppData path — staging path persistence"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1547.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\(Run|RunOnce)`)
    re.regex($e.target.registry.registry_value_data, `(?i)(\\temp\\|\\appdata\\|\\programdata\\)`)

  condition:
    $e
}

