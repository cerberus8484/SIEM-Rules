rule ht_gs_101009_registry_screensaver_path {
  meta:
    rule_id         = "GS-101009"
    author          = "HuntingThreats"
    description     = "Screensaver registry path changed to non-.scr executable — persistence"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1546.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Control Panel\\Desktop.*SCRNSAVE\.EXE`)
    NOT re.regex($e.target.registry.registry_value_data, `(?i)\.scr$`)

  condition:
    $e
}

