    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Windows Defender`)
    re.regex($e.target.registry.registry_key, `(?i)(DisableAntiSpyware|DisableRealtimeMonitoring|DisableBehaviorMonitoring)`)
