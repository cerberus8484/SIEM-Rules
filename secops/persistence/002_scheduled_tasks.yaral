rule ht_gs_101050_task_hidden_delete_run_once {
  meta:
    rule_id         = "GS-101050"
    author          = "HuntingThreats"
    description     = "RunOnce key written pointing to cmd self-delete — one-shot payload execution"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1547.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\RunOnce`)
