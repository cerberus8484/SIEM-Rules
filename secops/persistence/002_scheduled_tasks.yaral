rule ht_gs_101041_task_query_hidden {
  meta:
    rule_id         = "GS-101041"
    author          = "HuntingThreats"
    description     = "Task with Hidden flag in XML — concealed task registration"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1564.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\System32\\Tasks\\`)
    re.regex($e.target.file.full_path, `(?i)\.(xml|job)$`)

  condition:
    $e
}

rule ht_gs_101042_task_high_frequency_creation {
  meta:
    rule_id         = "GS-101042"
    author          = "HuntingThreats"
    description     = "Multiple scheduled tasks created in short time — batch task creation anomaly"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1053.005"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/create`)

  match:
    $e.principal.hostname over 5m

  condition:
    #e > 5
}

rule ht_gs_101043_task_run_key_combo {
  meta:
    rule_id         = "GS-101043"
    author          = "HuntingThreats"
    description     = "Both Run key and scheduled task created in same session — redundant persistence"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e1.target.registry.registry_key, `(?i)\\(Run|RunOnce)`)

    $e2.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e2.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e2.target.process.command_line, `(?i)/create`)

    $e1.principal.hostname = $e2.principal.hostname

  match:
    $e1.principal.hostname over 30m

  condition:
    $e1 and $e2
}

rule ht_gs_101044_task_ps_named_pipe_action {
  meta:
    rule_id         = "GS-101044"
    author          = "HuntingThreats"
