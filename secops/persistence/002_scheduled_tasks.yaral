// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Persistence — Scheduled Tasks (T1053)
// Batch    : 05 / Persistence
// Rules    : GS-101026 – GS-101055
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_101026_task_schtasks_powershell {
  meta:
    rule_id         = "GS-101026"
    author          = "HuntingThreats"
    description     = "Schtasks creating task that runs PowerShell — PS persistence via task"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/create`)
    re.regex($e.target.process.command_line, `(?i)(powershell|pwsh)`)

  condition:
    $e
}

rule ht_gs_101027_task_schtasks_from_temp {
  meta:
    rule_id         = "GS-101027"
    author          = "HuntingThreats"
    description     = "Schtasks task pointing to Temp/AppData binary — staging path task"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/create`)
    re.regex($e.target.process.command_line, `(?i)(\\temp\\|\\appdata\\|\\programdata\\)`)

  condition:
    $e
}

