rule ht_gs_101046_task_startup_folder_drop {
  meta:
    rule_id         = "GS-101046"
    author          = "HuntingThreats"
    description     = "File dropped in Startup folder by non-installer process — startup persistence"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1547.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(msiexec|setup|install).*\.exe$`)

  condition:
    $e
}

rule ht_gs_101047_task_exec_encoded_ps_action {
  meta:
    rule_id         = "GS-101047"
    author          = "HuntingThreats"
    description     = "Scheduled task launches PowerShell with -Encoded — obfuscated PS from task"
    mitre_tactic    = "Execution"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.principal.process.file.full_path, `(?i)\\(taskeng|taskhostw|svchost)\.exe$`)
    re.regex($e.target.process.file.full_path, `(?i)\\powershell\.exe$`)
    re.regex($e.target.process.command_line, `(?i)-enc`)

  condition:
    $e
}

