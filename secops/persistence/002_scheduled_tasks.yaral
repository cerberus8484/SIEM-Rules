rule ht_gs_101055_task_creation_threshold {
  meta:
    rule_id         = "GS-101055"
    author          = "HuntingThreats"
    description     = "Mass scheduled task creation — 10+ tasks created in 10 minutes — automation sweep"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\Windows\\System32\\Tasks\\`)

  match:
    $e.principal.hostname over 10m

  condition:
    #e > 10
}
