    re.regex($e.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/delete.*\/f`)

  condition:
    $e
}

rule ht_gs_101031_task_ps_register_scheduledtask {
  meta:
