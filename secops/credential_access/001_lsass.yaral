rule ht_gs_103022_password_spray_threshold {
  meta:
    rule_id         = "GS-103022"
    author          = "HuntingThreats"
    description     = "Password spray — 10+ failed logins from single source in 5 minutes"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1110.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.extensions.auth.auth_details = "FAILED"

  match:
    $e.principal.ip over 5m

  condition:
    #e > 10
}

rule ht_gs_103023_brute_force_success_after_failures {
  meta:
    rule_id         = "GS-103023"
    author          = "HuntingThreats"
    description     = "Successful login after 5+ failures from same IP — brute force success"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1110.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "USER_LOGIN"
    $e1.extensions.auth.auth_details = "FAILED"
    $e2.metadata.event_type = "USER_LOGIN"
    $e2.extensions.auth.auth_details = "SUCCESS"
    $e1.principal.ip = $e2.principal.ip

  match:
    $e1.principal.ip over 10m

  condition:
    #e1 > 5 and $e2
}

