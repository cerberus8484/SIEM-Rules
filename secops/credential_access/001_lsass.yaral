rule ht_gs_103027_lsaprotect_patch {
  meta:
    rule_id         = "GS-103027"
    author          = "HuntingThreats"
    description     = "LSA RunAsPPL registry disabled — LSASS protection removal"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.010"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\lsa\\RunAsPPL`)
    $e.target.registry.registry_value_data = "0"

  condition:
    $e
}

