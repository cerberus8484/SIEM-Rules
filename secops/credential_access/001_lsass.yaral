rule ht_gs_103006_sam_hive_access {
  meta:
    rule_id         = "GS-103006"
    author          = "HuntingThreats"
    description     = "SAM hive file read by non-system process — local credential dump"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1003.002"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\Windows\\System32\\config\\(SAM|SYSTEM|SECURITY)`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(System|lsass|smss|winlogon)\.exe$`)

  condition:
    $e
}

