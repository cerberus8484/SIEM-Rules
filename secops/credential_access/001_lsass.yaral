// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Credential Access — LSASS / Kerberos / Token Theft (T1003, T1558, T1550)
// Batch    : 07 / Credential Access
// Rules    : GS-103001 – GS-103035
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_103001_lsass_procdump_access {
  meta:
    rule_id         = "GS-103001"
    author          = "HuntingThreats"
    description     = "Procdump targeting lsass.exe — credential dump via Sysinternals tool"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1003.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\procdump(64)?\.exe$`)
    re.regex($e.target.process.command_line, `(?i)lsass`)

  condition:
    $e
}

rule ht_gs_103002_lsass_mimikatz_sekurlsa {
  meta:
    rule_id         = "GS-103002"
    author          = "HuntingThreats"
    description     = "Mimikatz sekurlsa or lsadump keyword in command line — credential tool"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1003.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(sekurlsa|lsadump|privilege::debug|token::elevate)`)

  condition:
    $e
}

rule ht_gs_103003_lsass_task_manager_dump {
  meta:
    rule_id         = "GS-103003"
