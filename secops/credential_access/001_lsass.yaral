    re.regex($e.principal.process.file.full_path, `(?i)\\taskmgr\.exe$`)
    re.regex($e.target.file.full_path, `(?i)lsass.*\.dmp$`)

  condition:
    $e
}

rule ht_gs_103004_lsass_dump_file_creation {
