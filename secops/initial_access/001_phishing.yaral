// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Initial Access — Phishing / Exploit / Supply Chain (T1566, T1190, T1195)
// Batch    : 15 / Initial Access
// Rules    : GS-110001 – GS-110040
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_110001_office_spawns_powershell {
  meta:
    rule_id         = "GS-110001"
    author          = "HuntingThreats"
    description     = "Office application spawning PowerShell — macro-based initial access"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1566.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\powershell\.exe$`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(winword|excel|powerpnt|onenote|outlook)\.exe$`)

  condition:
    $e
}

rule ht_gs_110002_iso_img_from_downloads {
  meta:
    rule_id         = "GS-110002"
    author          = "HuntingThreats"
    description     = "ISO/IMG/VHD file mounted from Downloads — container-based phishing delivery"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1204.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(\\downloads\\|\\temp\\).*\.(iso|img|vhd|vhdx)`)

  condition:
    $e
}

rule ht_gs_110003_chm_hh_execute {
  meta:
    rule_id         = "GS-110003"
    author          = "HuntingThreats"
    description     = "CHM file executed via hh.exe — compiled HTML help phishing delivery"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1204.002"
