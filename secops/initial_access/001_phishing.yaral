    re.regex($e.principal.process.file.full_path, `(?i)\\w3wp\.exe$`)
    re.regex($e.target.process.file.full_path, `(?i)\\(cmd|powershell|wscript|cscript|mshta|rundll32)\.exe$`)

  condition:
    $e
}

rule ht_gs_110006_apache_spawn_shell {
