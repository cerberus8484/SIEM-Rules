rule ht_gs_110036_vpn_credential_spray {
  meta:
    rule_id         = "GS-110036"
    author          = "HuntingThreats"
    description     = "VPN auth failure spike from external IP — credential spray against VPN"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1133"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.extensions.auth.auth_details = "FAILED"
    re.regex($e.target.application, `(?i)(vpn|forticlient|pulsesecure|anyconnect|globalprotect)`)

  match:
    $e.principal.ip over 5m

  condition:
    #e > 5
}

rule ht_gs_110037_drive_by_download_js {
  meta:
    rule_id         = "GS-110037"
    author          = "HuntingThreats"
    description     = "Browser downloading and immediately executing .js file — drive-by JS payload"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1189"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(wscript|cscript)\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\\downloads\\|\\temp\\).*\.js$`)

  condition:
    $e
}

rule ht_gs_110038_external_rdp_initial {
  meta:
    rule_id         = "GS-110038"
    author          = "HuntingThreats"
    description     = "RDP access from external IP with first-time successful logon — initial RDP access"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1133"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.network.application_protocol = "RDP"
    $e.extensions.auth.auth_details = "SUCCESS"
    NOT $e.principal.ip in cidr "10.0.0.0/8"
    NOT $e.principal.ip in cidr "192.168.0.0/16"
    NOT $e.principal.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_110039_one_time_password_bypass {
  meta:
    rule_id         = "GS-110039"
    author          = "HuntingThreats"
    description     = "MFA push fatigue — multiple MFA requests from same user in short time"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1621"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.metadata.product_name, `(?i)(mfa|okta|azure.*mfa|duo|authenticator)`)

  match:
    $e.target.user.userid over 5m

  condition:
    #e > 5
}

rule ht_gs_110040_initial_access_combo_detection {
  meta:
    rule_id         = "GS-110040"
    author          = "HuntingThreats"
    description     = "Initial access combo — external logon + discovery + persistence within 30 min"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1078"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "USER_LOGIN"
    $e1.extensions.auth.auth_details = "SUCCESS"
    NOT $e1.principal.ip in cidr "10.0.0.0/8"
    NOT $e1.principal.ip in cidr "192.168.0.0/16"

    $e2.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e2.target.process.file.full_path, `(?i)\\(net|nltest|whoami|tasklist|ipconfig|systeminfo)\.exe$`)

    $e3.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e3.target.registry.registry_key, `(?i)\\(Run|RunOnce|Startup)`)

    $e1.target.hostname = $e2.principal.hostname
    $e2.principal.hostname = $e3.principal.hostname

  match:
    $e1.target.hostname over 30m

  condition:
    $e1 and $e2 and $e3
}
