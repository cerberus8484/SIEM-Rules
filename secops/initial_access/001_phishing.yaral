    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\hh\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\\downloads\\|\\temp\\|\\desktop\\)`)

  condition:
    $e
}

rule ht_gs_110004_web_shell_dropped {
  meta:
    rule_id         = "GS-110004"
    author          = "HuntingThreats"
    description     = "Web shell dropped in web root — server-side exploitation initial access"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1190"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\(inetpub|htdocs|www|wwwroot|public_html)\\.*\.(php|aspx|jsp|asp|ashx|cfm)$`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(w3wp|httpd|nginx|apache|tomcat|java|python)`)

  condition:
    $e
}

rule ht_gs_110005_iis_w3wp_spawn_shell {
  meta:
    rule_id         = "GS-110005"
