rule ht_gs_110018_dropper_child_threshold {
  meta:
    rule_id         = "GS-110018"
    author          = "HuntingThreats"
    description     = "3+ suspicious child processes from single parent in 5 min — dropper chain"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1204.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(cmd|powershell|wscript|cscript|mshta|rundll32|regsvr32)\.exe$`)

  match:
    $e.principal.process.file.full_path over 5m

  condition:
    #e > 3
}

rule ht_gs_110019_impossible_travel {
  meta:
    rule_id         = "GS-110019"
    author          = "HuntingThreats"
    description     = "Same user logging in from 2+ distinct external IPs in 5 min — impossible travel"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1078"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.extensions.auth.auth_details = "SUCCESS"
    NOT $e.principal.ip in cidr "10.0.0.0/8"
    NOT $e.principal.ip in cidr "192.168.0.0/16"

  match:
    $e.target.user.userid over 5m

  condition:
    #e > 2
}

