}

rule ht_gs_110008_spring4shell_classloader {
  meta:
    rule_id         = "GS-110008"
    author          = "HuntingThreats"
    description     = "Spring4Shell — class.module.classLoader in HTTP parameter — CVE-2022-22965"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1190"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    re.regex($e.network.http.url, `(?i)(class\.module\.classLoader|class\.classLoader)`)

  condition:
    $e
}

rule ht_gs_110009_proxyshell_exchange {
  meta:
    rule_id         = "GS-110009"
    author          = "HuntingThreats"
    description     = "ProxyShell — Exchange w3wp.exe spawning cmd.exe — CVE-2021-34473"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1190"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.principal.process.file.full_path, `(?i)\\w3wp\.exe$`)
    re.regex($e.target.process.file.full_path, `(?i)\\cmd\.exe$`)
    re.regex($e.principal.process.command_line, `(?i)(MSExchange|ClientAccess|OWA)`)

  condition:
    $e
}

rule ht_gs_110010_sql_injection_union {
  meta:
    rule_id         = "GS-110010"
    author          = "HuntingThreats"
    description     = "SQL injection pattern in HTTP — UNION SELECT or WAITFOR DELAY"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1190"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    re.regex($e.network.http.url, `(?i)(union\s+select|waitfor\s+delay|'.*or.*'.*=|1=1|sleep\(\d+\))`)

  condition:
    $e
}

rule ht_gs_110011_directory_traversal {
  meta:
    rule_id         = "GS-110011"
    author          = "HuntingThreats"
    description     = "Directory traversal attempt in HTTP request — ../ path traversal"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1190"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    re.regex($e.network.http.url, `(?i)(\.\./|\.\.\\|%2e%2e%2f|%2e%2e/)`)

  condition:
    $e
}

rule ht_gs_110012_password_spray_initial {
  meta:
    rule_id         = "GS-110012"
    author          = "HuntingThreats"
    description     = "Password spray — 5+ distinct usernames from single IP in 5 min"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1078"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.extensions.auth.auth_details = "FAILED"

  match:
    $e.principal.ip over 5m

  condition:
    #e > 5
}

rule ht_gs_110013_brute_force_success {
  meta:
    rule_id         = "GS-110013"
    author          = "HuntingThreats"
    description     = "Successful logon after 10+ failures from same IP — brute force success"
    mitre_tactic    = "Initial Access"
    mitre_technique = "T1110"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "USER_LOGIN"
    $e1.extensions.auth.auth_details = "FAILED"

    $e2.metadata.event_type = "USER_LOGIN"
    $e2.extensions.auth.auth_details = "SUCCESS"

    $e1.principal.ip = $e2.principal.ip

  match:
    $e1.principal.ip over 10m

  condition:
    #e1 > 10 and $e2
}

rule ht_gs_110014_clickfix_clipboard_iex {
  meta:
    rule_id         = "GS-110014"
    author          = "HuntingThreats"
    description     = "ClickFix attack — Get-Clipboard + IEX — clipboard-injected PS execution"
