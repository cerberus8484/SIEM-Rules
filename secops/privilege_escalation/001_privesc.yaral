    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)HKCU.*\\exefile\\Shell\\runas\\command\\IsolatedCommand`)

  condition:
    $e
}

rule ht_gs_109004_uac_bypass_cmstp {
  meta:
    rule_id         = "GS-109004"
    author          = "HuntingThreats"
    description     = "CMSTP /s used for UAC bypass — auto-elevated COM object abuse"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1548.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\cmstp\.exe$`)
    re.regex($e.target.process.command_line, `(?i)\/s`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|cmd|wscript)\.exe$`)

  condition:
    $e
}

rule ht_gs_109005_uac_bypass_computerdefaults {
  meta:
    rule_id         = "GS-109005"
