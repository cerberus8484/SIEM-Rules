rule ht_gs_109018_kernel_driver_byovd {
  meta:
    rule_id         = "GS-109018"
    author          = "HuntingThreats"
    description     = "Known vulnerable driver loaded for kernel exploitation — BYOVD attack"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1068"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "SERVICE_CREATION"
    re.regex($e.target.resource.name, `(?i)(gdrv|rtcore64|dbutil_2_3|cpuz|mhyprot|iqvw64|ntiolib|winio|razer|aswarpot|kprocesshacker)`)

