    mitre_technique = "T1055"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(net|sc|schtasks|reg|wmic)\.exe$`)
    $e.principal.user.userid = "SYSTEM"
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(svchost|services|wmiprvse|taskhost)\.exe$`)

  condition:
    $e
}

rule ht_gs_109037_getsystem_meterpreter {
  meta:
    rule_id         = "GS-109037"
    author          = "HuntingThreats"
    description     = "Meterpreter getsystem technique — named pipe or token duplication for SYSTEM"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1134.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(getsystem|Incognito|ImpersonateToken|steal_token)`)

  condition:
    $e
}

rule ht_gs_109038_credentialguard_bypass {
  meta:
    rule_id         = "GS-109038"
    author          = "HuntingThreats"
    description     = "Credential Guard bypass attempt — disabling HVCI or SecureBoot for cred access"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.010"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\DeviceGuard`)
    re.regex($e.target.registry.registry_key, `(?i)(EnableVirtualizationBasedSecurity|LsaCfgFlags)`)
    $e.target.registry.registry_value_data = "0"

  condition:
    $e
}

rule ht_gs_109039_whoami_system_verify {
  meta:
    rule_id         = "GS-109039"
    author          = "HuntingThreats"
    description     = "Whoami returning SYSTEM from script — privilege escalation success verification"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1033"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\whoami\.exe$`)
    $e.principal.user.userid = "SYSTEM"
    re.regex($e.principal.process.file.full_path, `(?i)\\(cmd|powershell|wscript)\.exe$`)

  condition:
    $e
}

rule ht_gs_109040_privesc_exploit_chain {
  meta:
    rule_id         = "GS-109040"
    author          = "HuntingThreats"
    description     = "Privilege escalation chain — non-admin process spawning SYSTEM child — full chain"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1068"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "PROCESS_LAUNCH"
    NOT $e1.principal.user.userid = "SYSTEM"
    re.regex($e1.target.process.file.full_path, `(?i)\\(cmd|powershell|wscript|cscript|mshta)\.exe$`)

    $e2.metadata.event_type = "PROCESS_LAUNCH"
    $e2.principal.user.userid = "SYSTEM"
    $e2.principal.process.file.full_path = $e1.target.process.file.full_path

    $e1.principal.hostname = $e2.principal.hostname

  match:
    $e1.principal.hostname over 5m

  condition:
    $e1 and $e2
}
