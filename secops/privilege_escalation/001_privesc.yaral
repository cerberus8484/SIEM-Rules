rule ht_gs_109019_unquoted_service_path {
  meta:
    rule_id         = "GS-109019"
    author          = "HuntingThreats"
    description     = "Service with unquoted path containing spaces — privilege escalation via DLL plant"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1574.009"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Services\\.*\\ImagePath`)
    re.regex($e.target.registry.registry_value_data, `^[^"'].*\s.*\\.*\.exe`)
    NOT re.regex($e.target.registry.registry_value_data, `^"`)

  condition:
    $e
}

rule ht_gs_109020_always_install_elevated {
  meta:
    rule_id         = "GS-109020"
    author          = "HuntingThreats"
    description     = "AlwaysInstallElevated enabled — MSI install with SYSTEM privileges"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1548.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Installer\\AlwaysInstallElevated`)
    $e.target.registry.registry_value_data = "1"

  condition:
    $e
}

rule ht_gs_109021_process_from_system_parent_unusual {
  meta:
    rule_id         = "GS-109021"
    author          = "HuntingThreats"
    description     = "SYSTEM-context process from unexpected parent — threshold 3+ in 5 min"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1055"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    $e.principal.user.userid = "SYSTEM"
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(services|svchost|wininit|smss|ntoskrnl|taskhost|taskhostw|msiexec|trustedinstaller)`)

  match:
    $e.principal.hostname over 5m

  condition:
    #e > 3
}

