    mitre_technique = "T1543.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Services\\.*\\ServiceDll`)
    re.regex($e.target.registry.registry_value_data, `(?i)(\\Users\\|\\Temp\\|\\AppData\\)`)

  condition:
    $e
}

rule ht_gs_109011_consentprompt_disabled {
  meta:
    rule_id         = "GS-109011"
    author          = "HuntingThreats"
