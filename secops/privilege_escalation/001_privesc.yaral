    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)HKCU.*\\AppX.*Shell\\Open\\Command`)

  condition:
    $e
}

rule ht_gs_109006_juicypotato_rottenpotatong {
  meta:
    rule_id         = "GS-109006"
    author          = "HuntingThreats"
    description     = "JuicyPotato/RottenPotato/GodPotato/SweetPotato CLSID escalation"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1134.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(juicypotato|rottenpotato|godpotato|sweetpotato|printspoofer|roguepotato)`)

  condition:
    $e
}

rule ht_gs_109007_sebdebugprivilege_abuse {
  meta:
    rule_id         = "GS-109007"
    author          = "HuntingThreats"
    description     = "SeDebugPrivilege used by non-system process — privilege abuse for injection"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1134"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(SeDebugPrivilege|AdjustTokenPrivileges)`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(taskmgr|procexp|svchost|lsass)\.exe$`)

  condition:
    $e
}

rule ht_gs_109008_dll_search_order_hijack {
  meta:
    rule_id         = "GS-109008"
    author          = "HuntingThreats"
    description     = "DLL dropped in application directory of privileged binary — search order hijack"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1574.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\Program Files.*\.dll$`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(msiexec|setup|install|trustedinstaller|tiworker)`)

  condition:
    $e
}

rule ht_gs_109009_print_nightmare_spoolsv {
  meta:
    rule_id         = "GS-109009"
    author          = "HuntingThreats"
    description     = "PrintNightmare — spoolsv.exe loading DLL from non-System32 path"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1547.012"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.principal.process.file.full_path, `(?i)\\spoolsv\.exe$`)
    re.regex($e.target.file.full_path, `(?i)\.dll$`)
    NOT re.regex($e.target.file.full_path, `(?i)\\(System32|SysWOW64)\\`)

  condition:
    $e
}

rule ht_gs_109010_service_dll_user_path {
  meta:
    rule_id         = "GS-109010"
    author          = "HuntingThreats"
    description     = "ServiceDll registry pointing to user-writable path — DLL service escalation"
