// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Privilege Escalation — UAC Bypass / Token Theft / Exploits (T1134, T1548, T1068)
// Batch    : 14 / Privilege Escalation
// Rules    : GS-109001 – GS-109040
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_109001_uac_bypass_fodhelper {
  meta:
    rule_id         = "GS-109001"
    author          = "HuntingThreats"
    description     = "UAC bypass via fodhelper ms-settings registry key — HKCU COM hijack"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1548.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)HKCU.*\\ms-settings\\Shell\\Open\\Command`)

  condition:
    $e
}

rule ht_gs_109002_uac_bypass_eventvwr {
  meta:
    rule_id         = "GS-109002"
    author          = "HuntingThreats"
    description     = "UAC bypass via eventvwr mscfile registry — auto-elevate exploit"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1548.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)HKCU.*\\mscfile\\Shell\\Open\\Command`)

  condition:
    $e
}

rule ht_gs_109003_uac_bypass_sdclt {
  meta:
    rule_id         = "GS-109003"
    author          = "HuntingThreats"
    description     = "UAC bypass via sdclt IsolatedCommand registry — Backup and Restore UAC bypass"
    mitre_tactic    = "Privilege Escalation"
