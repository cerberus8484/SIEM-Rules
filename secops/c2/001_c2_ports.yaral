// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Command & Control — C2 Beaconing / Tunneling / RATs (T1071, T1095, T1571)
// Batch    : 08 / C2
// Rules    : GS-104001 – GS-104035
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_104001_c2_non_standard_high_port {
  meta:
    rule_id         = "GS-104001"
    author          = "HuntingThreats"
    description     = "Outbound connection to non-standard high port (8443/4443/8080) from workstation"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1571"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [4443, 8443, 8080, 9001, 9090, 1337, 31337]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_104002_c2_cobalt_strike_default_port {
  meta:
    rule_id         = "GS-104002"
    author          = "HuntingThreats"
    description     = "Outbound TCP 50050 — Cobalt Strike default Team Server port"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port = 50050
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  condition:
    $e
}

rule ht_gs_104003_c2_metasploit_port {
  meta:
    rule_id         = "GS-104003"
    author          = "HuntingThreats"
    description     = "Outbound TCP 4444 to external IP — Metasploit default reverse shell port"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1095"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port = 4444
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_104004_c2_beacon_regular_interval {
  meta:
    rule_id         = "GS-104004"
    author          = "HuntingThreats"
    description     = "Regular outbound connections from one host to one external IP — beaconing pattern"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"
    NOT $e.target.ip in cidr "127.0.0.0/8"

  match:
    $e.principal.hostname, $e.target.ip over 60m

  condition:
    #e > 20
}

rule ht_gs_104005_c2_dns_long_subdomain {
  meta:
    rule_id         = "GS-104005"
    author          = "HuntingThreats"
    description     = "DNS query with subdomain > 50 chars — DNS tunneling data exfil"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.004"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `.{50,}\..+\..+`)

  condition:
    $e
}

rule ht_gs_104006_c2_dns_many_queries_same_domain {
  meta:
    rule_id         = "GS-104006"
    author          = "HuntingThreats"
    description     = "High-frequency DNS queries to same domain — DNS tunnel data stream"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.004"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_DNS"

  match:
    $e.principal.hostname, $e.network.dns.questions.name over 10m

  condition:
    #e > 100
}

rule ht_gs_104007_c2_iodine_dns_tool {
  meta:
    rule_id         = "GS-104007"
    author          = "HuntingThreats"
    description     = "Iodine or dnscat DNS tunnel tool execution"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.004"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(iodine|dnscat|dns2tcp)`)

  condition:
    $e
}

rule ht_gs_104008_c2_tor_exit_node_port {
  meta:
    rule_id         = "GS-104008"
    author          = "HuntingThreats"
    description     = "Outbound TCP 9050/9150/9001 — Tor SOCKS proxy or relay port"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1090.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [9050, 9150, 9001, 9030]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  condition:
    $e
}

rule ht_gs_104009_c2_empire_http_ua {
  meta:
    rule_id         = "GS-104009"
    author          = "HuntingThreats"
    description     = "Empire C2 user agent pattern in HTTP — Mozilla/5.0 (Windows; .*rv:) PowerShell"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    re.regex($e.network.http.user_agent, `(?i)(PowerShell\/|MSHTA\/|invoke-webrequest)`)

  condition:
    $e
}

rule ht_gs_104010_c2_named_pipe_cobalt {
  meta:
    rule_id         = "GS-104010"
    author          = "HuntingThreats"
    description     = "Cobalt Strike default named pipe pattern — \\postex_ssh_ or \\msagent_ pipes"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1090.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(\\\\\.\\pipe\\(postex_ssh_|msagent_|mojo\.|chrome\.|status_|MSSE-|spoolss|\\ntsvcs|\\scerpc))`)

  condition:
    $e
}

rule ht_gs_104011_c2_process_unusual_outbound {
  meta:
    rule_id         = "GS-104011"
    author          = "HuntingThreats"
    description     = "Unusual process making outbound connection — non-browser making HTTPS on 443"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [80, 443]
    re.regex($e.principal.process.file.full_path, `(?i)\\(cmd|powershell|rundll32|regsvr32|mshta|wscript|cscript)\.exe$`)
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  condition:
    $e
}

rule ht_gs_104012_c2_sliver_default_port {
  meta:
    rule_id         = "GS-104012"
    author          = "HuntingThreats"
    description     = "Outbound TCP 31337 or 8888 — Sliver C2 default ports"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [31337, 8888]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  condition:
    $e
}

rule ht_gs_104013_c2_brute_ratel_port {
  meta:
    rule_id         = "GS-104013"
    author          = "HuntingThreats"
    description     = "Brute Ratel C4 default port 443 with Brute-Ratel HTTP header patterns"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    re.regex($e.network.http.user_agent, `(?i)(Brute\s*Ratel|BRC4)`)

  condition:
    $e
}

rule ht_gs_104014_c2_havoc_c2_framework {
  meta:
    rule_id         = "GS-104014"
    author          = "HuntingThreats"
    description     = "Havoc C2 Demon agent process or port pattern detected"
