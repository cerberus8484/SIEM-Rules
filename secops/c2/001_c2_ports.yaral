    re.regex($e.target.process.command_line, `(?i)(wssh|websocket|ws://)`)

  condition:
    $e
}

rule ht_gs_104030_c2_github_raw_download {
  meta:
    rule_id         = "GS-104030"
    author          = "HuntingThreats"
    description     = "Script downloading from raw.githubusercontent.com — C2 payload from GitHub"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1102.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)raw\.githubusercontent\.com`)
    re.regex($e.target.process.file.full_path, `(?i)\\(powershell|cmd|curl|wscript|mshta)\.exe$`)

  condition:
