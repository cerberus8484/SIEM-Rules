    re.regex($e.target.process.command_line, `(?i)(havoc|demon\.exe|havocui)`)

  condition:
    $e
}

rule ht_gs_104015_c2_ngrok_tunnel {
  meta:
    rule_id         = "GS-104015"
    author          = "HuntingThreats"
    description     = "Ngrok or similar tunnel tool — exposing internal service to internet"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1572"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(ngrok|frp|chisel|ligolo)\.exe$`)

  condition:
    $e
}

rule ht_gs_104016_c2_ssh_tunnel_spawn {
  meta:
    rule_id         = "GS-104016"
    author          = "HuntingThreats"
    description     = "SSH with -R or -L tunnel flags — reverse or local port forwarding for C2"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1572"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\ssh\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\s-R\s|\s-L\s|-D\s)`)

  condition:
    $e
}

rule ht_gs_104017_c2_plink_tunnel {
  meta:
    rule_id         = "GS-104017"
    author          = "HuntingThreats"
    description     = "Plink.exe with -R or -L — PuTTY link tunnel for C2 pivoting"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1572"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\plink\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(-R|-L|-N)`)

  condition:
    $e
}

rule ht_gs_104018_c2_cloudflare_bypass_domain {
  meta:
    rule_id         = "GS-104018"
    author          = "HuntingThreats"
    description     = "Connection via known C2-hosting Cloudflare workers domain pattern"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1102"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)(\.workers\.dev|\.pages\.dev|\.trycloudflare\.com)`)

  condition:
    $e
}

rule ht_gs_104019_c2_discord_webhook_abuse {
  meta:
    rule_id         = "GS-104019"
    author          = "HuntingThreats"
    description     = "Non-browser process connecting to Discord webhook — Discord C2 channel"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1102"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)discord(app)?\.com`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|cmd|wscript|rundll32|mshta)\.exe$`)

  condition:
    $e
}

rule ht_gs_104020_c2_telegram_bot_api {
  meta:
    rule_id         = "GS-104020"
