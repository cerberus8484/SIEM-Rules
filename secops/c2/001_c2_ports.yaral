    re.regex($e.network.dns.questions.name, `(?i)api\.telegram\.org`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|python|cmd|wscript)\.exe$`)

  condition:
    $e
}

rule ht_gs_104021_c2_pastebin_retrieval {
  meta:
    rule_id         = "GS-104021"
    author          = "HuntingThreats"
    description     = "Process downloading from pastebin.com or similar paste site — C2 payload retrieval"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1102.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)(pastebin\.com|paste\.ee|hastebin\.com|ghostbin\.co)`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|cmd|wscript|cscript|mshta)\.exe$`)

  condition:
    $e
}

rule ht_gs_104022_c2_icmp_tunneling {
  meta:
    rule_id         = "GS-104022"
    author          = "HuntingThreats"
    description     = "ICMP tunneling tool — ptunnel or icmptunnel process detected"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1095"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(ptunnel|icmptunnel|icmp-tunnel|ping-tunnel)`)

  condition:
    $e
}

rule ht_gs_104023_c2_rdp_over_non_standard_port {
  meta:
    rule_id         = "GS-104023"
    author          = "HuntingThreats"
    description     = "RDP connection on non-standard port (not 3389) — RDP port change for evasion"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1571"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.network.application_protocol = "RDP"
    NOT $e.target.port = 3389

  condition:
    $e
}

rule ht_gs_104024_c2_lolbin_outbound_curl {
  meta:
    rule_id         = "GS-104024"
    author          = "HuntingThreats"
    description     = "Curl.exe outbound POST to non-corporate domain — payload upload or C2 check-in"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1071.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\curl\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(-X\s+POST|-d\s+|-F\s+)`)
    NOT $e.target.process.command_line = /localhost|127\.0\.0\.1|10\.|192\.168\./

  condition:
    $e
}

rule ht_gs_104025_c2_certutil_download {
  meta:
    rule_id         = "GS-104025"
    author          = "HuntingThreats"
    description     = "Certutil -urlcache downloading from internet — C2 stage download"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1105"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\certutil\.exe$`)
    re.regex($e.target.process.command_line, `(?i)-urlcache`)
    re.regex($e.target.process.command_line, `(?i)http`)

  condition:
    $e
}

rule ht_gs_104026_c2_bitsadmin_callback {
  meta:
    rule_id         = "GS-104026"
    author          = "HuntingThreats"
    description     = "BITSAdmin job downloading from external URL — BITS C2 callback"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1197"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\bitsadmin\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(/transfer|/download)`)
    re.regex($e.target.process.command_line, `(?i)https?://`)
    NOT $e.target.process.command_line = /192\.168\.|10\.|172\.1[6-9]\.|172\.2[0-9]\.|172\.3[01]\./

  condition:
    $e
}

rule ht_gs_104027_c2_gh0st_rat_port {
  meta:
    rule_id         = "GS-104027"
    author          = "HuntingThreats"
    description     = "Outbound TCP to port 9090 or 1234 — Gh0st RAT or common RAT ports"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1095"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [9090, 1234, 1604]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_104028_c2_teamviewer_anydesk_unusual {
  meta:
    rule_id         = "GS-104028"
    author          = "HuntingThreats"
    description     = "Remote access tool (TeamViewer/AnyDesk) spawned by Office or scripting host — malicious install"
    mitre_tactic    = "Command and Control"
    mitre_technique = "T1219"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(teamviewer|anydesk|screenconnect|zoho_assist|logmein|ultraviewer)`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(winword|excel|powerpnt|cmd|powershell|wscript)\.exe$`)

  condition:
    $e
}

rule ht_gs_104029_c2_websocket_tool {
  meta:
    rule_id         = "GS-104029"
