rule ht_gs_100024_powershell_webrequest_post {
  meta:
    rule_id         = "GS-100024"
    author          = "HuntingThreats"
    description     = "PowerShell: Invoke-WebRequest POST with -Body or -InFile — data upload"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1041"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(invoke-webrequest|invoke-restmethod)`)
    re.regex($e.target.process.command_line, `(?i)-method\s+post`)
    re.regex($e.target.process.command_line, `(?i)(-body|-infile)`)

  condition:
    $e
}

rule ht_gs_100025_powershell_scriptblock_logging_disabled {
  meta:
    rule_id         = "GS-100025"
    author          = "HuntingThreats"
    description     = "PowerShell: ScriptBlock logging disabled via registry — evasion"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\ScriptBlockLogging`)
    $e.target.registry.registry_value_data = "0"

  condition:
    $e
}
