// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Execution — PowerShell (T1059.001)
// Batch    : 01 / Execution
// Rules    : GS-100001 – GS-100025
// Platform : Google SecOps / Chronicle SIEM
// UDM      : PROCESS_LAUNCH, metadata.product_name = "Microsoft-Windows-Sysmon"
// ============================================================

rule ht_gs_100001_powershell_encoded_command {
  meta:
    rule_id         = "GS-100001"
    author          = "HuntingThreats"
    description     = "PowerShell: -EncodedCommand flag — obfuscated script execution"
    mitre_tactic    = "Execution"
    mitre_technique = "T1059.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)-enc(odedcommand)?\s`) nocase

  condition:
    $e
}

rule ht_gs_100002_powershell_hidden_window {
  meta:
    rule_id         = "GS-100002"
    author          = "HuntingThreats"
    description     = "PowerShell: -WindowStyle Hidden — execution without user visibility"
    mitre_tactic    = "Execution"
    mitre_technique = "T1059.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\powershell\.exe$`)
    re.regex($e.target.process.command_line, `(?i)-w(indowstyle)?\s+h(idden)?`)

  condition:
    $e
}

rule ht_gs_100003_powershell_iex_download {
