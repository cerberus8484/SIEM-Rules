rule ht_gs_100092_wmi_query_logsource_voluminous {
  meta:
    rule_id         = "GS-100092"
    author          = "HuntingThreats"
    description     = "High-frequency WMI process launches — threshold: 10+ in 5 minutes"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1047"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\wmic\.exe$`)

  match:
    $e.principal.hostname over 5m

  condition:
    #e > 10
}

