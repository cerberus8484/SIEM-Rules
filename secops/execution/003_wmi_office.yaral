    re.regex($e.target.process.command_line, `(?i)(\\temp\\|\\appdata\\|\\programdata\\)`)

  condition:
    $e
}

rule ht_gs_100096_wmi_start_service {
  meta:
    rule_id         = "GS-100096"
    author          = "HuntingThreats"
    description     = "WMIC starting suspicious service — service abuse for execution"
    mitre_tactic    = "Execution"
    mitre_technique = "T1543.003"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\wmic\.exe$`)
    re.regex($e.target.process.command_line, `(?i)service.*call\s+startservice`)

  condition:
    $e
}

