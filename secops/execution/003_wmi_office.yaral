// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Execution — WMI Abuse / Office Macros (T1047, T1566, T1204)
// Batch    : 03 / Execution
// Rules    : GS-100061 – GS-100100
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_100061_wmi_process_creation_event {
  meta:
    rule_id         = "GS-100061"
    author          = "HuntingThreats"
    description     = "WMI Win32_Process.Create — process spawned via WMI subscription"
    mitre_tactic    = "Execution"
    mitre_technique = "T1047"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.principal.process.file.full_path, `(?i)\\wmiprvse\.exe$`)
    re.regex($e.target.process.file.full_path, `(?i)\\(cmd|powershell|wscript|cscript|mshta|rundll32|regsvr32)\.exe$`)

  condition:
    $e
}

rule ht_gs_100062_wmi_event_subscription_create {
  meta:
    rule_id         = "GS-100062"
    author          = "HuntingThreats"
    description     = "WMI EventFilter + CommandLineEventConsumer — WMI persistence subscription"
    mitre_tactic    = "Persistence"
    mitre_technique = "T1546.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(EventFilter|EventConsumer|FilterToConsumerBinding)`)
    re.regex($e.target.process.command_line, `(?i)(CommandLineEventConsumer|ActiveScriptEventConsumer)`)

  condition:
    $e
}

rule ht_gs_100063_wmi_lateral_movement_node {
  meta:
    rule_id         = "GS-100063"
    author          = "HuntingThreats"
    description     = "WMIC with /node: and remote command — WMI lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.006"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\wmic\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/node:`)
    re.regex($e.target.process.command_line, `(?i)process\s+call\s+create`)

  condition:
    $e
}

