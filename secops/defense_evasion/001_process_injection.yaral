    re.regex($e.target.process.file.full_path, `(?i)\\csc\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\\temp\\|\\appdata\\|\\programdata\\)`)

  condition:
    $e
}

rule ht_gs_102025_wdac_bypass_pattern {
  meta:
    rule_id         = "GS-102025"
    author          = "HuntingThreats"
    description     = "WDAC / Device Guard bypass attempt — nircmd or PsExec via rundll32"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1553.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(wdac.*bypass|ci\.dll.*Uninstall|device.guard.*bypass)`)

  condition:
    $e
}

rule ht_gs_102026_sandbox_detection_vm_query {
  meta:
    rule_id         = "GS-102026"
    author          = "HuntingThreats"
    description     = "Malware sandbox/VM detection — CPUID VBOX/VMware registry check"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1497.001"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(vbox|vmware|virtual|sandbox|cuckoosandbox|sandboxie)`)
    re.regex($e.target.process.command_line, `(?i)(wmi|registry|env|get-item)`)

  condition:
    $e
}

rule ht_gs_102027_dll_hijack_search_order {
  meta:
    rule_id         = "GS-102027"
    author          = "HuntingThreats"
    description     = "DLL placed in same directory as privileged executable — search order hijacking"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1574.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\(Program Files|System32)\\.*\.dll$`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(msiexec|setup|install|trustedinstaller|tiworker)`)

  condition:
    $e
}

rule ht_gs_102028_process_doppelganging_ntfs {
  meta:
    rule_id         = "GS-102028"
    author          = "HuntingThreats"
    description     = "Process using NTFS transactions to write payload — Transactional NTFS abuse"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.013"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(createtransaction|committransaction|rollbacktransaction)`)

  condition:
    $e
}

rule ht_gs_102029_exclusion_path_add {
  meta:
    rule_id         = "GS-102029"
    author          = "HuntingThreats"
    description     = "Defender exclusion path added — Add-MpPreference -ExclusionPath for payload staging"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)add-mppreference`)
    re.regex($e.target.process.command_line, `(?i)-exclusionpath`)

  condition:
    $e
}

rule ht_gs_102030_unhook_api {
  meta:
    rule_id         = "GS-102030"
    author          = "HuntingThreats"
    description     = "EDR hook removal — Unhook or manual DLL reloading via WriteProcessMemory to ntdll"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(unhook|freshen.*ntdll|load.*fresh.*ntdll)`)

  condition:
    $e
}

rule ht_gs_102031_process_injection_shellcode_blob {
  meta:
    rule_id         = "GS-102031"
    author          = "HuntingThreats"
    description     = "Shellcode blob in PowerShell command — hex-encoded or byte-array shellcode"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\powershell\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\[byte\[\]\]|\[Byte\[\]\]|0x[0-9a-fA-F]{2},0x[0-9a-fA-F]{2},0x[0-9a-fA-F]{2})`)

  condition:
    $e
}

rule ht_gs_102032_indicator_removal_prefetch {
  meta:
    rule_id         = "GS-102032"
    author          = "HuntingThreats"
    description     = "Prefetch files deleted via cmd — anti-forensics indicator removal"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1070.004"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(del|erase|remove-item).*\\prefetch\\`)

  condition:
    $e
}

rule ht_gs_102033_wevtutil_export_delete {
  meta:
    rule_id         = "GS-102033"
    author          = "HuntingThreats"
    description     = "Wevtutil exporting then clearing security log — log export + cover tracks"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1070.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e1.target.process.command_line, `(?i)wevtutil.*epl`)

    $e2.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e2.target.process.command_line, `(?i)wevtutil.*cl`)

    $e1.principal.hostname = $e2.principal.hostname

  match:
    $e1.principal.hostname over 10m

  condition:
    $e1 and $e2
}

rule ht_gs_102034_deobfuscate_decode_chain {
  meta:
    rule_id         = "GS-102034"
    author          = "HuntingThreats"
    description     = "Multi-layer decode chain — certutil + base64 + iex in one command"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1140"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(certutil.*-decode|frombase64string)`)
    re.regex($e.target.process.command_line, `(?i)(iex|invoke-expression|&\(|\.invoke\()`)

  condition:
    $e
}

rule ht_gs_102035_userland_rootkit_driver {
  meta:
    rule_id         = "GS-102035"
    author          = "HuntingThreats"
    description     = "Known vulnerable driver loaded for BYOVD — gdrv/rtcore64/dbutil abuse"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1068"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "SERVICE_CREATION"
    re.regex($e.target.resource.name, `(?i)(gdrv|rtcore64|dbutil_2_3|cpuz|mhyprot|iqvw64e|ntiolib)`)

  condition:
    $e
}
