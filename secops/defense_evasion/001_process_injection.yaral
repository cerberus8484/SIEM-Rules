}

rule ht_gs_102006_masquerade_svchost {
  meta:
    rule_id         = "GS-102006"
    author          = "HuntingThreats"
    description     = "Process named svchost.exe running from non-system path — masquerading"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1036.005"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)svchost\.exe$`)
    NOT re.regex($e.target.process.file.full_path, `(?i)\\Windows\\System32\\svchost\.exe$`)

  condition:
    $e
}

rule ht_gs_102007_masquerade_lsass {
  meta:
    rule_id         = "GS-102007"
    author          = "HuntingThreats"
    description     = "Process named lsass.exe running from non-system path — masquerade as LSASS"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1036.005"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)lsass\.exe$`)
    NOT re.regex($e.target.process.file.full_path, `(?i)\\Windows\\System32\\lsass\.exe$`)

  condition:
    $e
}

rule ht_gs_102008_masquerade_explorer {
  meta:
    rule_id         = "GS-102008"
    author          = "HuntingThreats"
    description     = "Explorer.exe running from non-standard path — masquerade as Windows shell"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1036.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)explorer\.exe$`)
    NOT re.regex($e.target.process.file.full_path, `(?i)\\Windows\\explorer\.exe$`)

  condition:
    $e
}

rule ht_gs_102009_amsi_bypass_registry {
  meta:
    rule_id         = "GS-102009"
    author          = "HuntingThreats"
    description     = "AMSI disabled via registry — AmsiEnable set to 0"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Software\\Microsoft\\Windows Script\\Settings\\AmsiEnable`)
    $e.target.registry.registry_value_data = "0"

  condition:
    $e
}

rule ht_gs_102010_amsi_patch_memory {
  meta:
    rule_id         = "GS-102010"
    author          = "HuntingThreats"
    description     = "AMSI.dll patch in memory via PS — AmsiScanBuffer patch pattern"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(amsi\.dll|amsiscanbuffer|amsiutils.*scan)`)
    re.regex($e.target.process.command_line, `(?i)(0xb8|0x57|virtualpro|getprocaddress)`)

  condition:
    $e
}

rule ht_gs_102011_timestomp_touch_file {
  meta:
    rule_id         = "GS-102011"
    author          = "HuntingThreats"
    description     = "File timestamp modified via PowerShell or touch-like operation — timestomping"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1070.006"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(\.lastwritetime|\.creationtime|\.lastaccesstime|set-itemproperty.*lastwrite)`)

  condition:
    $e
}

rule ht_gs_102012_disable_defender_ps {
  meta:
    rule_id         = "GS-102012"
    author          = "HuntingThreats"
    description     = "Set-MpPreference disabling Defender real-time monitoring via PowerShell"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)set-mppreference`)
    re.regex($e.target.process.command_line, `(?i)(-disablerealtimemonitoring\s+\$true|-disablebehaviormonitoring\s+\$true)`)

  condition:
    $e
}

rule ht_gs_102013_process_injection_syscall_ps {
  meta:
    rule_id         = "GS-102013"
    author          = "HuntingThreats"
    description     = "PowerShell using direct syscall for injection — NtOpenProcess/NtAllocate via PS"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(ntopenprocess|ntallocatevirtualmemory|ntwritevirtualmemory|ntcreatethread)`)
    re.regex($e.target.process.file.full_path, `(?i)\\powershell\.exe$`)

  condition:
    $e
}

rule ht_gs_102014_dll_sideloading_known_vuln {
  meta:
    rule_id         = "GS-102014"
    author          = "HuntingThreats"
    description     = "DLL dropped next to known vulnerable signed binary — DLL sideloading setup"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1574.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\(WINWORD|EXCEL|chrome|teams|slack|onedrive)\\.*\.dll$`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(msiexec|setup|install|update).*\.exe$`)

  condition:
    $e
}

rule ht_gs_102015_etw_provider_disable {
  meta:
    rule_id         = "GS-102015"
    author          = "HuntingThreats"
    description     = "ETW provider disabled via logman or wevtutil — log evasion"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.006"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(logman|wevtutil)\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(stop|disable|delete|cl|clear-log)`)

  condition:
    $e
}

rule ht_gs_102016_sysmon_tampering {
  meta:
    rule_id         = "GS-102016"
    author          = "HuntingThreats"
    description     = "Sysmon driver or service tampered or stopped — EDR blind spot creation"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1562.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(sysmon.*-u|sc\s+stop.*sysmon|sc\s+delete.*sysmon)`)

  condition:
    $e
}

rule ht_gs_102017_alternate_data_stream {
  meta:
    rule_id         = "GS-102017"
    author          = "HuntingThreats"
    description     = "File written to NTFS Alternate Data Stream — payload hidden in ADS"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1564.004"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\:\w+$`)

  condition:
    $e
}

rule ht_gs_102018_hidden_file_attribute {
  meta:
    rule_id         = "GS-102018"
    author          = "HuntingThreats"
    description     = "Attrib.exe setting hidden + system attributes on executable — file hiding"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1564.001"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\attrib\.exe$`)
    re.regex($e.target.process.command_line, `(?i)\+h.*\+s`)

  condition:
    $e
}

rule ht_gs_102019_event_log_clear {
  meta:
    rule_id         = "GS-102019"
    author          = "HuntingThreats"
    description     = "Windows event log cleared — wevtutil cl or Clear-EventLog (EID 1102/104)"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1070.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(wevtutil\s+cl|clear-eventlog|wevtutil.*cl\s+(security|system|application))`)

  condition:
    $e
}

rule ht_gs_102020_signed_binary_proxy {
  meta:
    rule_id         = "GS-102020"
    author          = "HuntingThreats"
    description     = "Microsoft-signed binary executing untrusted DLL — proxy execution via signed tool"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1218"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.principal.process.file.full_path, `(?i)\\(wusa|pcalua|eudcedit|xwizard|syncappvpublishingserver)\.exe$`)

  condition:
    $e
}

rule ht_gs_102021_parent_pid_spoofing {
  meta:
    rule_id         = "GS-102021"
    author          = "HuntingThreats"
    description     = "Explorer spawning suspicious process with mismatched grandparent — PPID spoofing"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1134.004"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.principal.process.file.full_path, `(?i)\\explorer\.exe$`)
    re.regex($e.target.process.file.full_path, `(?i)\\(powershell|cmd|wscript|mshta|rundll32)\.exe$`)
    NOT re.regex($e.target.process.command_line, `(?i)(\\Users\\|Desktop|Documents|Downloads)`)

  condition:
    $e
}

rule ht_gs_102022_binary_padding {
  meta:
    rule_id         = "GS-102022"
    author          = "HuntingThreats"
    description     = "Very large executable in Temp path — binary padding to evade size-based hashing"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1027.001"
    severity        = "MEDIUM"
    confidence      = "LOW"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)(\\temp\\|\\appdata\\|\\programdata\\).*\.exe$`)
    $e.target.file.size > 50000000

  condition:
    $e
}

rule ht_gs_102023_regsvcs_regasm_bypass {
  meta:
    rule_id         = "GS-102023"
    author          = "HuntingThreats"
    description     = "RegSvcs or RegAsm executing non-system DLL — AppLocker bypass"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1218.009"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(regsvcs|regasm)\.exe$`)
    NOT re.regex($e.target.process.command_line, `(?i)\\(System32|SysWOW64|Program Files)\\`)

  condition:
    $e
}

rule ht_gs_102024_compile_csharp_csc {
  meta:
    rule_id         = "GS-102024"
    author          = "HuntingThreats"
    description     = "Csc.exe compiling C# from Temp path — on-the-fly payload compilation"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1027.004"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
