// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Defense Evasion — Process Injection / Hollowing / AMSI Bypass (T1055, T1562)
// Batch    : 09 / Defense Evasion
// Rules    : GS-102001 – GS-102035
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_102001_injection_virtualalloc_exec {
  meta:
    rule_id         = "GS-102001"
    author          = "HuntingThreats"
    description     = "VirtualAlloc + WriteProcessMemory + CreateRemoteThread — classic injection pattern"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(virtualalloc.*writeprocessmemory|createremotethread.*virtualalloc)`)

  condition:
    $e
}

rule ht_gs_102002_injection_process_hollow {
  meta:
    rule_id         = "GS-102002"
    author          = "HuntingThreats"
    description     = "Process hollowing — CreateProcessSuspended + UnmapViewOfSection + NtResumeThread"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.012"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(unmapviewofsection|ntunmapviewofsection|resumethread)`)

  condition:
    $e
}

rule ht_gs_102003_injection_atompombing {
  meta:
    rule_id         = "GS-102003"
    author          = "HuntingThreats"
    description     = "AtomBombing technique — GlobalAddAtom + NtQueueApcThread pattern"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.015"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(globaladdatom|ntqueueapcthread|globalgetatomname)`)

  condition:
    $e
}

rule ht_gs_102004_injection_doppelganging {
  meta:
    rule_id         = "GS-102004"
    author          = "HuntingThreats"
    description     = "Process Doppelgänging — TxF transaction + NtCreateSection pattern"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.013"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(ntcreatesection.*txf|ntcreateprocessex|zavtransact)`)

  condition:
    $e
}

rule ht_gs_102005_injection_reflective_dll {
  meta:
    rule_id         = "GS-102005"
    author          = "HuntingThreats"
    description     = "Reflective DLL loading — ReflectiveDllInject or ReflectiveLoader export"
    mitre_tactic    = "Defense Evasion"
    mitre_technique = "T1055.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(reflectivedllinject|reflectiveloader|invoke-reflectivepeinject)`)

  condition:
