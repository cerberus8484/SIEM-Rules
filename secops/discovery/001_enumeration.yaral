rule ht_gs_106034_msconfig_recon {
  meta:
    rule_id         = "GS-106034"
    author          = "HuntingThreats"
    description     = "Msconfig or BCDEdit used for system recon — boot config / startup discovery"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1082"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(msconfig|bcdedit)\.exe$`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(cmd|powershell|wscript|wmiprvse)\.exe$`)

  condition:
    $e
}

rule ht_gs_106035_discovery_command_burst {
  meta:
    rule_id         = "GS-106035"
    author          = "HuntingThreats"
    description     = "Burst of discovery commands — 10+ recon tools in 2 minutes — post-compromise survey"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1082"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(net|netstat|ipconfig|systeminfo|whoami|tasklist|wmic|nltest|dsquery|ping)\.exe$`)

  match:
    $e.principal.hostname over 2m

  condition:
    #e > 10
}
