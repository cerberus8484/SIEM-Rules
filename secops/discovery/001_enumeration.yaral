// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Discovery — Enumeration / Recon / AD Discovery (T1087, T1069, T1018, T1082)
// Batch    : 11 / Discovery
// Rules    : GS-106001 – GS-106035
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_106001_net_user_domain {
  meta:
    rule_id         = "GS-106001"
    author          = "HuntingThreats"
    description     = "Net user /domain — domain user enumeration via net command"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1087.002"
    severity        = "MEDIUM"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\net\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(user|group|localgroup)`)
    re.regex($e.target.process.command_line, `(?i)\/domain`)

  condition:
    $e
}

rule ht_gs_106002_net_group_domain_admins {
  meta:
    rule_id         = "GS-106002"
    author          = "HuntingThreats"
    description     = "Net group 'Domain Admins' query — privileged group enumeration"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1069.002"
    severity        = "MEDIUM"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\net\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(domain admins|enterprise admins|schema admins|domain controllers)`)

  condition:
    $e
}

