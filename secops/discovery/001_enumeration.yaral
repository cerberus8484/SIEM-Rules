rule ht_gs_106021_find_file_sensitive {
  meta:
    rule_id         = "GS-106021"
    author          = "HuntingThreats"
    description     = "Dir or Where searching for sensitive file types — credential file hunting"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1083"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(cmd|powershell)\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(dir.*\*\.pem|dir.*\*\.kdbx|dir.*password|gci.*\.config|get-childitem.*secret)`)

  condition:
    $e
}

rule ht_gs_106022_dns_zone_transfer {
  meta:
    rule_id         = "GS-106022"
    author          = "HuntingThreats"
    description     = "DNS zone transfer request — nslookup or dig with AXFR query type"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1590.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(ls\s+-d|type=axfr|axfr|ls\s+-t)`)
    re.regex($e.target.process.file.full_path, `(?i)\\(nslookup|dig)\.exe$`)

  condition:
    $e
}

rule ht_gs_106023_ldap_enumeration {
  meta:
    rule_id         = "GS-106023"
    author          = "HuntingThreats"
    description     = "LDAP queries to domain controller from non-DC workstation — AD LDAP recon"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1087.002"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [389, 636, 3268, 3269]
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(lsass|svchost|explorer|outlook)\.exe$`)

  condition:
    $e
}

rule ht_gs_106024_cloud_metadata_query {
  meta:
    rule_id         = "GS-106024"
    author          = "HuntingThreats"
    description     = "Cloud metadata endpoint queried from non-cloud tool — IMDS credential theft"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1526"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)(169\.254\.169\.254|metadata\.google\.internal|169\.254\.169\.254)`)

  condition:
    $e
}

rule ht_gs_106025_sandbox_vm_detect {
  meta:
    rule_id         = "GS-106025"
    author          = "HuntingThreats"
