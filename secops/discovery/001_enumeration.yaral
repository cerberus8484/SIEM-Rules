rule ht_gs_106031_browser_history_access {
  meta:
    rule_id         = "GS-106031"
    author          = "HuntingThreats"
    description     = "Browser history or profile accessed by non-browser process — credential / session theft"
    mitre_tactic    = "Collection"
    mitre_technique = "T1217"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\\(Chrome|Firefox|Edge)\\.*\\(History|Cookies|Web Data)`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(chrome|firefox|msedge|brave)\.exe$`)

  condition:
    $e
}

