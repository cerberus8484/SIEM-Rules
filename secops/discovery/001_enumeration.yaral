    re.regex($e.target.process.command_line, `(?i)(vboxguestadditions|vmwaretoolsd|vmtoolsd|virtualbox|virtualpc)`)

  condition:
    $e
}

rule ht_gs_106026_host_discovery_ping_sweep {
  meta:
    rule_id         = "GS-106026"
    author          = "HuntingThreats"
    description     = "Ping sweep — one host sending ICMP to 20+ distinct targets in 5 minutes"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1018"
