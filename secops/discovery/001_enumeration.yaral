rule ht_gs_106006_port_scan_threshold {
  meta:
    rule_id         = "GS-106006"
    author          = "HuntingThreats"
    description     = "One host connecting to 20+ distinct ports on target — port scan behavior"
    mitre_tactic    = "Discovery"
    mitre_technique = "T1046"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"

  match:
    $e.principal.hostname, $e.target.ip over 5m

  condition:
    #e > 20
}

