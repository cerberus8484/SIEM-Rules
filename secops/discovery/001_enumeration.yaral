rule ht_gs_106020_wmi_system_discovery {
  meta:
    rule_id         = "GS-106020"
    author          = "HuntingThreats"
    description     = "WMIC querying system info classes — multi-class WMI recon sweep"
    mitre_tactic    = "Discovery"
