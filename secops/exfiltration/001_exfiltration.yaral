// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Exfiltration — Data Theft / Upload / DNS Tunnel (T1048, T1041, T1071.004)
// Batch    : 12 / Exfiltration
// Rules    : GS-107001 – GS-107030
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_107001_bitsadmin_upload {
  meta:
    rule_id         = "GS-107001"
    author          = "HuntingThreats"
    description     = "BITSAdmin /upload — data exfiltration via BITS upload job"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\bitsadmin\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(/upload|/addfileset.*upload)`)
    NOT $e.target.process.command_line = /192\.168\.|10\.|127\./

  condition:
    $e
}

rule ht_gs_107002_rclone_sync_external {
  meta:
    rule_id         = "GS-107002"
    author          = "HuntingThreats"
    description     = "Rclone sync or copy to cloud remote — bulk cloud exfiltration"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1567.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\rclone\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(sync|copy|move|mount)`)

  condition:
    $e
}

rule ht_gs_107003_archive_password_protected {
  meta:
    rule_id         = "GS-107003"
    author          = "HuntingThreats"
    description     = "7-Zip or WinRAR creating password-protected archive from sensitive path"
    mitre_tactic    = "Collection"
    mitre_technique = "T1560.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(7z|7za|rar|winrar)\.exe$`)
    re.regex($e.target.process.command_line, `(?i)-p`)
    re.regex($e.target.process.command_line, `(?i)(\\documents\\|\\desktop\\|\\users\\)`)

  condition:
    $e
}

rule ht_gs_107004_dns_tunnel_long_subdomain {
  meta:
    rule_id         = "GS-107004"
    author          = "HuntingThreats"
    description     = "DNS query with excessively long subdomain — DNS tunnel data exfiltration"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `.{63,}\..+\..+`)

  condition:
    $e
}

rule ht_gs_107005_cloud_storage_cli_aws_s3 {
  meta:
    rule_id         = "GS-107005"
    author          = "HuntingThreats"
    description     = "AWS CLI s3 sync or cp to bucket — cloud storage exfiltration"
