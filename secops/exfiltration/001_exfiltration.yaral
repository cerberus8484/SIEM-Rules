  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(smbclient\.py|smbclient.*get\s+)`)

  condition:
    $e
}

rule ht_gs_107022_compress_sensitive_data {
