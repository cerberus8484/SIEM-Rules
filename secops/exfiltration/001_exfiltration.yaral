    mitre_technique = "T1567.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\aws\.exe$`)
    re.regex($e.target.process.command_line, `(?i)s3\s+(sync|cp|mv)`)

  condition:
    $e
}

rule ht_gs_107006_mega_cli_upload {
