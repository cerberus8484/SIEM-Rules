}

rule ht_gs_107015_browser_credential_copy {
  meta:
    rule_id         = "GS-107015"
    author          = "HuntingThreats"
    description     = "Chrome Login Data copied to Temp — browser credential staging for exfil"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1020"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(copy|xcopy|robocopy).*Login Data.*(\\temp\\|\\appdata\\)`)

  condition:
    $e
}

rule ht_gs_107016_slack_file_upload_api {
  meta:
    rule_id         = "GS-107016"
    author          = "HuntingThreats"
    description     = "Script calling Slack files.upload API — data exfiltration via Slack"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1567"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)(slack\.com|hooks\.slack\.com)`)
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|python|cmd|wscript|curl)`)

  condition:
    $e
}

rule ht_gs_107017_large_file_to_external {
  meta:
    rule_id         = "GS-107017"
    author          = "HuntingThreats"
    description     = "Large outbound data transfer (>100MB equivalent session) to external IP"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1041"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.network.sent_bytes > 100000000
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_107018_github_repo_push {
  meta:
    rule_id         = "GS-107018"
    author          = "HuntingThreats"
    description     = "Git push to external GitHub from server or non-dev workstation — source code exfil"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1567.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\git\.exe$`)
    re.regex($e.target.process.command_line, `(?i)push.*github\.com`)

  condition:
    $e
}

rule ht_gs_107019_usb_data_copy {
  meta:
    rule_id         = "GS-107019"
    author          = "HuntingThreats"
    description     = "Large file copy to removable media — physical exfiltration via USB"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1052.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(xcopy|robocopy|copy).*[EF-Z]:\\`)
    re.regex($e.target.process.command_line, `(?i)(documents|desktop|users|programdata)`)

  condition:
    $e
}

rule ht_gs_107020_auto_exfil_threshold {
  meta:
    rule_id         = "GS-107020"
    author          = "HuntingThreats"
    description     = "5+ file uploads to same external IP within 10 minutes — automated exfiltration"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1029"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.network.sent_bytes > 1000000
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  match:
    $e.principal.hostname, $e.target.ip over 10m

  condition:
    #e > 5
}

rule ht_gs_107021_impacket_smbclient_get {
  meta:
    rule_id         = "GS-107021"
    author          = "HuntingThreats"
    description     = "Impacket smbclient get command — file retrieval via SMB for exfil"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048"
