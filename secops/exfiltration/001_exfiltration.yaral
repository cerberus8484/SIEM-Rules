rule ht_gs_107011_ftp_upload_external {
  meta:
    rule_id         = "GS-107011"
    author          = "HuntingThreats"
    description     = "FTP client uploading to external server — legacy FTP exfiltration"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048.003"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [21, 990]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    NOT $e.target.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_107012_email_attachment_bulk {
  meta:
    rule_id         = "GS-107012"
    author          = "HuntingThreats"
    description     = "SMTP connection with large attachment from workstation — email exfiltration"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [25, 587, 465]
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"
    re.regex($e.principal.process.file.full_path, `(?i)\\(powershell|cmd|python|wscript)`)

  condition:
    $e
}

rule ht_gs_107013_winscp_sftp_upload {
  meta:
    rule_id         = "GS-107013"
