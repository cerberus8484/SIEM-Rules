rule ht_gs_107026_copy_ntds_staging {
  meta:
    rule_id         = "GS-107026"
    author          = "HuntingThreats"
    description     = "NTDS.dit or SAM hive file copied to temp staging area — pre-exfil"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1020"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(copy|xcopy|robocopy).*(ntds\.dit|SAM|SECURITY|SYSTEM)`)
    re.regex($e.target.process.command_line, `(?i)(\\temp\\|\\appdata\\|\\programdata\\)`)

  condition:
    $e
}

rule ht_gs_107027_onion_site_access {
  meta:
    rule_id         = "GS-107027"
    author          = "HuntingThreats"
    description     = "DNS query for .onion domain — Tor hidden service access attempt"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1048"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_DNS"
    re.regex($e.network.dns.questions.name, `(?i)\.onion$`)

  condition:
    $e
}

rule ht_gs_107028_data_staged_archive_temp {
  meta:
    rule_id         = "GS-107028"
    author          = "HuntingThreats"
    description     = "Multiple archive files created in Temp within short time — data staging"
    mitre_tactic    = "Collection"
    mitre_technique = "T1074.001"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)(\\temp\\|\\appdata\\local\\temp\\).*\.(zip|7z|rar|tar\.gz)$`)

  match:
    $e.principal.hostname over 10m

  condition:
    #e > 5
}

rule ht_gs_107029_oauth_token_steal {
  meta:
    rule_id         = "GS-107029"
    author          = "HuntingThreats"
    description     = "OAuth token file or browser token database accessed by unusual process"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1528"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)(access_token|refresh_token|oauth_token|\.tokens)`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(chrome|firefox|edge|outlook|teams)\.exe$`)

  condition:
    $e
}

rule ht_gs_107030_http_post_large_body {
  meta:
    rule_id         = "GS-107030"
    author          = "HuntingThreats"
    description     = "HTTP POST with large body from script process — HTTP exfiltration channel"
    mitre_tactic    = "Exfiltration"
    mitre_technique = "T1041"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.network.http.method = "POST"
    $e.network.sent_bytes > 10000000
    NOT $e.target.ip in cidr "10.0.0.0/8"
    NOT $e.target.ip in cidr "192.168.0.0/16"

  condition:
    $e
}
