}

rule ht_gs_108023_data_destruction_rm_rf {
  meta:
    rule_id         = "GS-108023"
    author          = "HuntingThreats"
    description     = "PowerShell Remove-Item -Recurse on data directory — mass deletion"
    mitre_tactic    = "Impact"
    mitre_technique = "T1485"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)remove-item.*-recurse`)
    re.regex($e.target.process.command_line, `(?i)(\\documents|\\desktop|\\users|\\data|\\shares)`)

  condition:
    $e
}

rule ht_gs_108024_service_stop_list_ransomware {
  meta:
    rule_id         = "GS-108024"
    author          = "HuntingThreats"
    description     = "Known ransomware service stop list executed — batch service kill script"
    mitre_tactic    = "Impact"
    mitre_technique = "T1489"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\(sc|net)\.exe$`)
    re.regex($e.target.process.command_line, `(?i)stop.*(sql|oracle|mysql|postgres|mongodb|exchange|iis|apache|nginx|tomcat|backupexec|veeam|acronis)`)

  condition:
    $e
}

rule ht_gs_108025_arp_spoofing_tool {
  meta:
    rule_id         = "GS-108025"
    author          = "HuntingThreats"
    description     = "ARP spoofing tool launched — network disruption / MITM for impact"
    mitre_tactic    = "Impact"
    mitre_technique = "T1498"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(arpspoof|ettercap|cain|arp.*-s.*poison)`)

  condition:
    $e
}

rule ht_gs_108026_registry_destruction {
  meta:
    rule_id         = "GS-108026"
    author          = "HuntingThreats"
    description     = "Reg.exe deleting critical registry hives — registry destruction/wiper"
    mitre_tactic    = "Impact"
    mitre_technique = "T1485"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\reg\.exe$`)
    re.regex($e.target.process.command_line, `(?i)delete.*hklm\\(sam|security|system|software)`)

  condition:
    $e
}

rule ht_gs_108027_dns_flood_attack {
  meta:
    rule_id         = "GS-108027"
    author          = "HuntingThreats"
    description     = "High-frequency DNS queries from one host — DNS flood / DDoS tool"
    mitre_tactic    = "Impact"
    mitre_technique = "T1498.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "NETWORK_DNS"

  match:
    $e.principal.hostname over 1m

  condition:
    #e > 1000
}

rule ht_gs_108028_wiper_malware_patterns {
  meta:
    rule_id         = "GS-108028"
    author          = "HuntingThreats"
    description     = "Known wiper tool or binary pattern — NotPetya/Hermetic/Destover style"
    mitre_tactic    = "Impact"
    mitre_technique = "T1561"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(hermeticwiper|notpetya|destover|shamoon|stonedrill|wipeall)`)

  condition:
    $e
}

rule ht_gs_108029_inhibit_recovery_reagentc {
  meta:
    rule_id         = "GS-108029"
    author          = "HuntingThreats"
    description     = "Reagentc /disable — Windows Recovery Environment disabled"
    mitre_tactic    = "Impact"
    mitre_technique = "T1490"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\reagentc\.exe$`)
    re.regex($e.target.process.command_line, `(?i)\/disable`)

  condition:
    $e
}

rule ht_gs_108030_encrypted_file_read_high_volume {
  meta:
    rule_id         = "GS-108030"
    author          = "HuntingThreats"
    description     = "Process reading then writing large number of files — encryption in progress"
    mitre_tactic    = "Impact"
    mitre_technique = "T1486"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(windows|microsoft|system32|program files)`)
    re.regex($e.target.file.full_path, `(?i)\\(Documents|Desktop|Downloads|Pictures|Users)\\`)

  match:
    $e.principal.process.file.full_path over 5m

  condition:
    #e > 200
}
