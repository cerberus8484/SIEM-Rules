  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(sharphound|invoke-bloodhound|-collectionmethod\s+(all|session|localadmin))`)

  condition:
    $e
}

