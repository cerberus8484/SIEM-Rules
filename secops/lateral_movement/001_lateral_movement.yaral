  condition:
    $e
}

rule ht_gs_105024_win_rm_remote_exec {
  meta:
    rule_id         = "GS-105024"
    author          = "HuntingThreats"
    description     = "WinRM WS-Management remote execution detected — PS remoting over 5985/5986"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.006"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port in [5985, 5986]
    NOT $e.target.ip in cidr "127.0.0.0/8"

  condition:
    $e
}

rule ht_gs_105025_lateral_via_scheduled_task {
