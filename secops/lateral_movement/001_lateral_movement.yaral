    description     = "GPO modified — groupPolicyContainer attribute changed (EID 5136)"
    mitre_tactic    = "Privilege Escalation"
    mitre_technique = "T1484.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(groupPolicyContainer|gpLink|gpcFileSysPath|Set-GPO|New-GPLink)`)

  condition:
