    re.regex($e.target.process.command_line, `(?i)(new-pssession|enter-pssession)`)
    re.regex($e.target.process.command_line, `(?i)(-computername|-cn|-hostname)`)

  condition:
    $e
}

rule ht_gs_105035_enable_rdp_via_registry {
  meta:
    rule_id         = "GS-105035"
    author          = "HuntingThreats"
    description     = "RDP enabled via registry modification — fDenyTSConnections set to 0"
    mitre_tactic    = "Lateral Movement"
