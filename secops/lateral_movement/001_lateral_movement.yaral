rule ht_gs_105016_dcom_lateral_movement {
  meta:
    rule_id         = "GS-105016"
    author          = "HuntingThreats"
    description     = "DCOM lateral movement — MMC20.Application or Excel.Application Execute"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(MMC20\.Application|ShellWindows|ShellBrowserWindow|Excel\.Application.*run)`)

  condition:
