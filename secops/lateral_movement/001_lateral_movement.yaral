    $e
}

rule ht_gs_105037_internal_port_scan_smb {
  meta:
    rule_id         = "GS-105037"
    author          = "HuntingThreats"
    description     = "One host connecting to 10+ internal SMB targets — lateral movement scanner"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.port = 445
    $e.target.ip in cidr "10.0.0.0/8"

  match:
    $e.principal.hostname over 10m

  condition:
    #e > 10
}

rule ht_gs_105038_lsass_lateral_dump_copy {
  meta:
    rule_id         = "GS-105038"
    author          = "HuntingThreats"
    description     = "LSASS dump copied to admin share — credential dump staging for lateral use"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(copy|xcopy|robocopy).*lsass.*\\\\`)

  condition:
    $e
}

rule ht_gs_105039_kerberoasting_then_lateral {
  meta:
    rule_id         = "GS-105039"
    author          = "HuntingThreats"
    description     = "Kerberoasting followed by logon to target service host — attack chain"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1558.003"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e1.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e1.target.process.command_line, `(?i)(kerberoast|getuserspns|invoke-kerberoast)`)

    $e2.metadata.event_type = "USER_LOGIN"
    re.regex($e2.metadata.product_log_id, `(?i)4624`)
    NOT $e2.target.hostname = $e2.principal.hostname

    $e1.principal.hostname = $e2.principal.hostname

  match:
    $e1.principal.hostname over 60m

  condition:
    $e1 and $e2
}

rule ht_gs_105040_atexec_lateral_movement {
  meta:
    rule_id         = "GS-105040"
    author          = "HuntingThreats"
    description     = "Atexec.py or remote AT job — task-based lateral movement via Impacket"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1053.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(atexec|at\.exe\s+\\\\)`)

  condition:
    $e
}
