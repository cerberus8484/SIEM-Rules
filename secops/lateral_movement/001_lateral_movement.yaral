// ============================================================
// HuntingThreats — Google SecOps YARA-L 2.0 Hunt Rules
// Category : Lateral Movement — RDP / SMB / WMI / Pass-the-X (T1021, T1047, T1570, T1550)
// Batch    : 10 / Lateral Movement
// Rules    : GS-105001 – GS-105040
// Platform : Google SecOps / Chronicle SIEM
// ============================================================

rule ht_gs_105001_rdp_logon_from_unusual_source {
  meta:
    rule_id         = "GS-105001"
    author          = "HuntingThreats"
    description     = "RDP logon (Type 10) from external or unusual source IP"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    $e.extensions.auth.auth_details = "INTERACTIVE"
    re.regex($e.metadata.product_log_id, `(?i)4624`)
    NOT $e.principal.ip in cidr "10.0.0.0/8"
    NOT $e.principal.ip in cidr "192.168.0.0/16"
    NOT $e.principal.ip in cidr "172.16.0.0/12"

  condition:
    $e
}

rule ht_gs_105002_rdp_new_user_logon {
  meta:
    rule_id         = "GS-105002"
    author          = "HuntingThreats"
    description     = "RDP logon with unusual username — new account RDP access"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.001"
    severity        = "MEDIUM"
    confidence      = "MEDIUM"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.target.user.userid, `(?i)(admin|administrator|guest|support|service|backup|temp)`)
    $e.network.application_protocol = "RDP"

  condition:
    $e
}

rule ht_gs_105003_admin_share_access {
  meta:
    rule_id         = "GS-105003"
    author          = "HuntingThreats"
    description     = "Admin share access (C$ ADMIN$ IPC$) from remote host — lateral movement via SMB"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.target.resource.name, `(?i)(C\$|ADMIN\$|IPC\$)`)

  condition:
    $e
}

rule ht_gs_105004_psexec_service_install {
  meta:
    rule_id         = "GS-105004"
    author          = "HuntingThreats"
    description     = "PsExec PSEXESVC service installed — PsExec lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1570"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "SERVICE_CREATION"
    re.regex($e.target.resource.name, `(?i)(PSEXESVC|psexec)`)

  condition:
    $e
}

rule ht_gs_105005_wmi_lateral_node {
  meta:
    rule_id         = "GS-105005"
    author          = "HuntingThreats"
    description     = "WMIC /node: remote process creation — WMI-based lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.006"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\wmic\.exe$`)
    re.regex($e.target.process.command_line, `(?i)/node:`)
    re.regex($e.target.process.command_line, `(?i)process\s+call\s+create`)

  condition:
    $e
}

rule ht_gs_105006_ps_invoke_command_remote {
  meta:
    rule_id         = "GS-105006"
    author          = "HuntingThreats"
    description     = "PowerShell Invoke-Command with -ComputerName — PS remoting lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.006"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)invoke-command`)
    re.regex($e.target.process.command_line, `(?i)(-computername|-cn\s)`)

  condition:
    $e
}

rule ht_gs_105007_pass_the_hash_ntlm {
  meta:
    rule_id         = "GS-105007"
    author          = "HuntingThreats"
    description     = "Pass-the-Hash NTLM logon with no interactive session — hash reuse detected"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1550.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.metadata.product_log_id, `(?i)4624`)
    re.regex($e.extensions.auth.auth_details, `(?i)(NtLmSsp|NTLM)`)
    NOT $e.target.hostname = $e.principal.hostname

  condition:
    $e
}

rule ht_gs_105008_pass_the_ticket_rubeus {
  meta:
    rule_id         = "GS-105008"
    author          = "HuntingThreats"
    description     = "Rubeus ticket injection — ptt or createnetonly — Pass-the-Ticket"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1550.003"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(rubeus.*ptt|rubeus.*createnetonly|mimikatz.*kerberos::ptt)`)

  condition:
    $e
}

rule ht_gs_105009_rdp_hijack_tscon {
  meta:
    rule_id         = "GS-105009"
    author          = "HuntingThreats"
    description     = "Tscon.exe used for RDP session hijacking — reconnect to another user's session"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\tscon\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\/dest|console|\d+\s+\/dest)`)

  condition:
    $e
}

rule ht_gs_105010_impacket_workstation_name {
  meta:
    rule_id         = "GS-105010"
    author          = "HuntingThreats"
    description     = "Impacket-style random workstation name in logon — DESKTOP-XXXXXXX pattern"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1550.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.principal.hostname, `(?i)DESKTOP-[A-Z0-9]{7}`)
    NOT $e.target.hostname = $e.principal.hostname

  condition:
    $e
}

rule ht_gs_105011_lateral_sc_remote {
  meta:
    rule_id         = "GS-105011"
    author          = "HuntingThreats"
    description     = "SC.exe targeting remote host for service install — remote service lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1543.003"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\sc\.exe$`)
    re.regex($e.target.process.command_line, `(?i)\\\\[a-z0-9]`)
    re.regex($e.target.process.command_line, `(?i)(create|start)`)

  condition:
    $e
}

rule ht_gs_105012_lateral_schtasks_remote {
  meta:
    rule_id         = "GS-105012"
    author          = "HuntingThreats"
    description     = "Schtasks /s targeting remote host — remote scheduled task creation"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1053.005"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\schtasks\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(/s\s+\\\\|\/s\s+[a-z0-9])`)
    re.regex($e.target.process.command_line, `(?i)/create`)

  condition:
    $e
}

rule ht_gs_105013_bloodhound_recon {
  meta:
    rule_id         = "GS-105013"
    author          = "HuntingThreats"
    description     = "SharpHound or BloodHound AD collection tool — attack path mapping"
