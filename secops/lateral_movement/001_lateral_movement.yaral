  condition:
    $e
}

rule ht_gs_105026_overpass_hash_logon_type9 {
  meta:
    rule_id         = "GS-105026"
    author          = "HuntingThreats"
    description     = "Logon Type 9 (NewCredentials) from non-standard tool — Overpass-the-Hash indicator"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1550.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.metadata.product_log_id, `(?i)4648`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(explorer|chrome|firefox|outlook)\.exe$`)

  condition:
    $e
}

rule ht_gs_105027_golden_ticket_logon_anomaly {
  meta:
    rule_id         = "GS-105027"
    author          = "HuntingThreats"
    description     = "Kerberos ticket with unusual encryption type (23/RC4) for privileged account — Golden Ticket indicator"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1558.001"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.target.user.userid, `(?i)(administrator|krbtgt|admin)`)
    re.regex($e.extensions.auth.auth_details, `(?i)(0x17|rc4|rc4-hmac)`)

  condition:
    $e
}

rule ht_gs_105028_lateral_reg_remote {
  meta:
    rule_id         = "GS-105028"
    author          = "HuntingThreats"
    description     = "Reg.exe targeting remote registry — remote registry modification for lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.file.full_path, `(?i)\\reg\.exe$`)
    re.regex($e.target.process.command_line, `(?i)(\\\\[a-z0-9].*\\HKLM|\\\\[a-z0-9].*\\HKCU)`)

  condition:
    $e
}

rule ht_gs_105029_ssh_key_theft {
  meta:
    rule_id         = "GS-105029"
    author          = "HuntingThreats"
    description     = "SSH private key file (.pem/.key/.ppk) accessed by non-SSH process"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.004"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "FILE_CREATION"
    re.regex($e.target.file.full_path, `(?i)\.(pem|ppk|id_rsa|id_ed25519)$`)
    NOT re.regex($e.principal.process.file.full_path, `(?i)\\(ssh|putty|winscp|filezilla|pageant)`)

  condition:
    $e
}

rule ht_gs_105030_network_logon_new_admin {
  meta:
    rule_id         = "GS-105030"
    author          = "HuntingThreats"
    description     = "Network logon (Type 3) with new account added to local admin — privilege escalation via lateral"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1078.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "USER_LOGIN"
    re.regex($e.metadata.product_log_id, `(?i)4728`)

  condition:
    $e
}

rule ht_gs_105031_active_directory_replication {
  meta:
    rule_id         = "GS-105031"
    author          = "HuntingThreats"
    description     = "Non-DC machine requesting AD replication — DCSync credential attack"
    mitre_tactic    = "Credential Access"
    mitre_technique = "T1003.006"
    severity        = "CRITICAL"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)(DS-Replication-Get-Changes|drsuapi|drsync|drsr|DRSBind)`)

