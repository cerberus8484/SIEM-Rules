}

rule ht_gs_105017_lateral_distinct_targets_threshold {
  meta:
    rule_id         = "GS-105017"
    author          = "HuntingThreats"
    description     = "One source connecting to 5+ distinct internal hosts in 10 min — lateral sweep"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "NETWORK_CONNECTION"
    $e.target.ip in cidr "10.0.0.0/8"

  match:
    $e.principal.hostname over 10m

  condition:
    #e > 5
}

rule ht_gs_105018_crackmapexec_pattern {
  meta:
    rule_id         = "GS-105018"
    author          = "HuntingThreats"
    description     = "CrackMapExec pattern — cmd /Q /c in service or logon — CME lateral movement"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e.target.process.command_line, `(?i)cmd\.exe\s+/Q\s+/c`)

  condition:
    $e
}

rule ht_gs_105019_smb_execution_meterpreter {
  meta:
    rule_id         = "GS-105019"
    author          = "HuntingThreats"
    description     = "SMB share connection followed by immediate process creation — SMB execution chain"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1021.002"
    severity        = "HIGH"
    confidence      = "MEDIUM"

  events:
    $e1.metadata.event_type = "USER_LOGIN"
    re.regex($e1.target.resource.name, `(?i)(C\$|ADMIN\$)`)

    $e2.metadata.event_type = "PROCESS_LAUNCH"
    re.regex($e2.target.process.file.full_path, `(?i)\\(cmd|powershell|wscript)\.exe$`)

    $e1.target.hostname = $e2.principal.hostname

  match:
    $e1.target.hostname over 5m

  condition:
    $e1 and $e2
}

