}

rule ht_gs_105032_smb_signing_disabled {
  meta:
    rule_id         = "GS-105032"
    author          = "HuntingThreats"
    description     = "SMB signing disabled — enabling NTLM relay attack condition"
    mitre_tactic    = "Lateral Movement"
    mitre_technique = "T1557.001"
    severity        = "HIGH"
    confidence      = "HIGH"

  events:
    $e.metadata.event_type = "REGISTRY_MODIFICATION"
    re.regex($e.target.registry.registry_key, `(?i)\\Smb.*RequireSecuritySignature`)
    $e.target.registry.registry_value_data = "0"

  condition:
    $e
}

rule ht_gs_105033_gpo_link_at_dc {
  meta:
    rule_id         = "GS-105033"
    author          = "HuntingThreats"
