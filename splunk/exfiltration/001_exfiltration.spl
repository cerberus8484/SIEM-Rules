`comment("SP-107026 | T1048 | Exfil: Unusual number of files read before outbound connection | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=11
(TargetFilename="*.docx" OR TargetFilename="*.xlsx" OR TargetFilename="*.pdf" OR TargetFilename="*.txt" OR TargetFilename="*.key" OR TargetFilename="*.pfx")
| bin _time span=5m
| stats count as FileRead by _time, host, Image
| where FileRead > 50
| eval rule_id="SP-107026", mitre_technique="T1048", mitre_tactic="Collection", severity="HIGH", confidence=62
| table _time, host, Image, FileRead, rule_id, severity
| sort -_time

`comment("SP-107027 | T1048 | Exfil: Stagefright — large ZIP created in Downloads then immediate connection | Severity: HIGH | Confidence: HIGH")`
index=windows
((EventCode=11 TargetFilename="*\\Downloads\\*.zip") OR (EventCode=3 NOT (DestinationIp="10.*" OR DestinationIp="192.168.*")))
| transaction host maxspan=5m
| where eventcount >= 2
| eval rule_id="SP-107027", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, rule_id, severity
| sort -_time

`comment("SP-107028 | T1020 | Exfil: Automated clipboard access + file write | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=4104
(ScriptBlockText="*Get-Clipboard*" OR ScriptBlockText="*GetClipboardData*")
(ScriptBlockText="*Out-File*" OR ScriptBlockText="*Set-Content*" OR ScriptBlockText="*Add-Content*")
| eval rule_id="SP-107028", mitre_technique="T1020", mitre_tactic="Collection", severity="MEDIUM", confidence=62
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107029 | T1048 | Exfil: Certutil encode before outbound — base64 exfil preparation | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\certutil.exe" OR NewProcessName="*\\certutil.exe")
(CommandLine="*-encode*" OR CommandLine="*-encodehex*")
| eval rule_id="SP-107029", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107030 | T1048 | Exfil: Exfil burst — recon + archive + outbound in 15-minute window | Severity: CRITICAL | Confidence: HIGH")`
index=windows
((EventCode=1 (Image="*\\systeminfo.exe" OR Image="*\\whoami.exe" OR Image="*\\ipconfig.exe")) OR
 (EventCode=11 (TargetFilename="*.zip" OR TargetFilename="*.rar")) OR
 (EventCode=3 NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")))
| transaction host maxspan=15m
| where eventcount >= 3
| eval rule_id="SP-107030", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="CRITICAL", confidence=90
| table _time, host, rule_id, severity
| sort -_time
