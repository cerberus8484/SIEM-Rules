`comment("SP-107019 | T1048 | Exfil: Massive outbound data volume — >500MB in 10 minutes | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=3
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
NOT (Image="*\\chrome.exe" OR Image="*\\svchost.exe" OR Image="*\\OneDrive.exe")
| bin _time span=10m
| stats sum(bytes_out) as TotalBytes by _time, host
| where TotalBytes > 524288000
| eval rule_id="SP-107019", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="CRITICAL", confidence=90
| table _time, host, TotalBytes, rule_id, severity
| sort -_time

`comment("SP-107020 | T1048 | Exfil: Reg export followed by file copy — credential exfil | Severity: CRITICAL | Confidence: HIGH")`
index=windows
((EventCode=1 Image="*\\reg.exe" CommandLine="*export*") OR (EventCode=3 NOT (DestinationIp="10.*" OR DestinationIp="192.168.*")))
| transaction host maxspan=10m
| where eventcount >= 2
| eval rule_id="SP-107020", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="CRITICAL", confidence=90
| table _time, host, rule_id, severity
| sort -_time

