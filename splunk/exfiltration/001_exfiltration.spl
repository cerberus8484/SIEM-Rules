index=windows EventCode=22
(QueryName="*api.github.com*" OR QueryName="*gist.github.com*" OR QueryName="*pastebin.com*" OR QueryName="*paste.ee*")
NOT (Image="*\\chrome.exe" OR Image="*\\msedge.exe" OR Image="*\\firefox.exe")
