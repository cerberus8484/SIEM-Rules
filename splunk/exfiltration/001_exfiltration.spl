`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Exfiltration (T1041, T1048, T1052, T1560)
Batch     : 11 / Exfiltration
Rules     : SP-107001 – SP-107030
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1/3/11, Windows Event 4688
============================================================
")`

`comment("SP-107001 | T1048.003 | Exfil: HTTPS POST to external IP from non-browser | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
DestinationPort IN (443, 8443)
NOT (Image="*\\chrome.exe" OR Image="*\\msedge.exe" OR Image="*\\firefox.exe" OR Image="*\\iexplore.exe" OR Image="*\\svchost.exe")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| eval rule_id="SP-107001", mitre_technique="T1048.003", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107002 | T1048.001 | Exfil: DNS TXT record with base64-like content — DNS exfil | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=22
QueryType="TXT"
| rex field=QueryName "^(?P<label>[a-zA-Z0-9+/=]{20,})\."
| where len(label) > 20
| eval rule_id="SP-107002", mitre_technique="T1048.001", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, Image, QueryName, label, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107003 | T1560.001 | Exfil: Archive created with sensitive file patterns | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=4104
(ScriptBlockText="*Compress-Archive*" OR ScriptBlockText="*ZipFile*" OR ScriptBlockText="*7z*")
(ScriptBlockText="*.docx*" OR ScriptBlockText="*.xlsx*" OR ScriptBlockText="*.pdf*" OR ScriptBlockText="*.kdbx*" OR ScriptBlockText="*.pfx*")
| eval rule_id="SP-107003", mitre_technique="T1560.001", mitre_tactic="Collection", severity="MEDIUM", confidence=62
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107004 | T1041 | Exfil: PowerShell UploadFile/UploadString — data sent via PS | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*UploadFile*" OR ScriptBlockText="*UploadString*" OR ScriptBlockText="*UploadData*")
| eval rule_id="SP-107004", mitre_technique="T1041", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107005 | T1048 | Exfil: Curl with data upload to external URL | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\curl.exe" OR CommandLine="*curl*")
(CommandLine="*-d*" OR CommandLine="*--data*" OR CommandLine="*-T*" OR CommandLine="*--upload*")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*")
| eval rule_id="SP-107005", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107006 | T1048 | Exfil: FTP client connecting to external — ftp.exe data transfer | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
(Image="*\\ftp.exe" OR Image="*\\sftp.exe")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| eval rule_id="SP-107006", mitre_technique="T1048", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107007 | T1052.001 | Exfil: USB/removable drive file copy — large copy to drive letter | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=11
(TargetFilename="E:\\*" OR TargetFilename="F:\\*" OR TargetFilename="G:\\*" OR TargetFilename="H:\\*")
(TargetFilename="*.zip" OR TargetFilename="*.rar" OR TargetFilename="*.tar*" OR TargetFilename="*.7z")
| eval rule_id="SP-107007", mitre_technique="T1052.001", mitre_tactic="Exfiltration", severity="HIGH", confidence=62
| table _time, host, Image, TargetFilename, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-107008 | T1567.002 | Exfil: OneDrive/Dropbox sync unusual large file | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=3
(Image="*\\OneDrive.exe" OR Image="*\\Dropbox*" OR Image="*\\googledrivesync*")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| bin _time span=10m
| stats count as SyncCount sum(bytes_out) as TotalBytes by _time, host, Image
| where TotalBytes > 104857600
| eval rule_id="SP-107008", mitre_technique="T1567.002", mitre_tactic="Exfiltration", severity="MEDIUM", confidence=62
| table _time, host, Image, TotalBytes, SyncCount, rule_id, severity
| sort -_time

`comment("SP-107009 | T1041 | Exfil: BITSAdmin transfer to external — stealthy exfil | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\bitsadmin.exe" OR NewProcessName="*\\bitsadmin.exe")
(CommandLine="*/transfer*" OR CommandLine="*/addfile*")
(CommandLine="*http://*" OR CommandLine="*https://*" OR CommandLine="*ftp://*")
| eval rule_id="SP-107009", mitre_technique="T1041", mitre_tactic="Exfiltration", severity="HIGH", confidence=78
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

