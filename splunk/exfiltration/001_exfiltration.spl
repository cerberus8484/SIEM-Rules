`comment("SP-107018 | T1041 | Exfil: Netcat outbound connection — raw socket data transfer | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
(Image="*\\nc.exe" OR Image="*\\ncat.exe" OR Image="*\\netcat*")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
