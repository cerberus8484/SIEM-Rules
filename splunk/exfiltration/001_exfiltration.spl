`comment("SP-107025 | T1041 | Exfil: Plink/SSH tunnel for data transfer | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
(Image="*\\plink.exe" OR Image="*\\putty.exe")
DestinationPort IN (22, 2222)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
