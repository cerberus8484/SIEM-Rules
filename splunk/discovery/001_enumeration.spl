`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Discovery — Enumeration (T1016, T1018, T1069, T1082, T1087)
Batch     : 10 / Discovery
Rules     : SP-106001 – SP-106035
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1, Windows Event 4688
============================================================
")`

`comment("SP-106001 | T1082 | Discovery: Systeminfo executed — OS/hardware enumeration | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\systeminfo.exe" OR NewProcessName="*\\systeminfo.exe")
| eval rule_id="SP-106001", mitre_technique="T1082", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106002 | T1087.002 | Discovery: Net user /domain — AD user enumeration | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\net1.exe" OR NewProcessName="*\\net.exe")
(CommandLine="*user*" AND CommandLine="*/domain*")
| eval rule_id="SP-106002", mitre_technique="T1087.002", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106003 | T1069.002 | Discovery: Net group /domain — domain group enumeration | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\net1.exe")
(CommandLine="*group*" AND CommandLine="*/domain*")
| eval rule_id="SP-106003", mitre_technique="T1069.002", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106004 | T1018 | Discovery: Ping sweep — high-frequency ICMP to multiple hosts | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\ping.exe" OR NewProcessName="*\\ping.exe")
| bin _time span=5m
| stats count as PingCount dc(CommandLine) as UniqueTargets by _time, host
| where PingCount > 10
| eval rule_id="SP-106004", mitre_technique="T1018", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, PingCount, UniqueTargets, rule_id, severity
| sort -_time

`comment("SP-106005 | T1016 | Discovery: Ipconfig /all — network configuration dump | Severity: LOW | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\ipconfig.exe" OR NewProcessName="*\\ipconfig.exe")
CommandLine="*/all*"
NOT (ParentImage="*\\explorer.exe" OR ParentImage="*\\cmd.exe")
| eval rule_id="SP-106005", mitre_technique="T1016", mitre_tactic="Discovery", severity="LOW", confidence=73
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106006 | T1018 | Discovery: Arp -a — ARP table enumeration for host discovery | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\arp.exe" OR NewProcessName="*\\arp.exe")
CommandLine="*-a*"
NOT (ParentImage="*\\explorer.exe" OR ParentImage="*\\svchost.exe")
| eval rule_id="SP-106006", mitre_technique="T1018", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106007 | T1049 | Discovery: Netstat — network connection enumeration | Severity: LOW | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\netstat.exe" OR NewProcessName="*\\netstat.exe")
NOT (ParentImage="*\\explorer.exe" OR ParentImage="*\\cmd.exe")
| eval rule_id="SP-106007", mitre_technique="T1049", mitre_tactic="Discovery", severity="LOW", confidence=73
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106008 | T1083 | Discovery: Dir /s /b — recursive directory listing | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\cmd.exe" OR NewProcessName="*\\cmd.exe")
CommandLine="*/c dir*" (CommandLine="*/s*" OR CommandLine="*/b*")
NOT (ParentImage="*\\explorer.exe")
| eval rule_id="SP-106008", mitre_technique="T1083", mitre_tactic="Discovery", severity="MEDIUM", confidence=57
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106009 | T1069.001 | Discovery: Net localgroup administrators — local admin enumeration | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\net1.exe")
CommandLine="*localgroup*" CommandLine="*administrators*"
| eval rule_id="SP-106009", mitre_technique="T1069.001", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106010 | T1087.001 | Discovery: Whoami /all — privilege and group enumeration | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\whoami.exe" OR NewProcessName="*\\whoami.exe")
(CommandLine="*/all*" OR CommandLine="*/priv*" OR CommandLine="*/groups*")
NOT (ParentImage="*\\explorer.exe")
| eval rule_id="SP-106010", mitre_technique="T1087.001", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106011 | T1012 | Discovery: Reg query for sensitive hive paths | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\reg.exe" OR NewProcessName="*\\reg.exe")
CommandLine="*query*"
(CommandLine="*Winlogon*" OR CommandLine="*LSA*" OR CommandLine="*SAM*" OR CommandLine="*System\\CurrentControlSet*")
| eval rule_id="SP-106011", mitre_technique="T1012", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106012 | T1057 | Discovery: Tasklist / Get-Process — running process enumeration | Severity: LOW | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688 OR EventCode=4104)
((Image="*\\tasklist.exe" OR NewProcessName="*\\tasklist.exe") OR ScriptBlockText="*Get-Process*" OR ScriptBlockText="*ps -*")
NOT (ParentImage="*\\explorer.exe")
| eval rule_id="SP-106012", mitre_technique="T1057", mitre_tactic="Discovery", severity="LOW", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106013 | T1082 | Discovery: WMIC OS/bios get — system info via WMI | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\wmic.exe" OR NewProcessName="*\\wmic.exe")
(CommandLine="*os get*" OR CommandLine="*computersystem get*" OR CommandLine="*bios get*" OR CommandLine="*cpu get*")
NOT (CommandLine="*/node:*")
| eval rule_id="SP-106013", mitre_technique="T1082", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106014 | T1135 | Discovery: Net share — local share enumeration | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\net1.exe")
CommandLine="*share*" NOT (CommandLine="*/add*" OR CommandLine="*/delete*")
| eval rule_id="SP-106014", mitre_technique="T1135", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106015 | T1087.002 | Discovery: PowerShell AD module user enumeration | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*Get-ADUser*" OR ScriptBlockText="*Get-ADGroup*" OR ScriptBlockText="*Get-ADComputer*" OR ScriptBlockText="*Get-ADGroupMember*")
NOT (ScriptBlockText="*-Identity*" AND ScriptBlockText!="*Filter*")
| eval rule_id="SP-106015", mitre_technique="T1087.002", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106016 | T1046 | Discovery: Port scan via PowerShell Test-NetConnection | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*Test-NetConnection*" OR ScriptBlockText="*TcpClient*" OR ScriptBlockText="*New-Object System.Net.Sockets*")
ScriptBlockText="*port*"
| eval rule_id="SP-106016", mitre_technique="T1046", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106017 | T1082 | Discovery: Get-ComputerInfo — comprehensive system info | Severity: MEDIUM | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*Get-ComputerInfo*" OR ScriptBlockText="*Get-HotFix*" OR ScriptBlockText="*Get-WmiObject Win32_ComputerSystem*")
| eval rule_id="SP-106017", mitre_technique="T1082", mitre_tactic="Discovery", severity="MEDIUM", confidence=73
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

