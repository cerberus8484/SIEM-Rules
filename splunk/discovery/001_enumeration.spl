`comment("SP-106020 | T1007 | Discovery: Sc query / tasklist /svc — service enumeration | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
((Image="*\\sc.exe" AND CommandLine="*query*") OR (Image="*\\tasklist.exe" AND CommandLine="*/svc*"))
