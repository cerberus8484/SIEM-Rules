| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106028 | T1082 | Discovery: Msinfo32 — system info GUI tool launched silently | Severity: LOW | Confidence: MEDIUM")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\msinfo32.exe" OR NewProcessName="*\\msinfo32.exe")
NOT (ParentImage="*\\explorer.exe")
| eval rule_id="SP-106028", mitre_technique="T1082", mitre_tactic="Discovery", severity="LOW", confidence=57
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106029 | T1217 | Discovery: Browser bookmark file access — credential/target mapping | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=11
(TargetFilename="*\\Chrome\\User Data\\Default\\Bookmarks*" OR TargetFilename="*\\Firefox\\Profiles\\*\\places.sqlite*" OR TargetFilename="*\\Edge\\User Data\\Default\\Bookmarks*")
NOT (Image="*\\chrome.exe" OR Image="*\\firefox.exe" OR Image="*\\msedge.exe")
| eval rule_id="SP-106029", mitre_technique="T1217", mitre_tactic="Discovery", severity="MEDIUM", confidence=57
| table _time, host, Image, TargetFilename, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106030 | T1087.002 | Discovery: LDAP query via PS — Get-ADDomain/Forest | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*Get-ADDomain*" OR ScriptBlockText="*Get-ADForest*" OR ScriptBlockText="*Get-ADTrust*" OR ScriptBlockText="*Get-ADOrganizationalUnit*")
| eval rule_id="SP-106030", mitre_technique="T1087.002", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106031 | T1082 | Discovery: Recon burst — >8 discovery tools in 2 minutes | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\whoami.exe" OR Image="*\\ipconfig.exe" OR Image="*\\systeminfo.exe" OR Image="*\\net.exe" OR Image="*\\arp.exe" OR Image="*\\netstat.exe" OR Image="*\\tasklist.exe" OR Image="*\\ping.exe" OR Image="*\\route.exe" OR Image="*\\nltest.exe")
| bin _time span=2m
| stats dc(Image) as UniqueTools count as Executions by _time, host
| where UniqueTools > 5
| eval rule_id="SP-106031", mitre_technique="T1082", mitre_tactic="Discovery", severity="CRITICAL", confidence=85
| table _time, host, UniqueTools, Executions, rule_id, severity
| sort -_time

`comment("SP-106032 | T1083 | Discovery: Powershell Get-ChildItem sensitive directory | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=4104
ScriptBlockText="*Get-ChildItem*"
(ScriptBlockText="*\\Users\\*" OR ScriptBlockText="*\\Documents\\*" OR ScriptBlockText="*\\Desktop\\*" OR ScriptBlockText="*-Recurse*")
| eval rule_id="SP-106032", mitre_technique="T1083", mitre_tactic="Discovery", severity="MEDIUM", confidence=57
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106033 | T1046 | Discovery: Internal port scan via Test-NetConnection burst | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
NOT (DestinationIp="127.*")
(DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| bin _time span=2m
| stats dc(DestinationPort) as UniquePorts dc(DestinationIp) as UniqueIPs by _time, host, Image
| where UniquePorts > 10 OR UniqueIPs > 20
| eval rule_id="SP-106033", mitre_technique="T1046", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, Image, UniquePorts, UniqueIPs, rule_id, severity
| sort -_time

`comment("SP-106034 | T1040 | Discovery: Network sniffer execution — Wireshark/tcpdump | Severity: HIGH | Confidence: MEDIUM")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\Wireshark*" OR Image="*\\tshark*" OR Image="*\\tcpdump*" OR Image="*\\windump*" OR Image="*\\rawshark*")
NOT (ParentImage="*\\explorer.exe")
| eval rule_id="SP-106034", mitre_technique="T1040", mitre_tactic="Discovery", severity="HIGH", confidence=57
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106035 | T1069.002 | Discovery: Domain admin group enumeration — net group 'Domain Admins' | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\net1.exe")
(CommandLine="*Domain Admins*" OR CommandLine="*Enterprise Admins*" OR CommandLine="*Schema Admins*")
| eval rule_id="SP-106035", mitre_technique="T1069.002", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time
