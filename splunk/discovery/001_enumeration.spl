index=windows EventCode=4104
(ScriptBlockText="*GetForegroundWindow*" OR ScriptBlockText="*EnumWindows*" OR ScriptBlockText="*FindWindowEx*")
| eval rule_id="SP-106026", mitre_technique="T1010", mitre_tactic="Discovery", severity="MEDIUM", confidence=57
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-106027 | T1033 | Discovery: Query session / quser — logged-on user enumeration | Severity: MEDIUM | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\quser.exe" OR Image="*\\query.exe" OR NewProcessName="*\\quser.exe")
(CommandLine="*session*" OR CommandLine="*user*")
