index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\nmap*" OR Image="*\\masscan*" OR CommandLine="*nmap*" OR CommandLine="*masscan*")
| eval rule_id="SP-106024", mitre_technique="T1018", mitre_tactic="Discovery", severity="HIGH", confidence=73
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
