`comment("SP-106021 | T1069.002 | Discovery: BloodHound/SharpHound execution — AD recon tool | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\SharpHound*" OR Image="*\\BloodHound*" OR CommandLine="*SharpHound*" OR CommandLine="*CollectionMethod*")
| eval rule_id="SP-106021", mitre_technique="T1069.002", mitre_tactic="Discovery", severity="CRITICAL", confidence=85
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

