`comment("SP-102019 | T1562.004 | Evasion: Netsh advfirewall rule added to allow external | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\netsh.exe" OR NewProcessName="*\\netsh.exe")
CommandLine="*advfirewall*" CommandLine="*add rule*" (CommandLine="*allow*" OR CommandLine="*enable*")
| eval rule_id="SP-102019", mitre_technique="T1562.004", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102020 | T1070.006 | Evasion: Timestomp — touch/PowerShell file timestamp modification | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*LastWriteTime*" OR ScriptBlockText="*CreationTime*" OR ScriptBlockText="*LastAccessTime*")
(ScriptBlockText="*Set-ItemProperty*" OR ScriptBlockText="*[System.IO.File]::SetLastWriteTime*")
| eval rule_id="SP-102020", mitre_technique="T1070.006", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102021 | T1027.001 | Evasion: Base64 string longer than 1000 chars in cmd | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\cmd.exe" OR Image="*\\powershell.exe")
| eval cmdlen=len(CommandLine)
| where cmdlen > 1000
| eval rule_id="SP-102021", mitre_technique="T1027.001", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, cmdlen, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102022 | T1562.006 | Evasion: Sysmon unload — fltMC or sc stop sysmon | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\fltMC.exe" OR (Image="*\\sc.exe" AND CommandLine="*stop*"))
(CommandLine="*sysmon*" OR CommandLine="*SysmonDrv*")
| eval rule_id="SP-102022", mitre_technique="T1562.006", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102023 | T1055.009 | Evasion: Proc memory via /proc equivalent — ReadProcessMemory from untrusted source | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=10
GrantedAccess="0x10"
NOT (SourceImage="*\\MsMpEng.exe" OR SourceImage="*\\csrss.exe" OR SourceImage="*\\System")
| eval rule_id="SP-102023", mitre_technique="T1055.009", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, SourceImage, TargetImage, GrantedAccess, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102024 | T1562.001 | Evasion: PowerShell disabling Script Block logging | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=13
(TargetObject="*\\ScriptBlockLogging\\EnableScriptBlockLogging*" OR TargetObject="*\\ModuleLogging\\EnableModuleLogging*")
Details="0"
| eval rule_id="SP-102024", mitre_technique="T1562.001", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, Image, TargetObject, Details, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102025 | T1036.007 | Evasion: Double file extension — file.pdf.exe pattern | Severity: HIGH | Confidence: HIGH")`
