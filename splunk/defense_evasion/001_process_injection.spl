`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Defense Evasion — Process Injection & Masquerading (T1055, T1036)
Batch     : 14 / Defense Evasion
Rules     : SP-102001 – SP-102035
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1/7/8/10, Windows Event 4688
============================================================
")`

`comment("SP-102001 | T1055.001 | Evasion: DLL injection — CreateRemoteThread to non-system process | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=8
NOT (SourceImage="*\\MsMpEng.exe" OR SourceImage="*\\csrss.exe" OR SourceImage="*\\System" OR SourceImage="*\\ntoskrnl.exe")
NOT (TargetImage="*\\MsMpEng.exe" OR TargetImage="*\\svchost.exe")
| eval rule_id="SP-102001", mitre_technique="T1055.001", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, SourceImage, TargetImage, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102002 | T1055.002 | Evasion: PE injection — VirtualAllocEx + WriteProcessMemory via PS | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*VirtualAllocEx*" OR ScriptBlockText="*WriteProcessMemory*")
(ScriptBlockText="*OpenProcess*" OR ScriptBlockText="*CreateRemoteThread*")
| eval rule_id="SP-102002", mitre_technique="T1055.002", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102003 | T1055.012 | Evasion: Process hollowing — NtUnmapViewOfSection API | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*NtUnmapViewOfSection*" OR ScriptBlockText="*ZwUnmapViewOfSection*")
| eval rule_id="SP-102003", mitre_technique="T1055.012", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102004 | T1036.003 | Evasion: Masquerading — svchost.exe from non-System32 path | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=1
(Image="*\\svchost.exe" OR Image="*\\lsass.exe" OR Image="*\\csrss.exe" OR Image="*\\winlogon.exe")
NOT (Image="*\\Windows\\System32\\*" OR Image="*\\Windows\\SysWOW64\\*")
| eval rule_id="SP-102004", mitre_technique="T1036.003", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, Image, ParentImage, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102005 | T1036.005 | Evasion: Process named like legitimate binary but different path | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=1
(Image="*\\svchost.exe" OR Image="*\\explorer.exe" OR Image="*\\csrss.exe" OR Image="*\\winlogon.exe")
NOT (Image="C:\\Windows\\System32\\*" OR Image="C:\\Windows\\SysWOW64\\*" OR Image="C:\\Windows\\explorer.exe")
| eval rule_id="SP-102005", mitre_technique="T1036.005", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102006 | T1055.003 | Evasion: Reflective DLL injection — Sysmon EventCode 7 unsigned DLL | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=7
Signed="false"
NOT (ImageLoaded="*\\Windows\\*" OR ImageLoaded="*\\Program Files\\*")
NOT (Image="*\\chrome.exe" OR Image="*\\msedge.exe" OR Image="*\\firefox.exe" OR Image="*\\java*")
| eval rule_id="SP-102006", mitre_technique="T1055.003", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, Image, ImageLoaded, Signed, SignatureStatus, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102007 | T1562.001 | Evasion: Windows Defender exclusion added — AV bypass | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=13
(TargetObject="*\\Windows Defender\\Exclusions\\Paths\\*" OR TargetObject="*\\Windows Defender\\Exclusions\\Processes\\*" OR TargetObject="*\\Windows Defender\\Exclusions\\Extensions\\*")
| eval rule_id="SP-102007", mitre_technique="T1562.001", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, Image, TargetObject, Details, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102008 | T1027 | Evasion: XOR decoding pattern in PS script block | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*-bxor*" OR ScriptBlockText="*XOR*" OR ScriptBlockText="*ForEach-Object{$_-bxor*")
| eval rule_id="SP-102008", mitre_technique="T1027", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102009 | T1070.004 | Evasion: File deletion via cmd /c del — covering tracks | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows (EventCode=1 OR EventCode=4688)
Image="*\\cmd.exe"
(CommandLine="*/c del*" OR CommandLine="*/c erase*")
(CommandLine="*\\Temp\\*" OR CommandLine="*\\AppData\\*" OR CommandLine="*\\ProgramData\\*")
| eval rule_id="SP-102009", mitre_technique="T1070.004", mitre_tactic="Defense Evasion", severity="MEDIUM", confidence="MEDIUM"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102010 | T1562.002 | Evasion: Windows Event Log service stopped | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\net.exe" OR Image="*\\sc.exe")
(CommandLine="*stop*" AND CommandLine="*EventLog*")
| eval rule_id="SP-102010", mitre_technique="T1562.002", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102011 | T1027.002 | Evasion: Software packing indicator — binary entropy high, small IAT | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=7
Signed="false" SignatureStatus!="Valid"
NOT (ImageLoaded="*\\Windows\\*" OR ImageLoaded="*\\Program Files\\*")
| eval rule_id="SP-102011", mitre_technique="T1027.002", mitre_tactic="Defense Evasion", severity="HIGH", confidence="MEDIUM"
| table _time, host, Image, ImageLoaded, Signed, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102012 | T1055.013 | Evasion: Process doppelgänging — NtCreateSection on file handle | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*NtCreateSection*" OR ScriptBlockText="*NtCreateTransaction*" OR ScriptBlockText="*doppelganging*" OR ScriptBlockText="*ProcessDoppelganging*")
| eval rule_id="SP-102012", mitre_technique="T1055.013", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102013 | T1036.004 | Evasion: Masquerade as scheduled task — image path matches but PPID wrong | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=1
ParentImage="*\\taskeng.exe" OR ParentImage="*\\svchost.exe"
(Image="*\\cmd.exe" OR Image="*\\powershell.exe")
NOT (CommandLine="*update*" OR CommandLine="*maintenance*")
| eval rule_id="SP-102013", mitre_technique="T1036.004", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102014 | T1070.001 | Evasion: Wevtutil cl — clearing specific event log | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\wevtutil.exe" OR NewProcessName="*\\wevtutil.exe")
(CommandLine="*cl*" OR CommandLine="*clear-log*")
| eval rule_id="SP-102014", mitre_technique="T1070.001", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102015 | T1562.001 | Evasion: MpCmdRun.exe disable realtime protection | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\MpCmdRun.exe" OR NewProcessName="*\\MpCmdRun.exe")
(CommandLine="*-RemediationRun*" OR CommandLine="*-SignatureUpdate*" OR CommandLine="*-Restore*")
