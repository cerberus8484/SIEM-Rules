`comment("SP-102026 | T1070.003 | Evasion: PowerShell history clear — Remove-Item ConsoleHost_history | Severity: MEDIUM | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*ConsoleHost_history.txt*" AND (ScriptBlockText="*Remove-Item*" OR ScriptBlockText="*del *" OR ScriptBlockText="*Clear-History*"))
| eval rule_id="SP-102026", mitre_technique="T1070.003", mitre_tactic="Defense Evasion", severity="MEDIUM", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102027 | T1218.011 | Evasion: Rundll32 with suspicious argument count — LOLBin abuse | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\rundll32.exe" OR NewProcessName="*\\rundll32.exe")
NOT (CommandLine="*shell32.dll*" OR CommandLine="*syssetup.dll*" OR CommandLine="*url.dll*")
NOT (CommandLine="*\\Windows\\System32\\*" OR CommandLine="*\\Windows\\SysWOW64\\*")
| eval rule_id="SP-102027", mitre_technique="T1218.011", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102028 | T1027.005 | Evasion: Indicator removal on host — sr.exe or Prefetch deletion | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(CommandLine="*\\Prefetch\\*" AND (CommandLine="*del*" OR CommandLine="*erase*")) OR (Image="*\\cleanmgr.exe" AND CommandLine="*/autoclean*")
| eval rule_id="SP-102028", mitre_technique="T1027.005", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102029 | T1055.015 | Evasion: ListPlanting — SetWindowsHookEx inject into UI thread | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=4104
(ScriptBlockText="*SetWindowsHookEx*" OR ScriptBlockText="*CallNextHookEx*")
ScriptBlockText="*WH_CBT*" OR ScriptBlockText="*WH_MOUSE*" OR ScriptBlockText="*WH_KEYBOARD*"
| eval rule_id="SP-102029", mitre_technique="T1055.015", mitre_tactic="Defense Evasion", severity="HIGH", confidence="MEDIUM"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102030 | T1562.001 | Evasion: CrowdStrike/SentinelOne agent tamper via reg delete | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\reg.exe" OR NewProcessName="*\\reg.exe")
CommandLine="*delete*"
(CommandLine="*CrowdStrike*" OR CommandLine="*SentinelOne*" OR CommandLine="*Carbon Black*" OR CommandLine="*Sophos*" OR CommandLine="*McAfee*" OR CommandLine="*Symantec*")
| eval rule_id="SP-102030", mitre_technique="T1562.001", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102031 | T1218.005 | Evasion: Mshta.exe executing remote HTA — LOLBin remote exec | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\mshta.exe" OR NewProcessName="*\\mshta.exe")
(CommandLine="*http://*" OR CommandLine="*https://*" OR CommandLine="*\\\\*")
| eval rule_id="SP-102031", mitre_technique="T1218.005", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102032 | T1070.004 | Evasion: Secure file deletion — sdelete or cipher /w | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\sdelete*" OR (Image="*\\cipher.exe" AND CommandLine="*/w:*"))
| eval rule_id="SP-102032", mitre_technique="T1070.004", mitre_tactic="Defense Evasion", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102033 | T1562.001 | Evasion: Tamper with PS execution policy via registry | Severity: MEDIUM | Confidence: HIGH")`
index=windows EventCode=13
TargetObject="*\\PowerShell\\*\\ExecutionPolicy*"
(Details="Bypass" OR Details="Unrestricted" OR Details="Undefined")
| eval rule_id="SP-102033", mitre_technique="T1562.001", mitre_tactic="Defense Evasion", severity="MEDIUM", confidence="HIGH"
| table _time, host, Image, TargetObject, Details, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-102034 | T1055.001 | Evasion: CreateRemoteThread high-frequency — >5 injects in 1 min | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=8
NOT (SourceImage="*\\MsMpEng.exe" OR SourceImage="*\\csrss.exe")
| bin _time span=1m
| stats count as InjectCount by _time, host, SourceImage
| where InjectCount > 5
| eval rule_id="SP-102034", mitre_technique="T1055.001", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, SourceImage, InjectCount, rule_id, severity
| sort -_time

`comment("SP-102035 | T1027 | Evasion: Obfuscation combo — encode + IEX + hidden + noprofile chain | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\powershell.exe" OR NewProcessName="*\\powershell.exe")
CommandLine="*-e*" CommandLine="*-nop*" CommandLine="*-w*" CommandLine="*-NonI*"
| eval rule_id="SP-102035", mitre_technique="T1027", mitre_tactic="Defense Evasion", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time
