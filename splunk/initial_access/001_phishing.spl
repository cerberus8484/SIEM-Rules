`comment("SP-110040 | T1566.001 | Initial: Phishing burst — Office spawning multiple suspicious children in 5 min | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=1
(ParentImage="*\\winword.exe" OR ParentImage="*\\excel.exe" OR ParentImage="*\\outlook.exe" OR ParentImage="*\\onenote.exe")
(Image="*\\cmd.exe" OR Image="*\\powershell.exe" OR Image="*\\wscript.exe" OR Image="*\\mshta.exe" OR Image="*\\certutil.exe" OR Image="*\\regsvr32.exe" OR Image="*\\rundll32.exe")
| bin _time span=5m
| stats dc(Image) as UniqueChildren count as SpawnCount by _time, host, ParentImage
| where UniqueChildren > 2 OR SpawnCount > 3
| eval rule_id="SP-110040", mitre_technique="T1566.001", mitre_tactic="Initial Access", severity="CRITICAL", confidence=90
| table _time, host, ParentImage, UniqueChildren, SpawnCount, rule_id, severity
| sort -_time
