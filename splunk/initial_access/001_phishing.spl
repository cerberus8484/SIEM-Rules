`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Initial Access — Phishing & Drive-by (T1566, T1190, T1204)
Batch     : 15 / Initial Access
Rules     : SP-110001 – SP-110040
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1/7/11, Windows Event 4688
============================================================
")`

`comment("SP-110001 | T1566.001 | Initial: Office spawning cmd.exe — macro payload | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=1
(ParentImage="*\\winword.exe" OR ParentImage="*\\excel.exe" OR ParentImage="*\\powerpnt.exe" OR ParentImage="*\\onenote.exe" OR ParentImage="*\\msaccess.exe" OR ParentImage="*\\outlook.exe")
(Image="*\\cmd.exe" OR Image="*\\powershell.exe" OR Image="*\\wscript.exe" OR Image="*\\cscript.exe" OR Image="*\\mshta.exe")
| eval rule_id="SP-110001", mitre_technique="T1566.001", mitre_tactic="Initial Access", severity="HIGH", confidence=78
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-110002 | T1566.001 | Initial: Office spawning powershell with -enc — encoded macro | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=1
(ParentImage="*\\winword.exe" OR ParentImage="*\\excel.exe" OR ParentImage="*\\powerpnt.exe")
Image="*\\powershell.exe"
