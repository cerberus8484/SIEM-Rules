`comment("SP-104029 | T1071.004 | C2: DNS query with entropy > 3.5 — high-entropy subdomain DGA | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=22
| rex field=QueryName "^(?P<subdomain>[^.]+)\."
| eval char_count=len(subdomain), digit_count=len(replace(subdomain,"[^0-9]",""))
| eval ratio=digit_count/char_count
| where char_count > 20 AND ratio > 0.3
NOT (QueryName="*microsoft.com" OR QueryName="*google.com")
| eval rule_id="SP-104029", mitre_technique="T1071.004", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, QueryName, char_count, ratio, rule_id, severity
| sort -_time

