index=windows EventCode=3
DestinationPort IN (9001, 9050, 9051, 9150)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| eval rule_id="SP-104007", mitre_technique="T1571", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104008 | T1071.001 | C2: Cobalt Strike common beacon ports 50050/2222/31337 | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=3
DestinationPort IN (50050, 2222, 31337, 1337, 6379, 8888)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| eval rule_id="SP-104008", mitre_technique="T1071.001", mitre_tactic="C2", severity="CRITICAL", confidence="HIGH"
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104009 | T1071.001 | Beaconing: Regular interval connections from same process | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
NOT (Image="*\\chrome.exe" OR Image="*\\msedge.exe" OR Image="*\\firefox.exe" OR Image="*\\svchost.exe")
| bin _time span=1m
| stats count as ConnCount by _time, host, Image, DestinationIp
| streamstats avg(ConnCount) as AvgConn stdev(ConnCount) as StdevConn by host, Image, DestinationIp
| where ConnCount > 0 AND StdevConn < 2 AND AvgConn > 1
| eval rule_id="SP-104009", mitre_technique="T1071.001", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DestinationIp, AvgConn, StdevConn, rule_id, severity
| sort -_time

`comment("SP-104010 | T1001.003 | C2: Long domain name DNS query — DGA pattern | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=22
| eval domain_len=len(QueryName)
| where domain_len > 50
NOT (QueryName="*microsoft.com" OR QueryName="*akamai.com" OR QueryName="*cloudfront.net")
| eval rule_id="SP-104010", mitre_technique="T1001.003", mitre_tactic="C2", severity="HIGH", confidence="MEDIUM"
| table _time, host, Image, QueryName, domain_len, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104011 | T1071.004 | C2: Subdomain count > 4 levels — DGA/tunneling indicator | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=22
| eval subdomain_count=len(QueryName)-len(replace(QueryName,"\.",""))
| where subdomain_count > 4
NOT (QueryName="*microsoft.com" OR QueryName="*google.com" OR QueryName="*akamai.net")
| eval rule_id="SP-104011", mitre_technique="T1071.004", mitre_tactic="C2", severity="HIGH", confidence="MEDIUM"
| table _time, host, Image, QueryName, subdomain_count, rule_id, mitre_technique, severity
| sort -_time

