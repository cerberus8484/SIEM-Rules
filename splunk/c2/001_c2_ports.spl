`comment("SP-104035 | T1071.004 | C2: Rapid DNS NXDomain responses — failed DGA beaconing | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=22
QueryStatus!="0"
NOT (QueryName="*microsoft.com" OR QueryName="*google.com" OR QueryName="*office.com")
| bin _time span=5m
| stats count as NxCount dc(QueryName) as UniqueNx by _time, host, Image
| where NxCount > 20 AND UniqueNx > 15
| eval rule_id="SP-104035", mitre_technique="T1071.004", mitre_tactic="C2", severity="HIGH", confidence="MEDIUM"
| table _time, host, Image, NxCount, UniqueNx, rule_id, severity
| sort -_time
