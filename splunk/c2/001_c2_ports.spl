`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Command & Control — Network & Ports (T1071, T1095)
Batch     : 8 / C2
Rules     : SP-104001 – SP-104035
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 3/22, Windows Event 5156
============================================================
")`

`comment("SP-104001 | T1071.001 | C2: HTTP on non-standard port (not 80/443/8080/8443) | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=3
(DestinationPort!=80 AND DestinationPort!=443 AND DestinationPort!=8080 AND DestinationPort!=8443)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*" OR DestinationIp="127.*")
| eval rule_id="SP-104001", mitre_technique="T1071.001", mitre_tactic="C2", severity="MEDIUM", confidence="MEDIUM"
| table _time, host, Image, DestinationIp, DestinationPort, Protocol, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104002 | T1095 | C2: Process connecting on port 4444/4445/5555 — Metasploit default | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
DestinationPort IN (4444, 4445, 5555, 5554, 1234, 6666, 7777)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| eval rule_id="SP-104002", mitre_technique="T1095", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104003 | T1095 | C2: PowerShell or wscript establishing outbound connection | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
(Image="*\\powershell.exe" OR Image="*\\pwsh.exe" OR Image="*\\wscript.exe" OR Image="*\\cscript.exe")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*" OR DestinationIp="127.*")
| eval rule_id="SP-104003", mitre_technique="T1095", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104004 | T1571 | C2: mshta.exe outbound connection — HTA remote C2 | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=3
(Image="*\\mshta.exe" OR Image="*\\wmic.exe" OR Image="*\\certutil.exe" OR Image="*\\bitsadmin.exe")
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*" OR DestinationIp="127.*")
| eval rule_id="SP-104004", mitre_technique="T1571", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DestinationIp, DestinationPort, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104005 | T1071.004 | C2: DNS TXT query for large record — DNS tunneling | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=22
QueryType="TXT"
NOT (QueryName="*google.com" OR QueryName="*microsoft.com" OR QueryName="*windows.com")
| eval rule_id="SP-104005", mitre_technique="T1071.004", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, QueryName, QueryType, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-104006 | T1071.004 | C2: High-frequency DNS queries — beaconing signature | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=22
NOT (QueryName="*microsoft.com" OR QueryName="*windows.com" OR QueryName="*office.com" OR QueryName="*azure.com")
| bin _time span=5m
| stats count as DnsCount dc(QueryName) as UniqueHosts by _time, host, Image
| where DnsCount > 50
| eval rule_id="SP-104006", mitre_technique="T1071.004", mitre_tactic="C2", severity="HIGH", confidence="HIGH"
| table _time, host, Image, DnsCount, UniqueHosts, rule_id, severity
| sort -_time

