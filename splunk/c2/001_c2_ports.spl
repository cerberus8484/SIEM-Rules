(Image="*\\excel.exe" OR Image="*\\winword.exe" OR Image="*\\powerpnt.exe")
NOT DestinationPort IN (80, 443)
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
