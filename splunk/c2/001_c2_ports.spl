`comment("SP-104033 | T1071.001 | C2: Unique external IPs per host > 50 in 10 min — scanning or C2 init | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=3
NOT (DestinationIp="10.*" OR DestinationIp="192.168.*" OR DestinationIp="172.16.*")
| bin _time span=10m
| stats dc(DestinationIp) as UniqueIPs by _time, host
| where UniqueIPs > 50
| eval rule_id="SP-104033", mitre_technique="T1071.001", mitre_tactic="C2", severity="HIGH", confidence="MEDIUM"
| table _time, host, UniqueIPs, rule_id, severity
| sort -_time

`comment("SP-104034 | T1090.003 | C2: Sliver/Havoc framework default ports 31337/10443/53 | Severity: CRITICAL | Confidence: HIGH")`
