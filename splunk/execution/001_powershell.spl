`comment("SP-100025 | T1059.001 | PowerShell: High-frequency execution threshold — >10 instances in 5 minutes | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows EventCode=1
(Image="*\\powershell.exe" OR Image="*\\pwsh.exe")
| bin _time span=5m
| stats count as ExecCount by _time, host
| where ExecCount > 10
| eval rule_id="SP-100025", mitre_technique="T1059.001", mitre_tactic="Execution", severity="MEDIUM", confidence=62
| table _time, host, ExecCount, rule_id, severity
| sort -_time
