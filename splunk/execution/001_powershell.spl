`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Execution — PowerShell (T1059.001)
Batch     : 1 / Execution
Rules     : SP-100001 – SP-100025
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1, Windows Event 4688, PS Event 4104
============================================================
")`

`comment("SP-100001 | T1059.001 | PowerShell: -EncodedCommand flag — obfuscated execution | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(CommandLine="*-EncodedCommand*" OR CommandLine="*-enc *" OR CommandLine="*-e *")
Image="*\\powershell.exe" OR NewProcessName="*\\powershell.exe"
| eval rule_id="SP-100001", mitre_technique="T1059.001", mitre_tactic="Execution", severity="HIGH", confidence=78
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-100002 | T1059.001 | PowerShell: Hidden Window (-w hidden / -windowstyle hidden) | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\powershell.exe" OR NewProcessName="*\\powershell.exe")
(CommandLine="*-w hidden*" OR CommandLine="*-windowstyle hidden*" OR CommandLine="*-window hidden*")
| eval rule_id="SP-100002", mitre_technique="T1059.001", mitre_tactic="Execution", severity="HIGH", confidence=78
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-100003 | T1059.001 | PowerShell: IEX + WebClient DownloadString — remote script execution | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*Invoke-Expression*" OR ScriptBlockText="*iex*")
(ScriptBlockText="*DownloadString*" OR ScriptBlockText="*WebClient*" OR ScriptBlockText="*Net.WebClient*")
| eval rule_id="SP-100003", mitre_technique="T1059.001", mitre_tactic="Execution", severity="HIGH", confidence=78
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

