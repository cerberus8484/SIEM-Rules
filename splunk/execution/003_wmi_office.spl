(ScriptBlockText="*Win32_Process*" OR ScriptBlockText="*Create*")
| eval rule_id="SP-100064", mitre_technique="T1047", mitre_tactic="Execution", severity="HIGH", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

