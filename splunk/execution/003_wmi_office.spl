`comment("
============================================================
HuntingThreats — Splunk SPL Hunt Rules
Category  : Execution — WMI & Office Macros (T1047, T1059.005)
Batch     : 3 / Execution
Rules     : SP-100061 – SP-100100
Platform  : Splunk Enterprise 8.0+ / Splunk Cloud
Sources   : Sysmon Event 1/11/13/19-22, Windows Event 4688
============================================================
")`

`comment("SP-100061 | T1047 | WMI: Process creation via wmiprvse.exe parent — lateral exec | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=1
ParentImage="*\\WmiPrvSE.exe"
(Image="*\\cmd.exe" OR Image="*\\powershell.exe" OR Image="*\\wscript.exe" OR Image="*\\cscript.exe" OR Image="*\\mshta.exe")
| eval rule_id="SP-100061", mitre_technique="T1047", mitre_tactic="Execution", severity="HIGH", confidence="HIGH"
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-100062 | T1546.003 | WMI: Event subscription creation — persistent backdoor | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=19 OR EventCode=20 OR EventCode=21
| eval rule_id="SP-100062", mitre_technique="T1546.003", mitre_tactic="Persistence", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, Name, Query, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-100063 | T1047 | WMI: /node: remote process execution — lateral movement | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\wmic.exe" OR NewProcessName="*\\wmic.exe")
CommandLine="*/node:*"
(CommandLine="*process call create*" OR CommandLine="*os get*" OR CommandLine="*computersystem*")
NOT CommandLine="*/node:localhost*"
| eval rule_id="SP-100063", mitre_technique="T1047", mitre_tactic="Lateral Movement", severity="HIGH", confidence="HIGH"
| table _time, host, user, ParentImage, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-100064 | T1047 | WMI: PowerShell Invoke-WmiMethod Win32_Process — remote exec | Severity: HIGH | Confidence: HIGH")`
