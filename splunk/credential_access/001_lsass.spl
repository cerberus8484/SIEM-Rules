index=windows EventCode=4104
(ScriptBlockText="*DCSync*" OR ScriptBlockText="*Invoke-DCsync*" OR ScriptBlockText="*Get-ADReplAccount*" OR ScriptBlockText="*DS-Replication-Get-Changes*")
