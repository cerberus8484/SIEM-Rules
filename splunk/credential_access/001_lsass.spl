`comment("SP-103022 | T1056.001 | Keylogger: GetAsyncKeyState / SetWindowsHookEx API in script | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4104
(ScriptBlockText="*GetAsyncKeyState*" OR ScriptBlockText="*SetWindowsHookEx*" OR ScriptBlockText="*keylogger*" OR ScriptBlockText="*GetKeyState*")
| eval rule_id="SP-103022", mitre_technique="T1056.001", mitre_tactic="Credential Access", severity="HIGH", confidence="HIGH"
| table _time, host, user, ScriptBlockText, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103023 | T1003.001 | LSASS: Access from unsigned binary — elevated access | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=10
TargetImage="*\\lsass.exe"
Signed="false"
NOT (SourceImage="*\\svchost.exe" OR SourceImage="*\\csrss.exe" OR SourceImage="*\\werfault.exe")
| eval rule_id="SP-103023", mitre_technique="T1003.001", mitre_tactic="Credential Access", severity="HIGH", confidence="HIGH"
| table _time, host, SourceImage, TargetImage, GrantedAccess, Signed, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103024 | T1552.001 | Credentials in files: findstr for password in common locations | Severity: MEDIUM | Confidence: MEDIUM")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\findstr.exe" OR NewProcessName="*\\findstr.exe")
(CommandLine="*password*" OR CommandLine="*passwd*" OR CommandLine="*cred*" OR CommandLine="*secret*")
| eval rule_id="SP-103024", mitre_technique="T1552.001", mitre_tactic="Credential Access", severity="MEDIUM", confidence="MEDIUM"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103025 | T1552.002 | Credentials in registry: reg query for password/autologon | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\reg.exe" OR NewProcessName="*\\reg.exe")
CommandLine="*query*"
(CommandLine="*DefaultPassword*" OR CommandLine="*Autologon*" OR CommandLine="*autologon*" OR CommandLine="*winlogon*password*")
| eval rule_id="SP-103025", mitre_technique="T1552.002", mitre_tactic="Credential Access", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103026 | T1558.001 | Golden Ticket: Kerberos 4768 with RC4 encryption type | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=4768
TicketEncryptionType="0x17"
NOT AccountName="*$*"
| eval rule_id="SP-103026", mitre_technique="T1558.001", mitre_tactic="Credential Access", severity="HIGH", confidence="MEDIUM"
| table _time, host, AccountName, ServiceName, TicketEncryptionType, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103027 | T1558.002 | Silver Ticket: Kerberos 4769 unusual service name + RC4 | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=4769
TicketEncryptionType="0x17"
NOT (ServiceName="krbtgt" OR ServiceName="*$")
| eval rule_id="SP-103027", mitre_technique="T1558.002", mitre_tactic="Credential Access", severity="HIGH", confidence="MEDIUM"
| table _time, host, AccountName, ServiceName, TicketEncryptionType, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103028 | T1003.001 | Pypykatz/Impacket: Python accessing LSASS | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=10
TargetImage="*\\lsass.exe"
(SourceImage="*\\python*" OR SourceImage="*\\python3*" OR SourceImage="*\\py.exe*")
| eval rule_id="SP-103028", mitre_technique="T1003.001", mitre_tactic="Credential Access", severity="CRITICAL", confidence="HIGH"
| table _time, host, SourceImage, TargetImage, GrantedAccess, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103029 | T1003.001 | Logon: Explicit credential use after failed logon — pass the hash | Severity: HIGH | Confidence: MEDIUM")`
index=windows EventCode=4648
NOT (TargetServerName="localhost" OR TargetServerName="127.0.0.1")
NOT SubjectUserName="*$*"
| bin _time span=10m
| stats count as ExplicitLogons by _time, host, SubjectUserName
| where ExplicitLogons > 5
| eval rule_id="SP-103029", mitre_technique="T1003.001", mitre_tactic="Lateral Movement", severity="HIGH", confidence="MEDIUM"
| table _time, host, SubjectUserName, ExplicitLogons, rule_id, severity
| sort -_time

`comment("SP-103030 | T1110.001 | RDP brute force: >15 failed logon type 10 events | Severity: HIGH | Confidence: HIGH")`
index=windows EventCode=4625
LogonType=10
| bin _time span=5m
| stats count as FailCount by _time, host
| where FailCount > 15
| eval rule_id="SP-103030", mitre_technique="T1110.001", mitre_tactic="Credential Access", severity="HIGH", confidence="HIGH"
| table _time, host, FailCount, rule_id, severity
| sort -_time

`comment("SP-103031 | T1555.003 | Credential Manager: rundll32 keymgr.dll — credential manager dump | Severity: HIGH | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688)
(Image="*\\rundll32.exe" OR NewProcessName="*\\rundll32.exe")
(CommandLine="*keymgr.dll*" OR CommandLine="*KRShowKeyMgr*")
| eval rule_id="SP-103031", mitre_technique="T1555.003", mitre_tactic="Credential Access", severity="HIGH", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103032 | T1003.001 | LSASS: Squiblydoo calls lsass — indirect access via regsvr32 | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=10
TargetImage="*\\lsass.exe"
SourceImage="*\\regsvr32.exe"
| eval rule_id="SP-103032", mitre_technique="T1003.001", mitre_tactic="Credential Access", severity="CRITICAL", confidence="HIGH"
| table _time, host, SourceImage, TargetImage, GrantedAccess, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103033 | T1003.002 | SAM: secretsdump or SAM hive copy pattern | Severity: CRITICAL | Confidence: HIGH")`
index=windows (EventCode=1 OR EventCode=4688 OR EventCode=4104)
(CommandLine="*secretsdump*" OR ScriptBlockText="*secretsdump*" OR CommandLine="*SAMDump*" OR CommandLine="*samdump2*")
| eval rule_id="SP-103033", mitre_technique="T1003.002", mitre_tactic="Credential Access", severity="CRITICAL", confidence="HIGH"
| table _time, host, user, Image, CommandLine, rule_id, mitre_technique, severity
| sort -_time

`comment("SP-103034 | T1003.001 | LSASS: High-frequency access from single source >3 in 1 minute | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=10
TargetImage="*\\lsass.exe"
| bin _time span=1m
| stats count as AccessCount by _time, host, SourceImage
| where AccessCount > 3
| eval rule_id="SP-103034", mitre_technique="T1003.001", mitre_tactic="Credential Access", severity="CRITICAL", confidence="HIGH"
| table _time, host, SourceImage, AccessCount, rule_id, severity
| sort -_time

`comment("SP-103035 | T1556.001 | LSA: Custom SSP DLL registered — credential interception | Severity: CRITICAL | Confidence: HIGH")`
index=windows EventCode=13
TargetObject="*\\LSA\\Security Packages*"
NOT (Details="*kerberos*" OR Details="*msv1_0*" OR Details="*wdigest*" OR Details="*pku2u*" OR Details="*tspkg*" OR Details="*livessp*" OR Details="*cloudap*")
| eval rule_id="SP-103035", mitre_technique="T1556.001", mitre_tactic="Credential Access", severity="CRITICAL", confidence="HIGH"
| table _time, host, Image, TargetObject, Details, rule_id, mitre_technique, severity
| sort -_time
