    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\schtasks\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\/create\s+.*\/tr\s+.*(powershell|cmd|wscript|mshta|rundll32)</field>
    <description>schtasks.exe: scheduled task with script interpreter — persistence via scheduled task (T1053.005)</description>
    <mitre><id>T1053.005</id></mitre>
    <group>persistence,scheduled_task,high_confidence,</group>
  </rule>

