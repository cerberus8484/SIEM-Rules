<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Execution — LOLBins / Living-Off-the-Land Binaries (T1218)
  Batch:     1 / Execution
  Rules:     100026 – 100060
  Platform:  Wazuh 4.x
  Sources:   Sysmon Event 1 (Process Creation)
             Sysmon Event 3 (Network Connection)
             Windows Event 4688 (Process Creation)

  LOLBins = Legitimate binaries abused for malicious execution.
  Each rule targets a specific binary + specific abuse pattern.
  FP rate is kept low by matching on the specific flags/arguments used in attacks.

  References:
    https://lolbas-project.github.io/
    MITRE ATT&CK T1218.* (System Binary Proxy Execution)
-->

<group name="hunt_execution,lolbins,windows,">

  <!-- ── certutil.exe — download & decode ─────────────────────────────────── -->

  <rule id="100026" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\certutil\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(-urlcache|-decode|-decodehex)</field>
    <description>certutil.exe: LOLBin abuse — urlcache/decode used for file download or decode (T1105, T1140)</description>
    <mitre><id>T1105</id><id>T1140</id></mitre>
    <group>lolbin,download,high_confidence,</group>
  </rule>

