    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\(ipconfig|arp|route)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript|cscript)</field>
    <description>Network tool: IP/ARP/route info collected from script — network configuration discovery (T1016)</description>
    <mitre><id>T1016</id></mitre>
    <group>discovery,network_info,</group>
  </rule>

  <!-- ── nslookup / Resolve-DnsName (internal DNS recon) ─────────────────── -->

