<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Discovery — System & Network Enumeration (T1082, T1016, T1018, T1083)
  Batch:     1 / Discovery
  Rules:     106001 – 106035
  Platform:  Wazuh 4.x
  Sources:   Sysmon Event 1 (Process Creation)
             Windows Event 4688 (Process Creation)
             Sysmon Event 22 (DNS Query)

  T1082  — System Information Discovery
  T1016  — System Network Configuration Discovery
  T1018  — Remote System Discovery
  T1083  — File and Directory Discovery
  T1135  — Network Share Discovery
  T1087  — Account Discovery
  T1069  — Permission Groups Discovery
  T1033  — System Owner / User Discovery
  T1057  — Process Discovery
  T1049  — System Network Connections Discovery
-->

<group name="hunt_discovery,enumeration,windows,">

  <!-- ── systeminfo — comprehensive system discovery ───────────────────────── -->

  <rule id="106001" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\systeminfo\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript|cscript|python|java)</field>
    <description>systeminfo.exe: system information gathered by script — attacker host reconnaissance (T1082)</description>
    <mitre><id>T1082</id></mitre>
    <group>discovery,systeminfo,</group>
  </rule>

  <!-- ── whoami with all flags ──────────────────────────────────────────────── -->

  <rule id="106002" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\whoami\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(/all|/groups|/priv|/user)</field>
    <description>whoami.exe: detailed user/group/privilege info gathered — post-exploitation context discovery (T1033)</description>
    <mitre><id>T1033</id></mitre>
    <group>discovery,whoami,</group>
  </rule>

  <!-- ── ipconfig / ip route / arp ─────────────────────────────────────────── -->

  <rule id="106003" level="6">
