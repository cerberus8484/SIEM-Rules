    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript)</field>
    <description>netstat.exe: active connections and listening ports enumerated — network state discovery (T1049)</description>
    <mitre><id>T1049</id></mitre>
    <group>discovery,netstat,</group>
