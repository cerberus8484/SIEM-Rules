    <mitre><id>T1562.001</id></mitre>
    <group>initial_access,macro_enable,high_confidence,</group>
  </rule>

  <!-- ── PDF JavaScript execution via Acrobat ──────────────────────────────── -->

  <rule id="110022" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript|mshta)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(AcroRd32|Acrobat|FoxitReader|SumatraPDF)\.exe$</field>
