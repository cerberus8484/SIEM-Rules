    <mitre><id>T1056.003</id></mitre>
    <group>initial_access,credential_phishing,web_root,high_confidence,</group>
  </rule>

  <!-- ── Supply chain: installer from unknown source ───────────────────────── -->

  <rule id="110017" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\msiexec\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\/i\s+(http[s]?://|\\\\[0-9]|[D-Z]:\\)</field>
    <description>msiexec.exe: MSI installed from non-C drive or network — untrusted installer source (T1195.002)</description>
    <mitre><id>T1195.002</id></mitre>
    <group>initial_access,supply_chain,msi_install,high_confidence,</group>
  </rule>

  <!-- ── Typosquatted domain connection ────────────────────────────────────── -->

  <rule id="110018" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^22$</field>
    <field name="win.eventdata.queryName" type="pcre2">(?i)(micros0ft|rnicrosoft|microsofft|apple-inc|googIe|paypa1|arnazon|faceb00k|linkedln)</field>
    <description>Sysmon DNS: typosquatted brand domain queried — possible phishing site or malware C2 (T1566.002)</description>
    <mitre><id>T1566.002</id></mitre>
    <group>initial_access,typosquatting,phishing,high_confidence,</group>
  </rule>

  <!-- ── Recently created Office file opened from internet ─────────────────── -->

  <rule id="110019" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(WINWORD|EXCEL|POWERPNT)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell)\.exe$</field>
    <description>Sysmon: Office spawning shell — suspicious document opened, macro executing payload (T1204.002)</description>
    <mitre><id>T1204.002</id></mitre>
    <group>initial_access,office_macro,shell,high_confidence,</group>
  </rule>

  <!-- ── MS Office Protected View bypass (registry) ────────────────────────── -->

  <rule id="110020" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Microsoft\\Office\\.*\\Protected View\\.*(Enable|Disable|Trusted)</field>
    <description>Sysmon: Office Protected View disabled via registry — reducing security for macro execution (T1562.001)</description>
    <mitre><id>T1562.001</id></mitre>
    <group>initial_access,protected_view_bypass,high_confidence,</group>
  </rule>

  <!-- ── Office macro setting enabled via registry ─────────────────────────── -->

  <rule id="110021" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Microsoft\\Office\\.*\\Security\\VBAWarnings</field>
    <field name="win.eventdata.details" type="pcre2">^1$|DWORD.*1</field>
