  <!-- ── HTM/HTML weaponized redirect ──────────────────────────────────────── -->

  <rule id="110034" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(\\Downloads\\|\\Temp\\|\\Desktop\\).*(invoice|payment|document|receipt|order|delivery).*\.(html|htm)$</field>
    <description>Sysmon: social-engineering HTML file downloaded — phishing HTML redirect/credential page (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,html_lure,</group>
  </rule>

  <!-- ── Adversary-in-the-middle proxy indicators ───────────────────────────── -->

  <rule id="110035" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Internet Settings\\.*(ProxyServer|ProxyEnable|AutoConfigURL)</field>
    <description>Sysmon: browser proxy settings changed — AiTM proxy injection for credential theft (T1557.002)</description>
    <mitre><id>T1557.002</id></mitre>
    <group>initial_access,proxy_change,aitm,high_confidence,</group>
  </rule>

  <!-- ── SSH key drop from unknown source ──────────────────────────────────── -->

  <rule id="110036" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\\.ssh\\authorized_keys$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(?!.*\\(ssh|putty|pageant|winscp|openssh)\.exe)</field>
    <description>Sysmon: authorized_keys written by non-SSH process — SSH persistence after initial compromise (T1098.004)</description>
    <mitre><id>T1098.004</id></mitre>
    <group>initial_access,ssh_key_add,high_confidence,</group>
  </rule>

  <!-- ── Shodan/Censys-indexed service responding anomalously ──────────────── -->

  <rule id="110037" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(tomcat|catalina|glassfish|jboss|websphere|weblogic).*\.exe$</field>
    <description>Sysmon: shell spawned by Java application server — Java deserialization or RCE exploit (T1190)</description>
    <mitre><id>T1190</id></mitre>
    <group>initial_access,java_exploit,rce,critical,</group>
  </rule>

  <!-- ── OneNote .one file with embedded script ────────────────────────────── -->

  <rule id="110038" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(\\Downloads\\|\\Temp\\|\\Desktop\\).*\.one$</field>
    <description>Sysmon: OneNote file downloaded — OneNote-based phishing with embedded executable (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,onenote,high_confidence,</group>
  </rule>

  <!-- ── VBA stomping (macro without visible code) ─────────────────────────── -->

  <rule id="110039" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\WINWORD\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(?!.*\/c\s+echo)</field>
    <description>Sysmon: cmd/PS spawned by Word without visible macro code — possible VBA stomping technique (T1204.002)</description>
    <mitre><id>T1204.002</id></mitre>
    <group>initial_access,vba_stomp,word,critical,</group>
  </rule>

  <!-- ── Excel XLSB (binary) with macro ────────────────────────────────────── -->

  <rule id="110040" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(\\Downloads\\|\\Temp\\|\\Desktop\\).*\.xlsb$</field>
    <description>Sysmon: Excel binary format file downloaded — XLSB harder to inspect than XLSM for macros (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,xlsb,</group>
  </rule>

</group>
