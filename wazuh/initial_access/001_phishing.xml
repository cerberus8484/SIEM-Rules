  <!-- ── Exploitation: Exchange/IIS spawning process ───────────────────────── -->

  <rule id="110030" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(MSExchangeOWAAppPool|MSExchangeECPAppPool|UMWorkerProcess|w3wp)\.exe$</field>
