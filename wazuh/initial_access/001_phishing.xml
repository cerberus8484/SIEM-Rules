    <mitre><id>T1553.005</id></mitre>
    <group>initial_access,disk_mount,phishing,high_confidence,</group>
  </rule>

  <!-- ── Office file executed directly from email temp ─────────────────────── -->

  <rule id="110027" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\\AppData\\Local\\Microsoft\\Windows\\(INetCache|Temporary Internet Files)\\.*\.(doc|xls|pdf|exe)</field>
    <description>Sysmon: file executed from IE/Edge cache — document or EXE opened from phishing link (T1204.001)</description>
    <mitre><id>T1204.001</id></mitre>
    <group>initial_access,phishing,ie_cache,high_confidence,</group>
