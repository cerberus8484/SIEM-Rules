    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)(\\Downloads\\|\\Temp\\|\\Desktop\\).*\.(iso|img|vhd|vhdx)$</field>
    <description>Sysmon: disk image downloaded — phishing via ISO/VHD to bypass MOTW (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,iso_file,high_confidence,</group>
