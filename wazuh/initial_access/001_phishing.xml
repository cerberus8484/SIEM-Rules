    <mitre><id>T1204.002</id></mitre>
    <group>initial_access,pdf_malware,critical,</group>
  </rule>

  <!-- ── Cobalt Strike phishing link (mailto: shell spawn) ─────────────────── -->

  <rule id="110023" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(chrome|msedge|firefox|iexplore)\.exe$</field>
