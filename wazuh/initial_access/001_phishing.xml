  <!-- ── VPN / remote access account compromise ─────────────────────────────── -->

  <rule id="110031" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4625$</field>
    <field name="win.eventdata.logonType" type="pcre2">^3$|^10$</field>
    <field name="win.eventdata.ipAddress" type="pcre2">(?!^10\.|^192\.168\.|^172\.(1[6-9]|2[0-9]|3[0-1])\.|^127\.)</field>
    <frequency>5</frequency>
    <timeframe>60</timeframe>
    <description>Windows Security: 5+ failed external logon attempts in 60s — credential stuffing or brute force (T1078)</description>
    <mitre><id>T1078</id></mitre>
    <group>initial_access,brute_force,credential_stuffing,high_confidence,</group>
  </rule>

  <!-- ── Successful logon after multiple failures (same source) ────────────── -->

  <rule id="110032" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4624$</field>
    <field name="win.eventdata.logonType" type="pcre2">^3$</field>
    <field name="win.eventdata.ipAddress" type="pcre2">(?!^10\.|^192\.168\.|^172\.(1[6-9]|2[0-9]|3[0-1])\.|^127\.)</field>
