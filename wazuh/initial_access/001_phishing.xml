    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,macro_doc,</group>
  </rule>

  <!-- ── User opened Office doc from internet (Mark of the Web 3) ──────────── -->

  <rule id="110012" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\.(doc|docx|xls|xlsx|ppt|pptx|pdf|rtf):Zone\.Identifier$</field>
