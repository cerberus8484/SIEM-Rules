  <!-- ── MarkOfTheWeb bypass via renaming ──────────────────────────────────── -->

  <rule id="110028" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(copy|move|ren|rename).*(Downloads|Temp|Desktop).*(exe|dll|js|vbs|hta)</field>
