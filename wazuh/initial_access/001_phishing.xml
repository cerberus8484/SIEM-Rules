  <!-- ── Exploitation of public-facing app — IIS/Apache spawn ─────────────── -->

  <rule id="110013" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(w3wp|httpd|nginx|tomcat|catalina|java)\.exe$</field>
