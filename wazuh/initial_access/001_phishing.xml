<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Initial Access — Phishing & Drive-by (T1566, T1190, T1189)
  Batch:     1 / Initial Access
  Rules:     110001 – 110040
  Platform:  Wazuh 4.x
  Sources:   Sysmon Event 1 (Process Creation)
             Sysmon Event 11 (File Create — email attachment dropped)
             Sysmon Event 3 (Network Connection)
             Windows Event 4688 (Process Creation)

  T1566.001 — Phishing: Spearphishing Attachment
  T1566.002 — Phishing: Spearphishing Link
  T1204.001 — User Execution: Malicious Link
  T1204.002 — User Execution: Malicious File
  T1190     — Exploit Public-Facing Application
  T1189     — Drive-by Compromise
-->

<group name="hunt_initial_access,phishing,windows,">

  <!-- ── Executable opened from email client ───────────────────────────────── -->

  <rule id="110001" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\.(exe|dll|scr|pif|com)$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\\Users\\.*\\AppData\\Local\\Temp\\.*|Outlook.*\\Content\\.OLK)</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(OUTLOOK|thunderbird|eM Client|mailspring)\.exe$</field>
    <description>Sysmon: executable spawned from email client — phishing attachment execution (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,attachment,critical,</group>
  </rule>

  <!-- ── Outlook temp folder script execution ──────────────────────────────── -->

  <rule id="110002" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\\Content\.Outlook\\[A-Z0-9]{8}\\.*\.(exe|vbs|js|hta|ps1|bat|cmd|lnk)$</field>
    <description>Sysmon: file executed from Outlook Content temp cache — email attachment clicked (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,outlook_temp,critical,</group>
  </rule>

  <!-- ── LNK file execution from Downloads or email ────────────────────────── -->

  <rule id="110003" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript|mshta)\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(\\Downloads\\|\\Temp\\|\\Desktop\\).*\.lnk</field>
    <description>Sysmon: LNK shortcut executed from download path — weaponized LNK phishing (T1204.002)</description>
    <mitre><id>T1204.002</id></mitre>
    <group>initial_access,lnk,phishing,critical,</group>
  </rule>

  <!-- ── ISO / IMG mount + execution ───────────────────────────────────────── -->

  <rule id="110004" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)[D-Z]:\\.*\.(exe|dll|lnk|bat|vbs|js|hta)$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(explorer|cmd|powershell)\.exe$</field>
    <description>Sysmon: process executed from non-C drive — possible ISO/IMG-mounted malware (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,iso_mount,phishing,high_confidence,</group>
  </rule>

  <!-- ── ZIP attachment extraction + execution ─────────────────────────────── -->

  <rule id="110005" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(Downloads|Temp|Desktop)\\.*\.(exe|dll|vbs|js|hta|bat|ps1)$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(7z|winrar|winzip|explorer)\.exe$</field>
    <description>Sysmon: executable extracted from archive to staging path — phishing zip execution (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,zip_extract,high_confidence,</group>
  </rule>

  <!-- ── Browser download + immediate execution ────────────────────────────── -->

  <rule id="110006" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\Downloads\\.*\.(exe|msi|dll|js|vbs|ps1|bat|hta|wsf|lnk)$</field>
    <description>Sysmon: executable downloaded to Downloads folder — potentially malicious browser download (T1204.001)</description>
    <mitre><id>T1204.001</id></mitre>
    <group>initial_access,browser_download,</group>
  </rule>

  <!-- ── Zone.Identifier bypass (ADS deletion for MOTW removal) ────────────── -->

  <rule id="110007" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(attrib\s+.*:Zone\.Identifier|streams\.exe.*-d|Remove-Item.*Zone\.Identifier|[Ss]tream.*Zone)</field>
    <description>Command: Zone Identifier (Mark of the Web) removed — bypassing MOTW security warning (T1553.005)</description>
    <mitre><id>T1553.005</id></mitre>
    <group>initial_access,motw_bypass,high_confidence,</group>
  </rule>

  <!-- ── PowerShell downloading from email-like domain ────────────────────── -->

  <rule id="110008" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(downloadstring|downloadfile|invoke-webrequest|curl|wget).*(\.xyz|\.top|\.site|\.online|\.click|\.work|\.gdn|\.date|\.download|\.stream)</field>
    <description>PowerShell: download from suspicious TLD — phishing payload download from typosquat domain (T1566.002)</description>
    <mitre><id>T1566.002</id></mitre>
    <group>initial_access,phishing,suspicious_tld,high_confidence,</group>
  </rule>

  <!-- ── Browser spawning cmd after navigation ─────────────────────────────── -->

  <rule id="110009" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript|mshta)\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(chrome|firefox|msedge|iexplore|opera|brave|vivaldi)\.exe$</field>
    <description>Sysmon: script engine spawned by browser — drive-by exploit or malicious web page (T1189)</description>
    <mitre><id>T1189</id></mitre>
    <group>initial_access,drive_by,browser,critical,</group>
  </rule>

  <!-- ── ZIP password-protected attachment hint ────────────────────────────── -->

  <rule id="110010" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(Downloads|Temp|Desktop)\\.*password.*\.(zip|rar|7z)|.*invoice.*\.(zip|rar|7z)</field>
    <description>Sysmon: password-protected or invoice-named archive downloaded — phishing social engineering lure (T1566.001)</description>
    <mitre><id>T1566.001</id></mitre>
    <group>initial_access,phishing,password_zip,</group>
  </rule>

  <!-- ── Macro-enabled document opened from temp ───────────────────────────── -->

  <rule id="110011" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
