    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(Diskpart.*attach|Mount-DiskImage|Attach-VHD).*\.(vhd|vhdx|iso|img)$</field>
