    <mitre><id>T1553.005</id></mitre>
    <group>initial_access,motw_bypass,copy,</group>
  </rule>

  <!-- ── MSDT / Follina exploit (CVE-2022-30190) ────────────────────────────── -->

  <rule id="110029" level="14">
    <if_group>windows</if_group>
