    <mitre><id>T1078</id></mitre>
    <group>initial_access,external_logon,valid_accounts,</group>
  </rule>

  <!-- ── LSASS/SAM file in email temp folder ───────────────────────────────── -->

  <rule id="110033" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(Downloads|Temp|Desktop|AppData)\\.*lsass.*\.(dmp|bin|zip|rar)$</field>
    <description>Sysmon: LSASS dump file in user staging path — downloaded credential dump (T1003.001)</description>
    <mitre><id>T1003.001</id></mitre>
    <group>initial_access,credential_dump,download,critical,</group>
