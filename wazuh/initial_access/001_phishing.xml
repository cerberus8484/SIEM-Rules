    <mitre><id>T1505.003</id></mitre>
    <group>initial_access,web_shell,file_drop,critical,</group>
  </rule>

  <!-- ── w3wp.exe loading unsigned DLL ─────────────────────────────────────── -->

  <rule id="110015" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\w3wp\.exe$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)(\\temp\\|\\appdata\\|\\inetpub\\).*\.dll$</field>
    <description>Sysmon: IIS w3wp loading unsigned DLL from staging path — IIS module web shell (T1505.004)</description>
    <mitre><id>T1505.004</id></mitre>
    <group>initial_access,web_shell,iis_module,critical,</group>
  </rule>

  <!-- ── Credential phishing page creation ─────────────────────────────────── -->

  <rule id="110016" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(inetpub|wwwroot)\\.*login.*\.(html|php|asp)$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(?!.*\\(devenv|notepad|code|sublime|atom)\.exe)</field>
