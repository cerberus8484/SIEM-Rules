    <mitre><id>T1190</id></mitre>
    <group>initial_access,web_shell,server_exploit,critical,</group>
  </rule>

  <!-- ── Web shell file creation in web root ───────────────────────────────── -->

  <rule id="110014" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\(inetpub|wwwroot|htdocs|webroot|www|public_html|web)\\.*\.(php|asp|aspx|jsp|cfm|shtml)$</field>
