<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Defense Evasion — Process Injection & Hollowing (T1055)
  Batch:     1 / Defense Evasion
  Rules:     102001 – 102035
  Platform:  Wazuh 4.x
  Sources:   Sysmon Event 8 (CreateRemoteThread)
             Sysmon Event 10 (Process Access — inject prep)
             Sysmon Event 25 (Process Tamper — hollowing)
             Sysmon Event 7 (Image Load — injected DLL)
             Sysmon Event 1 (Process Creation — injection tools)

  T1055     — Process Injection
  T1055.001 — DLL Injection
  T1055.002 — Portable Executable Injection
  T1055.003 — Thread Execution Hijacking
  T1055.011 — Extra Window Memory Injection
  T1055.012 — Process Hollowing
  T1055.013 — Process Doppelgänging
  T1620     — Reflective Code Loading
-->

<group name="hunt_defense_evasion,process_injection,windows,">

  <!-- ── Sysmon 8: CreateRemoteThread ──────────────────────────────────────── -->

  <rule id="102001" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^8$</field>
    <description>Sysmon: CreateRemoteThread detected — thread injected into remote process (T1055.003)</description>
    <mitre><id>T1055.003</id></mitre>
    <group>defense_evasion,process_injection,remote_thread,</group>
  </rule>

  <!-- ── CreateRemoteThread into lsass ─────────────────────────────────────── -->

  <rule id="102002" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^8$</field>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\lsass\.exe$</field>
    <description>Sysmon: remote thread injected into LSASS — LSASS injection for credential access (T1055.003)</description>
    <mitre><id>T1055.003</id></mitre>
    <group>defense_evasion,process_injection,lsass,critical,</group>
  </rule>

  <!-- ── CreateRemoteThread into browser / Office process ─────────────────── -->

  <rule id="102003" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^8$</field>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)(\\(chrome|firefox|msedge|iexplore|WINWORD|EXCEL|POWERPNT)\.exe$)</field>
    <description>Sysmon: remote thread injected into browser/Office process — code injection for credential theft or evasion (T1055)</description>
    <mitre><id>T1055</id></mitre>
    <group>defense_evasion,process_injection,browser,high_confidence,</group>
  </rule>

  <!-- ── CreateRemoteThread from user-path process ─────────────────────────── -->

  <rule id="102004" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^8$</field>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\downloads\\|\\public\\)</field>
    <description>Sysmon: process from user-writable path created remote thread — dropped malware injecting code (T1055.003)</description>
    <mitre><id>T1055.003</id></mitre>
    <group>defense_evasion,process_injection,suspicious_source,critical,</group>
  </rule>

  <!-- ── Sysmon 25: Process Tamper (hollowing) ─────────────────────────────── -->

  <rule id="102005" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^25$</field>
    <description>Sysmon: process image tampered — process hollowing or doppelgänging detected (T1055.012)</description>
    <mitre><id>T1055.012</id></mitre>
    <group>defense_evasion,process_hollowing,critical,</group>
  </rule>

  <!-- ── Mavinject DLL injection ────────────────────────────────────────────── -->

  <rule id="102006" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\mavinject\.exe$</field>
    <description>mavinject.exe: Microsoft signed DLL injector invoked — LOLBin DLL injection (T1055.001)</description>
    <mitre><id>T1055.001</id></mitre>
    <group>defense_evasion,process_injection,mavinject,critical,</group>
  </rule>

  <!-- ── VirtualAllocEx + WriteProcessMemory (PS reflection pattern) ─────────── -->

  <rule id="102007" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(VirtualAllocEx|WriteProcessMemory|CreateRemoteThread|NtCreateThreadEx|RtlCreateUserThread)</field>
    <description>PowerShell: process injection API calls in script block — PS-based injection technique (T1055)</description>
    <mitre><id>T1055</id></mitre>
    <group>defense_evasion,process_injection,powershell,high_confidence,</group>
  </rule>

  <!-- ── Shellcode injection via PS (byte array + pointer) ────────────────── -->

  <rule id="102008" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(0x[0-9a-fA-F]{2},\s*){16,}|shellcode|[Bb]yte\[\]\s*\$[a-zA-Z]+\s*=\s*@\(0x</field>
    <description>PowerShell: shellcode byte array in script block — shellcode injection preparation (T1055.002)</description>
    <mitre><id>T1055.002</id></mitre>
    <group>defense_evasion,shellcode,critical,</group>
  </rule>

  <!-- ── Reflective DLL loading (PowerShell) ───────────────────────────────── -->

  <rule id="102009" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(Invoke-ReflectivePEInjection|Invoke-Shellcode|Invoke-DllInjection|ReflectiveDLL|reflective_loader)</field>
    <description>PowerShell: reflective PE/DLL injection function invoked (T1620)</description>
    <mitre><id>T1620</id></mitre>
    <group>defense_evasion,reflective_injection,critical,</group>
  </rule>

  <!-- ── Assembly.Load (C# execution in PS context) ────────────────────────── -->

  <rule id="102010" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)\[Reflection\.Assembly\]::Load|Assembly::Load\(|[Ss]ystem\.Reflection\.Assembly.*Load</field>
    <description>PowerShell: .NET assembly loaded via reflection — in-memory .NET execution (T1620)</description>
    <mitre><id>T1620</id></mitre>
    <group>defense_evasion,reflective_injection,assembly_load,high_confidence,</group>
  </rule>

  <!-- ── APC Queue injection (NtQueueApcThread) ────────────────────────────── -->

  <rule id="102011" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(NtQueueApcThread|QueueUserAPC|NtQueueApcThreadEx)</field>
