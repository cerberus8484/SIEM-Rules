  <!-- ── Process hollowing indicators (Sysmon 10 + 8 correlation) ──────────── -->

  <rule id="102012" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^10$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1f3fff|0x1f0fff|0x001f1fff</field>
    <field name="win.eventdata.targetImage" type="pcre2">(?i)\\(svchost|dllhost|taskhost|rundll32|msiexec|wuauclt)\.exe$</field>
