    <mitre><id>T1055.012</id></mitre>
    <group>defense_evasion,process_hollowing,high_confidence,</group>
  </rule>

  <!-- ── DLL side-loading (unsigned DLL in application path) ──────────────── -->

  <rule id="102013" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)\\(Program Files|Program Files \(x86\))\\.*\.dll$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(?!.*\\(svchost|MsMpEng|NisSrv|msiexec)\.exe)</field>
    <description>Sysmon: unsigned DLL loaded from application directory — DLL side-loading or hijacking (T1574.002)</description>
    <mitre><id>T1574.002</id></mitre>
    <group>defense_evasion,dll_sideloading,high_confidence,</group>
  </rule>

  <!-- ── Unsigned DLL loaded from user-writable path ────────────────────────── -->

