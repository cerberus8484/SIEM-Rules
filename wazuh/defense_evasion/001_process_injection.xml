  <rule id="102025" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^10$</field>
    <field name="win.eventdata.grantedAccess" type="pcre2">0x1f3fff|0x1f0fff</field>
    <field name="win.eventdata.sourceImage" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\downloads\\|\\public\\)</field>
