<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Persistence — Windows Services (T1543.003)
  Batch:     1 / Persistence
  Rules:     101056 – 101080
  Platform:  Wazuh 4.x
  Sources:   Windows Event 7045 (new service installed — System log)
             Windows Event 7040 (service start type changed)
             Sysmon Event 1 (sc.exe / service control)
             Windows Event 4688 (service binary execution)

  T1543.003 — Create or Modify System Process: Windows Service
  T1569.002 — System Services: Service Execution
  T1562.001 — Impair Defenses: Disable or Modify Tools
-->

<group name="hunt_persistence,service,windows,">

  <!-- ── New service installed (Event 7045) ───────────────────────────────── -->

  <rule id="101056" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <description>System: new Windows service installed (Event 7045) — verify service binary origin (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,event_7045,</group>
  </rule>

  <!-- ── New service — binary in user-writable path ───────────────────────── -->

  <rule id="101057" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\downloads\\|\\users\\public\\|\\programdata\\[^W])</field>
    <description>System: service binary installed in user-writable directory — high-risk persistence (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,suspicious_path,critical,</group>
  </rule>

  <!-- ── New service with scripting engine as binary ──────────────────────── -->

  <rule id="101058" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)(powershell|cmd\.exe|wscript|cscript|mshta|rundll32|regsvr32)</field>
    <description>System: service binary is a script interpreter — service executes script payload (T1543.003, T1059)</description>
    <mitre><id>T1543.003</id></mitre>
    <mitre><id>T1059</id></mitre>
    <group>persistence,service,interpreter,critical,</group>
  </rule>

  <!-- ── sc.exe create with interpreter binary ────────────────────────────── -->

  <rule id="101059" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)create.*(powershell|cmd\.exe|wscript|cscript|mshta|rundll32)</field>
    <description>sc.exe: service created with scripting engine binary — persistence via service (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,sc_exe,interpreter,</group>
  </rule>

  <!-- ── sc.exe create in user-writable path ──────────────────────────────── -->

  <rule id="101060" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)create.*(\\appdata\\|\\temp\\|\\public\\|\\downloads\\)</field>
    <description>sc.exe: service created with binary in user-writable path (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,sc_exe,suspicious_path,high_confidence,</group>
  </rule>

  <!-- ── sc.exe config — modify existing service ──────────────────────────── -->

  <rule id="101061" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+config\s+.*binpath</field>
    <description>sc.exe: service binary path reconfigured — existing service hijacked for persistence (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,service_hijack,high_confidence,</group>
  </rule>

  <!-- ── sc.exe stop critical security service ────────────────────────────── -->

  <rule id="101062" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+(stop|delete|config)\s+(wuauserv|windefend|msmpeng|sense|mbamdor|avp|mcshield|ekrn|bdss|afwserv)</field>
    <description>sc.exe: security/AV/Windows Update service stopped or deleted — defense impairment (T1562.001)</description>
    <mitre><id>T1562.001</id></mitre>
    <group>defense_evasion,service,av_tamper,critical,</group>
  </rule>

  <!-- ── Service start type changed to disabled (7040) ───────────────────── -->

  <rule id="101063" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7040$</field>
    <description>System: service start type changed (Event 7040) — security service may have been disabled (T1562.001)</description>
    <mitre><id>T1562.001</id></mitre>
    <group>defense_evasion,service,start_type_change,</group>
  </rule>

  <!-- ── sc.exe delete (service removal cleanup) ──────────────────────────── -->

  <rule id="101064" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+delete\s+</field>
    <description>sc.exe: service deleted — could be attacker cleanup after compromise (T1070, T1543.003)</description>
    <mitre><id>T1070</id></mitre>
    <group>defense_evasion,service,cleanup,</group>
  </rule>

  <!-- ── sc.exe start with non-standard parent ────────────────────────────── -->

  <rule id="101065" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript|cscript|python|java|node|mshta)</field>
    <description>Sysmon: sc.exe spawned by script engine — scripted service installation (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,sc_exe,suspicious_parent,high_confidence,</group>
  </rule>

  <!-- ── Service DLL — imagePath pointing to rundll32 + DLL ──────────────── -->

  <rule id="101066" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)rundll32\.exe.*\.dll</field>
    <description>System: service binary uses rundll32 to load DLL — service DLL persistence technique (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,rundll32,high_confidence,</group>
  </rule>

  <!-- ── Service with common malware service names ─────────────────────────── -->

  <rule id="101067" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.serviceName" type="pcre2">(?i)^(svchost|svhost|svhost32|winlogon64|lsm64|crond|update|secupdate|sysupdate|winsvc|winsvc32|syssvc)$</field>
    <description>System: service with name mimicking system process — service name masquerading (T1543.003, T1036)</description>
    <mitre><id>T1036</id></mitre>
    <group>persistence,service,masquerade,high_confidence,</group>
  </rule>

  <!-- ── Fake svchost — service not in valid svchost path ─────────────────── -->

  <rule id="101068" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)svchost</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)(?!.*system32\\\\svchost)</field>
    <description>System: service image contains 'svchost' but not from System32 — svchost spoofing (T1036.005)</description>
    <mitre><id>T1036.005</id></mitre>
    <group>persistence,service,svchost_spoof,critical,</group>
  </rule>

  <!-- ── Service DLL registered via ServiceDLL value ──────────────────────── -->

  <rule id="101069" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)\\Services\\.*\\Parameters\\ServiceDll$</field>
    <description>Sysmon: ServiceDll registry value set — DLL-based service registered for svchost loading (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,servicedll,high_confidence,</group>
  </rule>

  <!-- ── PowerShell New-Service ────────────────────────────────────────────── -->

  <rule id="101070" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)New-Service|Set-Service.*BinaryPathName</field>
    <description>PowerShell: new Windows service created via PS cmdlet — programmatic service persistence (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,powershell,high_confidence,</group>
  </rule>

  <!-- ── WMI Win32_Service create ──────────────────────────────────────────── -->

  <rule id="101071" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)Win32_Service.*Create|Invoke-WmiMethod.*Service</field>
    <description>PowerShell: service created via WMI Win32_Service — WMI-based service installation (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,wmi,high_confidence,</group>
  </rule>

  <!-- ── Service binary in network share ───────────────────────────────────── -->

  <rule id="101072" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)^\\\\[0-9a-zA-Z]</field>
    <description>System: service binary path is a UNC/network path — remote service execution (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,network_path,critical,</group>
  </rule>

  <!-- ── Service installed as kernel driver ────────────────────────────────── -->

  <rule id="101073" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.serviceType" type="pcre2">(?i)kernel\s*driver|file\s*system\s*driver</field>
    <description>System: kernel driver service installed — rootkit-level persistence technique (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,kernel_driver,critical,</group>
  </rule>

  <!-- ── sc.exe qc / query (service enumeration) ───────────────────────────── -->

  <rule id="101074" level="6">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)\s+(query|qc|qdescription)\s+</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript|cscript|python)</field>
    <description>sc.exe: service query from script process — service discovery activity (T1007)</description>
    <mitre><id>T1007</id></mitre>
    <group>discovery,service,enumeration,</group>
  </rule>

  <!-- ── Service DLL without .dll extension (evasion) ─────────────────────── -->

  <rule id="101075" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)\.(dat|log|tmp|sys|ini|bin|db|cfg)\s*$</field>
    <description>System: service binary has unusual file extension — file extension masquerading (T1036.008)</description>
    <mitre><id>T1036.008</id></mitre>
    <group>persistence,service,extension_masquerade,high_confidence,</group>
  </rule>

  <!-- ── Service failure action: exec command on failure ───────────────────── -->

  <rule id="101076" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\sc\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)failure.*actions.*command|failureflag</field>
    <description>sc.exe: service failure action configured to run command — arbitrary command on service failure (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,failure_action,high_confidence,</group>
  </rule>

  <!-- ── Suspicious service Account (Local System via non-admin process) ──── -->

  <rule id="101077" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7045$</field>
    <field name="win.eventdata.accountName" type="pcre2">(?i)(localsystem|nt authority\\\\system|local service|network service)</field>
    <field name="win.eventdata.imagePath" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\public\\|\\downloads\\)</field>
    <description>System: SYSTEM-privileged service installed with binary in user path — privilege escalation via service (T1543.003, T1134)</description>
    <mitre><id>T1134</id></mitre>
    <group>persistence,service,privilege_escalation,critical,</group>
  </rule>

  <!-- ── svchost.exe loading unusual DLL (Sysmon 7) ───────────────────────── -->

  <rule id="101078" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\svchost\.exe$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\public\\|\\downloads\\|\\programdata\\[^W])</field>
    <description>Sysmon ImageLoad: svchost loading DLL from user-writable path — hijacked service DLL (T1543.003)</description>
    <mitre><id>T1543.003</id></mitre>
    <group>persistence,service,dll_hijack,critical,</group>
  </rule>

  <!-- ── Service binary replaced (file write over existing .exe) ───────────── -->

  <rule id="101079" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\System32\\(svchost|lsass|services|winlogon)\.exe$</field>
    <description>Sysmon: system binary overwritten in System32 — binary replacement attack (T1574.001)</description>
    <mitre><id>T1574.001</id></mitre>
    <group>persistence,service,binary_replacement,critical,</group>
  </rule>

  <!-- ── Service stop + disable pattern (ransomware precursor) ─────────────── -->

  <rule id="101080" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)(sc\s+stop|sc\s+config.*disabled|net\s+stop).*(vss|sql|backup|spool|avp|windefend)</field>
    <description>Command: critical service stopped/disabled — ransomware precursor (backup/AV service impairment) (T1490, T1562.001)</description>
    <mitre><id>T1490</id></mitre>
    <mitre><id>T1562.001</id></mitre>
    <group>impact,service,ransomware_precursor,critical,</group>
  </rule>

</group>
