  </rule>

  <!-- ── net localgroup administrators add ─────────────────────────────────── -->

  <rule id="109016" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)net\s+localgroup\s+administrators\s+.*\/add</field>
