    <mitre><id>T1098</id></mitre>
    <group>privilege_escalation,local_admin_add,high_confidence,</group>
  </rule>

  <!-- ── PS Add-LocalGroupMember ────────────────────────────────────────────── -->

  <rule id="109017" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(Add-LocalGroupMember.*Administrators|Add-ADGroupMember.*(Domain Admins|Enterprise Admins))</field>
