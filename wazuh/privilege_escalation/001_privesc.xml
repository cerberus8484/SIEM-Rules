  <!-- ── RBCD (Resource-Based Constrained Delegation) attack ───────────────── -->

  <rule id="109037" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(msDS-AllowedToActOnBehalfOfOtherIdentity|Set-ADComputer.*PrincipalsAllowedToDelegateToAccount|RBCD)</field>
    <description>PowerShell: Resource-Based Constrained Delegation configured — RBCD privilege escalation (T1134.001)</description>
    <mitre><id>T1134.001</id></mitre>
    <group>privilege_escalation,rbcd,critical,</group>
  </rule>

  <!-- ── WriteDACL / WriteOwner on AD object ───────────────────────────────── -->

  <rule id="109038" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(Add-DomainObjectAcl|Set-DomainObjectOwner|WriteDACL|GenericWrite|GenericAll|AllExtendedRights)</field>
    <description>PowerShell: AD object ACL modification — privilege escalation via AD ACL abuse (T1098.001)</description>
    <mitre><id>T1098.001</id></mitre>
    <group>privilege_escalation,acl_abuse,high_confidence,</group>
  </rule>

  <!-- ── UAC bypass via CMSTPLUA COM ────────────────────────────────────────── -->

  <rule id="109039" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)HKCU\\Software\\Classes\\CLSID\\.*InprocServer32</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(powershell|cmd|wscript)</field>
    <description>Sysmon: HKCU CLSID COM server set from script — COM hijack UAC bypass preparation (T1548.002)</description>
    <mitre><id>T1548.002</id></mitre>
    <group>privilege_escalation,com_hijack,uac_bypass,critical,</group>
  </rule>

  <!-- ── Group Policy Object link to domain root ───────────────────────────── -->

  <rule id="109040" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^5136$</field>
    <field name="win.eventdata.ldapDisplayName" type="pcre2">(?i)gpLink</field>
    <field name="win.eventdata.objectDN" type="pcre2">(?i)DC=.*,DC=</field>
    <description>Windows Security: GPO linked at domain root level — domain-wide privilege escalation via GPO (T1484.001)</description>
    <mitre><id>T1484.001</id></mitre>
    <group>privilege_escalation,gpo_link,domain,critical,</group>
  </rule>

</group>
