    <mitre><id>T1574.010</id></mitre>
    <group>privilege_escalation,service_abuse,powershell,critical,</group>
  </rule>

  <!-- ── SID History injection ──────────────────────────────────────────────── -->

  <rule id="109021" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4765$|^4766$</field>
    <description>Windows Security: SID History added to account (Event 4765/4766) — AD privilege escalation via SID history (T1134.005)</description>
    <mitre><id>T1134.005</id></mitre>
    <group>privilege_escalation,sid_history,critical,</group>
  </rule>

  <!-- ── SDProp / AdminSDHolder modification ───────────────────────────────── -->

  <rule id="109022" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^5136$</field>
    <field name="win.eventdata.objectDN" type="pcre2">(?i)CN=AdminSDHolder</field>
    <description>Windows Security: AdminSDHolder modified — backdoor domain-level privilege escalation (T1098.001)</description>
    <mitre><id>T1098.001</id></mitre>
    <group>privilege_escalation,adminsd_holder,critical,</group>
  </rule>

  <!-- ── Kerberos unconstrained delegation ─────────────────────────────────── -->

  <rule id="109023" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4738$</field>
    <field name="win.eventdata.userAccountControl" type="pcre2">(?i)TRUSTED_FOR_DELEGATION</field>
