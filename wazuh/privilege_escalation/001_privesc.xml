  <!-- ── Phantom DLL hijacking (load order) ────────────────────────────────── -->

  <rule id="109030" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)\\(wlbsctrl|comsvcs|wbemcomn|oci|wlidsvc|cryptsp|ncobjapi)\.dll$</field>
