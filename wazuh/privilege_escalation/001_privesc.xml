    <mitre><id>T1068</id></mitre>
    <group>privilege_escalation,kernel_driver,critical,</group>
  </rule>

  <!-- ── Invoke-PsExec with SYSTEM ─────────────────────────────────────────── -->

  <rule id="109020" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(Invoke-PsExec|Invoke-ServiceAbuse|Write-ServiceBinary|Install-ServiceBinary)</field>
