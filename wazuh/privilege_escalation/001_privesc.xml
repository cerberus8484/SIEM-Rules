<!--
  HuntingThreats — Wazuh Hunt Rules
  Category:  Privilege Escalation (T1548, T1134, T1574, T1611)
  Batch:     1 / Privilege Escalation
  Rules:     109001 – 109040
  Platform:  Wazuh 4.x
  Sources:   Sysmon Event 1 (Process Creation)
             Windows Event 4688 (Process Creation)
             Windows Events 4672/4673 (Special Privilege)
             Sysmon Event 13 (Registry modification)
             Sysmon Event 7 (Image Load)

  T1548.002 — Abuse Elevation: UAC Bypass
  T1134     — Access Token Manipulation
  T1574     — Hijack Execution Flow (DLL order)
  T1055     — Process Injection (for privilege)
  T1611     — Escape to Host
  T1068     — Exploitation for Privilege Escalation
-->

<group name="hunt_privilege_escalation,windows,">

  <!-- ── Windows Event 4672 — admin privilege assigned at logon ────────────── -->

  <rule id="109001" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4672$</field>
    <field name="win.eventdata.subjectUserName" type="pcre2">(?i)(?!.*(SYSTEM|LOCAL SERVICE|NETWORK SERVICE)$)</field>
    <description>Windows Security: special privileges assigned to non-system account at logon (Event 4672) (T1134)</description>
    <mitre><id>T1134</id></mitre>
    <group>privilege_escalation,special_priv,</group>
  </rule>

  <!-- ── SeDebugPrivilege obtained ─────────────────────────────────────────── -->

  <rule id="109002" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4673$</field>
    <field name="win.eventdata.privileges" type="pcre2">(?i)SeDebugPrivilege</field>
    <description>Windows Security: SeDebugPrivilege requested — process can access any process memory (T1134)</description>
    <mitre><id>T1134</id></mitre>
    <group>privilege_escalation,sedebug,high_confidence,</group>
  </rule>

  <!-- ── Token theft (DuplicateTokenEx) ────────────────────────────────────── -->

  <rule id="109003" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(DuplicateTokenEx|ImpersonateLoggedOnUser|SetThreadToken|AdjustTokenPrivileges.*SeDebug)</field>
    <description>PowerShell: token impersonation/duplication API — privilege escalation via token theft (T1134.001)</description>
    <mitre><id>T1134.001</id></mitre>
    <group>privilege_escalation,token_theft,high_confidence,</group>
  </rule>

  <!-- ── UAC bypass — eventvwr.exe / registry hijack ─────────────────────── -->

  <rule id="109004" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)HKCU\\Software\\Classes\\mscfile\\shell\\open\\command</field>
    <description>Sysmon: eventvwr UAC bypass registry key set — HKCU COM hijack for elevation (T1548.002)</description>
    <mitre><id>T1548.002</id></mitre>
    <group>privilege_escalation,uac_bypass,eventvwr,critical,</group>
  </rule>

  <!-- ── UAC bypass — fodhelper registry ───────────────────────────────────── -->

  <rule id="109005" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)HKCU\\Software\\Classes\\ms-settings\\shell\\open\\command</field>
    <description>Sysmon: fodhelper UAC bypass registry key set — ms-settings COM hijack for elevation (T1548.002)</description>
    <mitre><id>T1548.002</id></mitre>
    <group>privilege_escalation,uac_bypass,fodhelper,critical,</group>
  </rule>

  <!-- ── runas.exe with different user ─────────────────────────────────────── -->

  <rule id="109006" level="8">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\runas\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(powershell|cmd|wscript)</field>
    <description>runas.exe: process executed as different user from script — credential-based elevation (T1134)</description>
    <mitre><id>T1134</id></mitre>
    <group>privilege_escalation,runas,</group>
  </rule>

  <!-- ── Unquoted service path exploitation ────────────────────────────────── -->

  <rule id="109007" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^11$</field>
    <field name="win.eventdata.targetFilename" type="pcre2">(?i)\\Program\.exe$|\\Program Files\.exe$|\\Common Files\.exe$</field>
    <description>Sysmon: binary planted in unquoted service path position — unquoted path privilege escalation (T1574.009)</description>
    <mitre><id>T1574.009</id></mitre>
    <group>privilege_escalation,unquoted_path,high_confidence,</group>
  </rule>

  <!-- ── DLL search order hijacking ────────────────────────────────────────── -->

  <rule id="109008" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)\\(System32|SysWOW64)\\.*\.dll$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(?!.*\\(svchost|msiexec|TiWorker|TrustedInstaller)\.exe)</field>
    <description>Sysmon: unsigned DLL loaded from System32 by non-system process — DLL hijacking (T1574.001)</description>
    <mitre><id>T1574.001</id></mitre>
    <group>privilege_escalation,dll_hijack,high_confidence,</group>
  </rule>

  <!-- ── Scheduled task as SYSTEM for privilege ────────────────────────────── -->

  <rule id="109009" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4698$</field>
    <field name="win.eventdata.taskContent" type="pcre2">(?i)(RunAs.*S-1-5-18|RunLevel.*HighestAvailable|Principal.*LocalSystem)</field>
    <description>Windows Security: scheduled task configured to run as SYSTEM — task-based privilege escalation (T1053.005, T1548)</description>
    <mitre><id>T1548</id></mitre>
    <group>privilege_escalation,schtask_system,high_confidence,</group>
  </rule>

  <!-- ── AlwaysInstallElevated registry key ────────────────────────────────── -->

  <rule id="109010" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^13$</field>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(HKLM|HKCU)\\SOFTWARE\\Policies\\Microsoft\\Windows\\Installer\\AlwaysInstallElevated</field>
    <field name="win.eventdata.details" type="pcre2">^1$|DWORD.*1</field>
    <description>Sysmon: AlwaysInstallElevated policy set — MSI executed as SYSTEM regardless of permissions (T1548.002)</description>
    <mitre><id>T1548.002</id></mitre>
    <group>privilege_escalation,always_install_elevated,critical,</group>
  </rule>

  <!-- ── msiexec installing from remote URL ────────────────────────────────── -->

  <rule id="109011" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$|^4688$</field>
    <field name="win.eventdata.image|win.eventdata.newProcessName" type="pcre2">(?i)\\msiexec\.exe$</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/i\s+(http[s]?:|\\\\[0-9a-zA-Z])</field>
    <description>msiexec.exe: MSI installed from remote location — remote MSI privilege escalation (T1548.002)</description>
    <mitre><id>T1548.002</id></mitre>
    <group>privilege_escalation,msiexec,remote_install,high_confidence,</group>
  </rule>

  <!-- ── PrintNightmare — Spool service exploitation ───────────────────────── -->

  <rule id="109012" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^7$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\spoolsv\.exe$</field>
    <field name="win.eventdata.imageLoaded" type="pcre2">(?i)(\\appdata\\|\\temp\\|\\downloads\\|\\Windows\\Temp\\).*\.dll$</field>
    <description>Sysmon: spoolsv.exe loading DLL from user-writable path — PrintNightmare/PrintSpooler exploitation (T1068)</description>
    <mitre><id>T1068</id></mitre>
    <group>privilege_escalation,printnightmare,critical,</group>
  </rule>

  <!-- ── Add user to local admin group ─────────────────────────────────────── -->

  <rule id="109013" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4732$</field>
