    <mitre><id>T1558</id></mitre>
    <group>privilege_escalation,unconstrained_delegation,high_confidence,</group>
  </rule>

  <!-- ── whoami /priv from suspicious process ──────────────────────────────── -->

  <rule id="109024" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\whoami\.exe$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(cmd|powershell|wscript)</field>
    <field name="win.eventdata.commandLine" type="pcre2">(?i)/priv</field>
    <description>Sysmon: whoami /priv — attacker checking their privileges post-escalation (T1033)</description>
    <mitre><id>T1033</id></mitre>
    <group>privilege_escalation,priv_check,</group>
  </rule>

  <!-- ── Token elevation via COM (IElevatedFactoryServer) ─────────────────── -->

  <rule id="109025" level="12">
    <if_group>windows</if_group>
