    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^4103$|^4104$</field>
    <field name="win.eventdata.scriptBlockText" type="pcre2">(?i)(Invoke-PrivescCheck|Invoke-AllChecks|PowerUp|Get-ModifiableServiceFile|Get-UnquotedService|Get-ServiceUnquoted)</field>
