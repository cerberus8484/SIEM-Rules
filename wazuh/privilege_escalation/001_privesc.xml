    <description>PowerShell: named pipe impersonation — token theft via pipe for privilege escalation (T1134.001)</description>
    <mitre><id>T1134.001</id></mitre>
    <group>privilege_escalation,named_pipe,high_confidence,</group>
  </rule>

  <!-- ── Exploitation via JuicyPotato / RoguePotato ───────────────────────── -->

