  <!-- ── Exploit known vulnerability — known CVE patterns ─────────────────── -->

  <rule id="109018" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^1$</field>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)\\(spoolsv|lsass|winlogon|svchost)\.exe$</field>
    <field name="win.eventdata.image" type="pcre2">(?i)\\(cmd|powershell|wscript|cscript|mshta)\.exe$</field>
    <description>Sysmon: scripting engine spawned by system process — possible service/driver exploitation (T1068)</description>
    <mitre><id>T1068</id></mitre>
    <group>privilege_escalation,service_exploit,critical,</group>
  </rule>

  <!-- ── Kernel exploit loading driver ─────────────────────────────────────── -->

  <rule id="109019" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID" type="pcre2">^6$</field>
    <field name="win.eventdata.signed" type="pcre2">^false$</field>
