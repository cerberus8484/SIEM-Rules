<!--
  HuntingThreats — Sysmon Config: Credential Theft + Lateral Movement
  =====================================================================
  Scenario : Post-compromise credential harvesting and lateral movement
  Goal     : Catch Mimikatz, LSASS dump, DCSync, PsExec, WMI remote,
             Pass-the-Hash, and named pipe abuse
  MITRE    : T1003 (OS Credential Dumping), T1558 (Kerberoasting),
             T1550 (Use Alternate Auth Material), T1021 (Remote Services),
             T1047 (WMI), T1570 (Lateral Tool Transfer)
  Pack     : credential_access.spl, lateral_movement.spl, identity.spl

  Install  : sysmon64.exe -accepteula -i credential-theft-lateral-movement.xml
  Update   : sysmon64.exe -c credential-theft-lateral-movement.xml

  Event coverage:
    Event 1  ProcessCreate  - credential dumping tools, lateral movement tools
    Event 3  NetworkConnect - SMB/RDP/WMI to remote hosts from unusual processes
    Event 8  CreateRemoteThread - process injection (all)
    Event 10 ProcessAccess  - LSASS access with privileged access masks
    Event 11 FileCreate     - procdump output, credential files
    Event 13 RegistryEvent  - SAM/SECURITY/SYSTEM hive access indicators
    Event 17 PipeEvent      - named pipe creation (PsExec, Mimikatz, CobaltStrike)
    Event 18 PipeEvent      - named pipe connection
-->
<Sysmon schemaversion="4.90">

  <HashAlgorithms>SHA256,IMPHASH</HashAlgorithms>
  <CheckRevocation/>

  <EventFiltering>

    <!-- ================================================================
         EVENT 1 — Process Create: Credential Theft + Lateral Movement Tools
         ================================================================ -->
    <RuleGroup name="ProcessCreate-CredTheft" groupRelation="or">
      <ProcessCreate onmatch="include">

        <!-- Mimikatz and variants — T1003 -->
        <CommandLine condition="contains">sekurlsa</CommandLine>
        <CommandLine condition="contains">logonpasswords</CommandLine>
        <CommandLine condition="contains">lsadump</CommandLine>
        <CommandLine condition="contains">dcsync</CommandLine>
        <CommandLine condition="contains">kerberos::ptt</CommandLine>
        <CommandLine condition="contains">kerberos::list</CommandLine>
        <CommandLine condition="contains">privilege::debug</CommandLine>
        <CommandLine condition="contains">token::elevate</CommandLine>
        <CommandLine condition="contains">vault::cred</CommandLine>
        <CommandLine condition="contains">dpapi::cred</CommandLine>
        <OriginalFileName condition="contains">mimikatz</OriginalFileName>

        <!-- ProcDump targeting LSASS — T1003.001 -->
        <CommandLine condition="contains all">procdump;lsass</CommandLine>
        <CommandLine condition="contains all">procdump;-ma;lsass</CommandLine>
        <CommandLine condition="contains all">procdump64;lsass</CommandLine>

        <!-- Task Manager LSASS dump (Create Dump File menu item) -->
        <CommandLine condition="contains all">TaskMgr;-AcceptEula;lsass</CommandLine>

        <!-- SQLDumper LSASS (LOLBin) -->
        <CommandLine condition="contains all">sqldumper;lsass</CommandLine>

        <!-- comsvcs.dll MiniDump — T1003.001 LOLBin -->
        <CommandLine condition="contains all">comsvcs;MiniDump</CommandLine>
        <CommandLine condition="contains all">comsvcs.dll;MiniDump</CommandLine>
        <CommandLine condition="contains">Out-Minidump</CommandLine>

        <!-- NTDSUtil — NTDS.dit extraction — T1003.003 -->
        <CommandLine condition="contains">ntdsutil</CommandLine>
        <CommandLine condition="contains">ac i ntds</CommandLine>
        <CommandLine condition="contains">ifm</CommandLine>

        <!-- VSS-based NTDS.dit copy -->
        <CommandLine condition="contains all">vssadmin;ntds.dit</CommandLine>
        <CommandLine condition="contains all">copy;ntds.dit</CommandLine>

        <!-- DCSync indicators (Impacket secretsdump) — T1003.006 -->
        <CommandLine condition="contains">secretsdump</CommandLine>
        <CommandLine condition="contains">GetNPUsers</CommandLine>
        <CommandLine condition="contains">GetUserSPNs</CommandLine>

        <!-- Lateral movement: PsExec — T1570 -->
        <Image condition="end with">PsExec.exe</Image>
        <Image condition="end with">PsExec64.exe</Image>
        <Image condition="contains">PSEXESVC</Image>
        <OriginalFileName condition="is">psexec.c</OriginalFileName>

        <!-- WMI remote execution — T1047 -->
        <CommandLine condition="contains all">wmic;/node:</CommandLine>
        <CommandLine condition="contains all">wmic;process call create</CommandLine>

        <!-- Remote PowerShell session — T1021.006 -->
        <CommandLine condition="contains">New-PSSession</CommandLine>
        <CommandLine condition="contains">Enter-PSSession</CommandLine>
        <CommandLine condition="contains">Invoke-Command</CommandLine>
        <CommandLine condition="contains">-ComputerName</CommandLine>

        <!-- Pass-the-Hash / Pass-the-Ticket tools -->
        <CommandLine condition="contains">Invoke-WMIExec</CommandLine>
        <CommandLine condition="contains">Invoke-SMBExec</CommandLine>
        <CommandLine condition="contains">Invoke-TheHash</CommandLine>
        <CommandLine condition="contains">Get-GPPPassword</CommandLine>

        <!-- Credential access tools -->
        <CommandLine condition="contains">LaZagne</CommandLine>
        <CommandLine condition="contains">pypykatz</CommandLine>
        <CommandLine condition="contains">lsassy</CommandLine>
        <CommandLine condition="contains">SharpDump</CommandLine>
        <CommandLine condition="contains">Rubeus</CommandLine>
        <CommandLine condition="contains">ASREPRoast</CommandLine>
        <CommandLine condition="contains">Invoke-Kerberoast</CommandLine>

        <!-- Registry SAM/SECURITY/SYSTEM hive save — T1003.002 -->
        <CommandLine condition="contains all">reg save;hklm\sam</CommandLine>
        <CommandLine condition="contains all">reg save;hklm\security</CommandLine>
        <CommandLine condition="contains all">reg save;hklm\system</CommandLine>

      </ProcessCreate>
    </RuleGroup>

    <!-- ================================================================
         EVENT 3 — Network Connection: Lateral Movement Ports
         ================================================================ -->
    <RuleGroup name="NetworkConnect-LateralMovement" groupRelation="or">
      <NetworkConnect onmatch="include">

        <!-- SMB from scripting engines / unusual processes — T1021.002 -->
        <DestinationPort condition="is">445</DestinationPort>
        <DestinationPort condition="is">139</DestinationPort>

        <!-- WMI DCOM — T1047 -->
        <DestinationPort condition="is">135</DestinationPort>

        <!-- RDP — T1021.001 -->
        <DestinationPort condition="is">3389</DestinationPort>

        <!-- WinRM — T1021.006 -->
        <DestinationPort condition="is">5985</DestinationPort>
        <DestinationPort condition="is">5986</DestinationPort>

      </NetworkConnect>
    </RuleGroup>

    <RuleGroup name="NetworkConnect-LM-Exclude" groupRelation="or">
      <NetworkConnect onmatch="exclude">
        <!-- Exclude Server processes that legitimately serve these ports -->
        <Image condition="is">C:\Windows\system32\lsass.exe</Image>
        <Image condition="is">C:\Windows\system32\svchost.exe</Image>
        <!-- Exclude loopback -->
        <DestinationIp condition="is">127.0.0.1</DestinationIp>
        <DestinationIp condition="is">::1</DestinationIp>
      </NetworkConnect>
    </RuleGroup>

    <!-- ================================================================
         EVENT 8 — CreateRemoteThread: Process Injection
         Log all (exclude browsers + known AV)
         ================================================================ -->
    <RuleGroup name="CreateRemoteThread-Injection" groupRelation="or">
      <CreateRemoteThread onmatch="exclude">
        <SourceImage condition="end with">chrome.exe</SourceImage>
        <SourceImage condition="end with">msedge.exe</SourceImage>
        <SourceImage condition="end with">firefox.exe</SourceImage>
        <SourceImage condition="begin with">C:\Program Files\Windows Defender\</SourceImage>
      </CreateRemoteThread>
    </RuleGroup>

    <!-- ================================================================
         EVENT 10 — Process Access: LSASS with privileged access masks
         Key access masks for credential extraction:
           0x1010 = PROCESS_QUERY_LIMITED_INFORMATION | PROCESS_VM_READ
           0x1410 = includes PROCESS_VM_READ
           0x0410 = PROCESS_QUERY_INFORMATION | PROCESS_VM_READ
           0x143A = common Mimikatz mask
         ================================================================ -->
    <RuleGroup name="ProcessAccess-CredTheft" groupRelation="or">
      <ProcessAccess onmatch="include">
        <TargetImage condition="end with">lsass.exe</TargetImage>
      </ProcessAccess>
    </RuleGroup>

    <RuleGroup name="ProcessAccess-CredTheft-Exclude" groupRelation="or">
      <ProcessAccess onmatch="exclude">
        <!-- Legitimate system access to LSASS -->
        <SourceImage condition="is">C:\Windows\system32\svchost.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\system32\wininit.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\system32\csrss.exe</SourceImage>
        <SourceImage condition="is">C:\Windows\System32\taskmgr.exe</SourceImage>
        <SourceImage condition="begin with">C:\Program Files\Windows Defender\</SourceImage>
        <!-- Add your EDR agent here:
        <SourceImage condition="begin with">C:\Program Files\CrowdStrike\</SourceImage>
        <SourceImage condition="begin with">C:\Program Files\SentinelOne\</SourceImage>
        -->
        <!-- Low-privilege access masks (query info only) -->
        <GrantedAccess condition="is">0x1000</GrantedAccess>
        <GrantedAccess condition="is">0x100000</GrantedAccess>
        <GrantedAccess condition="is">0x0400</GrantedAccess>
      </ProcessAccess>
    </RuleGroup>

    <!-- ================================================================
         EVENT 11 — File Create: Credential Dump Output Files
         ================================================================ -->
    <RuleGroup name="FileCreate-CredDump" groupRelation="or">
      <FileCreate onmatch="include">
        <!-- Common procdump / minidump output names -->
        <TargetFilename condition="end with">.dmp</TargetFilename>
        <TargetFilename condition="end with">.mdmp</TargetFilename>
        <!-- Specific credential dump filenames -->
        <TargetFilename condition="contains">lsass</TargetFilename>
        <TargetFilename condition="contains">ntds.dit</TargetFilename>
        <TargetFilename condition="contains">SAM</TargetFilename>
        <TargetFilename condition="contains">SECURITY</TargetFilename>
        <TargetFilename condition="contains">SYSTEM</TargetFilename>
        <!-- Mimikatz log output -->
        <TargetFilename condition="end with">kerberos.kirbi</TargetFilename>
      </FileCreate>
    </RuleGroup>

    <!-- ================================================================
         EVENTS 17/18 — Named Pipe Create/Connect
         PsExec:     \PSEXESVC
         Mimikatz:   \mimikatz, \mimi*
         CobaltStrike: \msagent_*, \MSSE-*, \postex_*, \status_*
         Meterpreter: \meterpreter
         ================================================================ -->
    <RuleGroup name="PipeEvent-Suspicious" groupRelation="or">
      <PipeEvent onmatch="include">

        <!-- PsExec service pipe -->
        <PipeName condition="begin with">\PSEXESVC</PipeName>
        <PipeName condition="begin with">\psexesvc</PipeName>

        <!-- Mimikatz -->
        <PipeName condition="begin with">\mimikatz</PipeName>
        <PipeName condition="begin with">\mimi</PipeName>

        <!-- Cobalt Strike malleable C2 defaults -->
        <PipeName condition="begin with">\msagent_</PipeName>
        <PipeName condition="begin with">\MSSE-</PipeName>
        <PipeName condition="begin with">\postex_</PipeName>
        <PipeName condition="begin with">\status_</PipeName>
        <PipeName condition="begin with">\halfduplexpipe</PipeName>
        <PipeName condition="begin with">\fullduplexpipe</PipeName>
        <PipeName condition="begin with">\mypipe-</PipeName>
        <PipeName condition="begin with">\ntsvcs</PipeName>

        <!-- Meterpreter default -->
        <PipeName condition="begin with">\meterpreter</PipeName>

        <!-- Empire/PowerShell C2 -->
        <PipeName condition="begin with">\empire_</PipeName>
        <PipeName condition="begin with">\pwshnet</PipeName>

        <!-- RemCom (open-source PsExec alternative) -->
        <PipeName condition="begin with">\RemCom</PipeName>
        <PipeName condition="begin with">\remcom</PipeName>

      </PipeEvent>
    </RuleGroup>

  </EventFiltering>
</Sysmon>
